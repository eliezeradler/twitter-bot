5d5\u05db\u05d9\u05dd \u05d5\u05d1...", "\ud83d\uddbc \u05de\u05e9\u05d4 \u05d5\u05d9\u05e1\u05d1\u05e8\u05d2: \u05db\u05d9\u05e0\u05d5\u05e1 \u05d4\u05d9\u05e1\u05d8\u05d5\u05e8\u05d9 \u05dc\u05db\u05dc\u05dc \u05e8\u05d1\u05e0\u05d9 \u05d4\u05e7\u05d4\u05d9\u05dc\u05d5\u05ea \u05de\u05db\u05dc \u05e8\u05d7\u05d1\u05d9 \u05d4\u05d0\u05e8\u05e5 \u05d9\u05d9\u05e2\u05e8\u05da \u05de\u05d7\u05e8 \u05d1\u05de\u05e2\u05de\u05d3 \u05de\u05e8\u05e0\u05df \u05d5...", "\ud83c\udfac \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05de\u05e9\u05d4 \u05d5\u05d9\u05e1\u05d1\u05e8\u05d2", "\u05d0\u05e8\u05d2\u05d5\u05df \u05d7\u05d5\u05e0\u05e0\u05d5 \u05e4\u05e0\u05d4 \u05dc\u05de\u05e4\u05e7\u05d3 \u05de\u05d7\u05d5\u05d6 \u05d9\u05e8\u05d5\u05e9\u05dc\u05d9\u05dd \u05d1\u05d3\u05e8\u05d9\u05e9\u05d4 \u05dc\u05d7\u05e7\u05d5\u05e8 \u05db\"\u05e0\u05d9\u05e1\u05d9\u05d5\u05df \u05dc\u05e8\u05e6\u05d7\" \u05d0\u05ea \u05ea\u05e7\u05d9\u05e4\u05ea \u05e9\u05dc\u05d5\u05e9\u05ea \u05d4\u05d9\u05d4\u05d5...", "\u05d3\u05e4\u05e0\u05d4 \u05dc\u05d9\u05d0\u05dc", "\u05d1\u05e0\u05d8 \u05de\u05d2\u05d9\u05d1 \u05dc\u05de\u05e9\u05d1\u05e8 \u05d1\u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7: \u05d9\u05d5\"\u05e8 \u05de\u05e4\u05dc\u05d2\u05ea '\u05d1\u05d9\u05d7\u05d3' \u05e0\u05e4\u05ea\u05dc\u05d9 \u05d1\u05e0\u05d8, \u05ea\u05e7\u05e3 \u05d0\u05ea \u05d4\u05de\u05e6\u05d1 \u05d1\u05e2\u05e7\u05d1\u05d5\u05ea \u05d4\u05d7\u05dc\u05d8\u05ea \u05d4\u05d4\u05e1\u05ea\u05d3\u05e8...", "\u05e6\u05d1\u05d0 \u05d9\u05e8\u05d3\u05df: \u05e9\u05d5\u05d2\u05e8\u05d5 \u05dc\u05e2\u05d1\u05e8 \u05d9\u05e8\u05d3\u05df 4 \u05d8\u05d9\u05dc\u05d9\u05dd \u05d0\u05d9\u05e8\u05d0\u05e0\u05d9\u05dd. \u05d9\u05d9\u05e8\u05d8\u05e0\u05d5 \u05e9\u05dc\u05d5\u05e9\u05d4 \u05d5\u05d0\u05d7\u05d3 \u05e0\u05e4\u05dc \u05d1\u05d0\u05d6\u05d5\u05e8 \u05dc\u05d0 \u05de\u05d9\u05d5\u05e9\u05d1.", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05de\u05e2\u05e8\u05db\u05d5\u05df \u05e2\u05dc \u05e2\u05d9\u05e8\u05d9\u05d9\u05ea \u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7 \u05de\u05e9\u05e0\u05d5\u05ea \u05d4-90", "\ud83c\udfac \u05e6\u05d5\u05dc\u05dc\u05ea \u05e9\u05dc \u05d7\u05d9\u05dc \u05d4\u05d9\u05dd \u05e0\u05e6\u05e4\u05ea\u05d4 \u05d1\u05d0\u05d5\u05e4\u05df \u05e0\u05d3\u05d9\u05e8 \u05de\u05e2\u05dc \u05d4\u05de\u05d9\u05dd \u05d5\u05e7\u05e8\u05d5\u05d1 \u05de\u05d0\u05d5\u05d3 \u05dc\u05d7\u05d5\u05e3 \u05d1\u05d0\u05d9\u05dc\u05ea, \u05dc\u05e2\u05d9\u05e0\u05d9 \u05d4\u05e8\u05d5\u05d7\u05e6\u05d9\u05dd ...", "*\u05d3\u05d9\u05d5\u05d5\u05d7\u05d9\u05dd \u05e2\u05dc \u05e4\u05d9\u05e6\u05d5\u05e6\u05d9\u05dd \u05d1\u05db\u05d5\u05d5\u05d9\u05ea*", "\u05e9\u05e8 \u05d4\u05d7\u05d5\u05e5 \u05e9\u05dc \u05d0\u05d9\u05e8\u05d0\u05df \u05e2\u05d1\u05d0\u05e1 \u05e2\u05e8\u05d0\u05e7\u05e6'\u05d9: \u05d0\u05dd \u05d4\u05e4\u05e1\u05e7\u05ea \u05d4\u05d0\u05e9 \u05d4\u05d9\u05d9\u05ea\u05d4 \u05de\u05d5\u05db\u05e8\u05d6\u05ea \u05e2\u05e9\u05e8\u05d4 \u05d9\u05de\u05d9\u05dd \u05e7\u05d5\u05d3\u05dd, \u05dc\u05d0\u05e8\u05d9\u05d2'\u05d0\u05e0\u05d9 \u05d5...", "\ud83d\uddbc \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d4\u05e9\u05d3\u05e8\u05df \u05d5\u05db\u05d5\u05db\u05d1 \u05d4\u05d9\u05dc\u05d3\u05d9\u05dd \u05d9\u05e8\u05d5\u05df \u05d1\u05e8 \u05d4\u05e6\u05d8\u05e8\u05e3 \u05dc\u05de\u05e9\u05e4\u05d7\u05ea \u05de\u05d8\u05e8\u05d5\u05e4\u05d5\u05dc\u05d9\u05df \u05d1\u05d0\u05dc\u05e2\u05d3, \u05e0\u05d0\u05d7\u05dc \u05dc\u05d5 \u05d1\u05d4\u05e6\u05dc\u05d7\u05d4", "\ud83c\udfac \u05de\u05d4\u05d5\u05de\u05d4 \u05d1\u05d0\u05dc\u05e2\u05d3: \u05d0\u05dc\u05de\u05d5\u05e0\u05d9\u05dd \u05e4\u05e8\u05e6\u05d5 \u05dc\u05e8\u05db\u05d1 \u05de\u05e1\u05d7\u05e8\u05d9 \u05d1\u05e8\u05d7\u05d5\u05d1 \u05d9\u05d5\u05d7\u05e0\u05df \u05d1\u05df \u05d6\u05db\u05d0\u05d9 \u05d1\u05d0\u05de\u05e6\u05e2\u05d5\u05ea \u05e9\u05dc\u05d8 \u05d0\u05d5\u05e0\u05d9\u05d1\u05e8\u05e1\u05dc\u05d9, ...", "\u05d0\u05d5\u05e8 \u05e8\u05d1\u05d9\u05d3", "\u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05e2\u05e6\u05e8\u05ea \u05d4\u05e8\u05d1\u05d1\u05d5\u05ea \u05e9\u05dc \u05d2\u05d5\u05e8 \u05de\u05d7\u05e8 \u05d1\u05dc\u05d9\u05dc\u05d4: \u05de\u05d5\u05d8\u05d9 \u05d1\u05d1\u05e6'\u05d9\u05e7 (\u05d1'\u05e9\u05e0\u05d4' \u05e2\u05dc \u05e4\u05d8\u05d9\u05e8\u05ea \u05d0\u05d1\u05d9\u05d5) \u05d9\u05e2\u05d1\u05d5\u05e8 \u05dc\u05e4\u05e0\u05d9 \u05d4\u05ea...", "\u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05e0\u05e4\u05d2\u05e9 \u05e2\u05dd \u05e8\u05d0\u05e9\u05d9 \u05e2\u05e8\u05d9\u05dd \u05de\u05d4\u05dc\u05d9\u05db\u05d5\u05d3 \u05dc\u05e7\u05e8\u05d0\u05ea \u05d4\u05d1\u05d7\u05d9\u05e8\u05d5\u05ea: \"\u05d0\u05dd \u05d4\u05de\u05e6\u05d1 \u05d4\u05d1\u05d9\u05d8\u05d7\u05d5\u05e0\u05d9 \u05d9\u05d7\u05d9\u05d9\u05d1 - \u05d4\u05e4\u05e8\u05d9\u05d9\u05de\u05e8\u05d9\u05d6...", "\ud83c\udfac \u05e9\u05e8\u05d9\u05e4\u05d4 \u05e4\u05e8\u05e6\u05d4 \u05d1\u05e9\u05de\u05d5\u05e8\u05ea \u05d4\u05d8\u05d1\u05e2 \u05e6\u05d9\u05e4\u05d5\u05e8 \u05e9\u05d1\u05d1\u05e7\u05e2\u05ea \u05d4\u05d9\u05e8\u05d3\u05df, \u05d0\u05e8\u05d1\u05e2\u05d4 \u05de\u05d8\u05d5\u05e1\u05d9 \u05db\u05d9\u05d1\u05d5\u05d9 \u05d4\u05d5\u05d6\u05e0\u05e7\u05d5.", "\ud83c\udfac \u05d0\u05d9\u05dc\u05ea: \u05e6\u05d5\u05dc\u05dc\u05ea \u05e9\u05dc \u05d7\u05d9\u05dc \u05d4\u05d9\u05dd \u05e0\u05e6\u05e4\u05ea\u05d4 \u05d1\u05d0\u05d5\u05e4\u05df \u05e0\u05d3\u05d9\u05e8 \u05de\u05e2\u05dc \u05d4\u05de\u05d9\u05dd \u05d5\u05e7\u05e8\u05d5\u05d1 \u05de\u05d0\u05d5\u05d3 \u05dc\u05d7\u05d5\u05e3. (\u05e7\u05d3\u05d5\u05e9)", "\ud83d\uddbc \u05d4\u05e2\u05e8\u05d9\u05e0\u05d2: \u05d9\u05e9\u05d9\u05d1\u05d5\u05e2\u05d7\u05e8 \u05d4\u05d6\u05de\u05d9\u05df \u05d1\u05e8\u05d3 \u05d1\u05e6\u05d1\u05e2\u05d9 \u05d0\u05e8\u05d2\u05e0\u05d8\u05d9\u05e0\u05d4 - \u05e1\u05e4\u05e8\u05d3. \u05e7\u05d5\u05d3 \u05e7\u05d5\u05e4\u05d5\u05df: \u05dc\u05d7\u05d5\u05d1\u05d1\u05d9 \u05d4\u05d6'\u05d0\u05e0\u05e8.", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d9\u05e9\u05e8\u05d0\u05dc \u05db\u05d4\u05df", "\ud83c\udfac *\u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05e1\u05e7\u05d5\u05e4\u05d9\u05dd*", "\u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05e9\u05e8 \u05d4\u05d1\u05d9\u05d8\u05d7\u05d5\u05df \u05d9\u05e9\u05e8\u05d0\u05dc \u05db\u05e5: \u05d0\u05dd \u05d0\u05d9\u05e8\u05df \u05ea\u05d9\u05e8\u05d4 \u05d8\u05d9\u05dc\u05d9\u05dd \u05e2\u05dc \u05d9\u05e9\u05e8\u05d0\u05dc - \u05e0\u05ea\u05e7\u05d5\u05e3 \u05d0\u05d5\u05ea\u05d4 \u05d1\u05e2\u05d5\u05e6\u05de\u05d4 \u05d1\u05dc\u05d9 \u05e9\u05d5\u05dd ...", "\ud83c\udfac \u05e9\u05e8 \u05d4\u05d1\u05d9\u05d8\u05d7\u05d5\u05df \u05d9\u05e9\u05e8\u05d0\u05dc \u05db\u05f4\u05e5 \u05de\u05ea\u05d9\u05d9\u05d7\u05e1 \u05dc\u05d0\u05e4\u05e9\u05e8\u05d5\u05ea \u05e9\u05dc \u05d4\u05e1\u05dc\u05de\u05d4 \u05de\u05d5\u05dc \u05d0\u05d9\u05e8\u05d0\u05df \u05d1\u05d1\u05d9\u05e7\u05d5\u05e8\u05d5 \u05d1\u05de\u05e8\u05dc\u05d5\u05d2 \u05d4\u05d0\u05e8\u05e6\u05d9 \u05e9\u05dc ...", "\ud83d\uddbc \u2022 \u05e0\u05e4\u05d2\u05e2 \u05de\u05e8\u05db\u05d1: \u05db\u05d5\u05d7\u05d5\u05ea \u05d4\u05e6\u05dc\u05d4 \u05d4\u05d5\u05d6\u05e2\u05e7\u05d5 \u05d1\u05e9\u05e2\u05d4 16:05 \u05dc\u05e8\u05d7\u05d5\u05d1 \u05d0\u05de\u05e8\u05d9 \u05d1\u05e8\u05d5\u05da \u05d1\u05e2\u05d9\u05e8, \u05d1\u05e2\u05e7\u05d1\u05d5\u05ea \u05d3\u05d9\u05d5\u05d5\u05d7 \u05e2\u05dc \u05ea\u05d0\u05d5...", "\ud83d\uddbc \u05d1\u05d5\u05db\u05d4\u05d4\u05d4\u05d4\ud83d\udc80\ud83e\udd23", "\ud83d\uddbc \u05d4\u05d0\u05d9\u05d7\u05d5\u05d3 \u05d4\u05d0\u05d9\u05e8\u05d5\u05e4\u05d0\u05d9 \u05d3\u05d5\u05e8\u05e9 \u05e9\u05de\u05e9\u05e0\u05ea 2027 \u05db\u05dc \u05d4\u05d8\u05dc\u05e4\u05d5\u05e0\u05d9\u05dd \u05d4\u05e0\u05d9\u05d9\u05d3\u05d9\u05dd \u05d5\u05de\u05db\u05e9\u05d9\u05e8\u05d9 \u05d4\u05de\u05d5\u05d1\u05d9\u05d9\u05dc \u05d9\u05d9\u05de\u05db\u05e8\u05d5 \u05e2\u05dd \u05e1\u05d5...", "\u05e9\u05e8 \u05d4\u05d1\u05d9\u05d8\u05d7\u05d5\u05df: \u05d4\u05d5\u05d3\u05e2\u05e0\u05d5 \u05e9\u05d0\u05dd \u05d0\u05d9\u05e8\u05df \u05ea\u05d9\u05e8\u05d4 \u05d8\u05d9\u05dc\u05d9\u05dd \u05e2\u05dc \u05d9\u05e9\u05e8\u05d0\u05dc - \u05e0\u05ea\u05e7\u05d5\u05e3 \u05d0\u05d5\u05ea\u05d4 \u05d1\u05e2\u05d5\u05e6\u05de\u05d4 \u05d1\u05dc\u05d9 \u05e9\u05d5\u05dd \u05ea\u05dc\u05d5\u05ea \u05d0\u05d5 ...", "\ud83d\uddbc \u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05e1\u05e7\u05d5\u05e4\u05d9\u05dd", "\u05e9\u05e8 \u05d4\u05d1\u05d9\u05d8\u05d7\u05d5\u05df \u05d9\u05e9\u05e8\u05d0\u05dc \u05db\"\u05e5: \"\u05d0\u05dd \u05d0\u05d9\u05e8\u05d0\u05df \u05ea\u05ea\u05e7\u05d5\u05e3 \u05d0\u05ea \u05d9\u05e9\u05e8\u05d0\u05dc \u05d9\u05e9\u05e8\u05d0\u05dc \u05ea\u05d2\u05d9\u05d1 \u05d5\u05ea\u05ea\u05e7\u05d5\u05e3 \u05d1\u05d7\u05d6\u05e8\u05d4 \u05d1\u05dc\u05d9 \u05e9\u05d5\u05dd \u05ea\u05dc\u05d5\u05ea ...", "\ud83c\udfac \u05d4\u05d0\u05d5\u05d8\u05d5\u05d1\u05d5\u05e1\u05d9\u05dd \u05d4\u05ea\u05e0\u05d2\u05e9\u05d5, \u05e9\u05de\u05df \u05e0\u05e9\u05e4\u05da \u05d1\u05db\u05d1\u05d9\u05e9: \u05db\u05d5\u05d7\u05d5\u05ea \u05d4\u05e6\u05dc\u05d4 \u05d4\u05d5\u05d6\u05e2\u05e7\u05d5 \u05d1\u05e9\u05e2\u05d4 12:00 \u05dc\u05e8\u05d7\u05d5\u05d1 \u05d1\u05df \u05d2\u05d5\u05e8\u05d9\u05d5\u05df \u05e4\u05d9...", "\u05e9\u05e8 \u05d4\u05d1\u05d9\u05d8\u05d7\u05d5\u05df \u05d9\u05e9\u05e8\u05d0\u05dc \u05db\"\u05e5 \u05d4\u05ea\u05d9\u05d9\u05d7\u05e1 \u05d4\u05d9\u05d5\u05dd \u05dc\u05d0\u05e4\u05e9\u05e8\u05d5\u05ea \u05e9\u05dc \u05d4\u05e1\u05dc\u05de\u05d4 \u05de\u05d5\u05dc \u05d0\u05d9\u05e8\u05d0\u05df, \u05dc\u05d0\u05d7\u05e8 \u05d4\u05d9\u05e8\u05d9 \u05d4\u05d0\u05d9\u05e8\u05d0\u05e0\u05d9 \u05dc\u05d9\u05e8\u05d3...", "\u05d3\u05e8\u05de\u05d4 \u05d1\u05dc\u05d9\u05db\u05d5\u05d3: \u05d1\u05d9\u05ea \u05d4\u05d3\u05d9\u05df \u05d3\u05d5\u05d7\u05d4 \u05d1\u05e9\u05e0\u05d9\u05ea \u05d0\u05ea \u05e4\u05e0\u05d9\u05d9\u05ea\u05d5 \u05e9\u05dc \u05e2\u05d5''\u05d3 \u05d1\u05d5\u05de\u05d1\u05da \u05d1\u05e9\u05dd \u05d7\u05d9\u05d9\u05dd \u05db\u05e5 \u05dc\u05db\u05d9\u05e0\u05d5\u05e1 \u05d5\u05e2\u05d3\u05ea \u05d4\u05d7...", "\u05e9\u05e8 \u05d4\u05d1\u05d9\u05d8\u05d7\u05d5\u05df \u05d9\u05e9\u05e8\u05d0\u05dc \u05db''\u05e5 \u05dc\u05d0\u05d7\u05e8 \u05d4\u05d9\u05e8\u05d9 \u05d4\u05d0\u05d9\u05e8\u05d0\u05e0\u05d9 \u05dc\u05d9\u05e8\u05d3\u05df \u05d4\u05d9\u05d5\u05dd: \"\u05d0\u05dd \u05d0\u05d9\u05e8\u05d0\u05df \u05ea\u05ea\u05e7\u05d5\u05e3 \u05d0\u05ea \u05d9\u05e9\u05e8\u05d0\u05dc, \u05d9\u05e9\u05e8\u05d0\u05dc \u05ea...", "*\u05e9\u05e8 \u05d4\u05d1\u05d9\u05d8\u05d7\u05d5\u05df:*", "\ud83c\udfac \u05e0\u05e9\u05d9\u05d0 \u05dc\u05d1\u05e0\u05d5\u05df \u05de\u05d2\u05d9\u05e2 \u05dc\u05d1\u05e0\u05d9\u05d9\u05df \u05de\u05e9\u05e8\u05d3 \u05d4\u05d7\u05d5\u05e5 \u05d4\u05d0\u05de\u05e8\u05d9\u05e7\u05d0\u05d9.", "\u05d1\u05d9\u05ea \u05d4\u05d3\u05d9\u05df \u05e9\u05dc \u05d4\u05dc\u05d9\u05db\u05d5\u05d3 \u05d3\u05d7\u05d4 \u05d0\u05ea \u05e4\u05e0\u05d9\u05d9\u05ea \u05d4\u05e9\u05e8 \u05d7\u05d9\u05d9\u05dd \u05db\u05e5 \u05dc\u05db\u05d9\u05e0\u05d5\u05e1 \u05d5\u05e2\u05d3\u05ea \u05d4\u05d7\u05d5\u05e7\u05d4 \u05de\u05d7\u05d3\u05e9. \u05d0\u05dd \u05ea\u05ea\u05db\u05e0\u05e1 \u05d4\u05d5\u05d5\u05e2\u05d3\u05d4 ...", "\u05d2\u05d5\u05e8\u05de\u05d9\u05dd \u05d1\u05dc\u05d9\u05db\u05d5\u05d3 \u05de\u05d0\u05e9\u05e8\u05d9\u05dd: \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05de\u05e7\u05d3\u05dd \u05d4\u05e7\u05de\u05ea \u05d5\u05e2\u05d3\u05d4 \u05de\u05e1\u05d3\u05e8\u05ea \u05e9\u05ea\u05e7\u05d1\u05e2 \u05d0\u05ea \u05e8\u05e9\u05d9\u05de\u05ea \u05d4\u05de\u05e4\u05dc\u05d2\u05d4, \u05d1\u05de\u05e7\u05e8\u05d4 \u05e9\u05d4\u05de...", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d4\u05d2\u05e8\u05e9\u05f4\u05d1 \u05e1\u05d5\u05e8\u05d5\u05e6\u05e7\u05d9\u05df \u05d4\u05d2\u05d9\u05e2 \u05dc\u05d1\u05d9\u05e7\u05d5\u05e8 \u05d1\u05e7\u05e2\u05de\u05e4 \u05e9\u05de\u05d7\u05d4 \u05d1\u05d0\u05e8\u05d4\u05f4\u05d1 \u05e9\u05dc \u05d0\u05e8\u05d2\u05d5\u05df \"\u05d7\u05d9\u05d9\u05e0\u05d5\", \u05e9\u05dd \u05e4\u05d2\u05e9 \u05d0\u05ea...", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05de\u05db\u05d5\u05df \"\u05e6\u05de\u05ea\" \u05de\u05e9\u05d9\u05e7 \u05de\u05d5\u05e6\u05e8 \u05d1\u05e9\u05dd \u05d2\u05e8\u05de\u05e2\u05dc\u05d9\u05ea \u05e9\u05d4\u05d5\u05e4\u05da \u05db\u05dc \u05de\u05e2\u05dc\u05d9\u05ea \u05dc\u05de\u05e2\u05dc\u05d9\u05ea \u05e9\u05d1\u05ea", "\ud83c\udfac \u05d3\u05e4\u05e0\u05d4 \u05dc\u05d9\u05d0\u05dc: \u05e9\u05e8 \u05d4\u05d1\u05d9\u05d8\u05d7\u05d5\u05df \u05d9\u05e9\u05e8\u05d0\u05dc \u05db\"\u05e5 \u05de\u05ea\u05d9\u05d9\u05d7\u05e1 \u05dc\u05d0\u05e4\u05e9\u05e8\u05d5\u05ea \u05e9\u05dc \u05d4\u05e1\u05dc\u05de\u05d4 \u05de\u05d5\u05dc \u05d0\u05d9\u05e8\u05d0\u05df \u05d1\u05d1\u05d9\u05e7\u05d5\u05e8\u05d5 \u05d1\u05de\u05e8\u05dc\u05d5\u05d2...", "\u05d4\u05e1\u05d5\u05db\u05e0\u05d5\u05ea \u05dc\u05d0\u05e0\u05e8\u05d2\u05d9\u05d4 \u05d0\u05d8\u05d5\u05de\u05d9\u05ea: \u05d1\u05d5\u05d7\u05e0\u05d9\u05dd \u05d3\u05d9\u05d5\u05d5\u05d7\u05d9\u05dd \u05e2\u05dc \u05ea\u05e7\u05d9\u05e4\u05d4 \u05d1\u05d0\u05ea\u05e8 \u05d4\u05d4\u05e7\u05de\u05d4 \u05e9\u05dc \u05ea\u05d7\u05e0\u05ea \u05d4\u05db\u05d5\u05d7 \u05d4\u05d2\u05e8\u05e2\u05d9\u05e0\u05d9\u05ea \u05d4...", "\u05dc\u05d0\u05d7\u05e8 \u05d1\u05e7\u05e8\u05ea \u05e4\u05ea\u05e2 \u05e9\u05dc \u05de\u05e9\u05e8\u05d3 \u05d4\u05d1\u05e8\u05d9\u05d0\u05d5\u05ea \u05e9\u05e0\u05e2\u05e8\u05db\u05d4 \u05d1\u05de\u05db\u05d5\u05df \u05d4\u05e4\u05d5\u05d8\u05d5\u05ea\u05e8\u05e4\u05d9\u05d4 '\u05e2\u05d5\u05e8 \u05d1\u05e8\u05d9\u05d0' \u05d1\u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7: \u05d4\u05d5\u05d7\u05dc\u05d8 \u05e2\u05dc ...", "\ud83c\udfac \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d7\u05e8\u05d3\u05d9\u05dd10", "\ud83d\udcc4 \u05d0\u05d5\u05e3 \u05d3\u05d4 \u05e8\u05e7\u05d5\u05e8\u05d3 - \u05d1\u05e7\u05e9\u05ea \u05e4\u05d9\u05e8\u05d5\u05e7 \u05e2\u05de\u05d5\u05ea\u05d4.pdf - 10.5 MB", "\u05d2\u05d9\u05d0 \u05d5\u05e8\u05d5\u05df", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05e2\u05dd \u05d4\u05e7\u05d5\u05d1\u05e5: \u05e9\u05e8 \u05d4\u05d1\u05d9\u05d8\u05d7\u05d5\u05df \u05d9\u05e9\u05e8\u05d0\u05dc \u05db\"\u05e5 \u05d1\u05de\u05d4\u05dc\u05da \u05d1\u05d9\u05e7\u05d5\u05e8 \u05d1\u05de\u05e8\u05dc\u05d5\"\u05d2 \u05d4\u05d0\u05e8\u05e6\u05d9 \u05e9\u05dc \u05d6\u05e7\"\u05d0: \"\u05d4\u05d1\u05d4\u05e8\u05e0\u05d5 \u05d1...", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d5\u05d5\u05dc\u05d5\u05d4 \u05e6\u05d5\u05d3\u05e7. \u05d0\u05d9\u05d1\u05d3\u05e0\u05d5 \u05d0\u05ea \u05d6\u05d4 \u05dc\u05d2\u05de\u05e8\u05d9", "\u05d7\u05d6\u05e8\u05d4 \u05dc\u05de\u05dc\u05d7\u05de\u05d4 \u05de\u05d5\u05dc \u05d0\u05d9\u05e8\u05d0\u05df? \u05d7\"\u05db \u05e0\u05d9\u05e1\u05d9\u05dd \u05d5\u05d0\u05d8\u05d5\u05e8\u05d9 \u05de\u05e2\u05e8\u05d9\u05da: \"\u05e6\u05e4\u05d5\u05d9\u05d4 \u05de\u05e2\u05e8\u05db\u05d4 \u05e7\u05e9\u05d4 - \u05e0\u05e9\u05d5\u05d1 \u05dc\u05dc\u05d7\u05d9\u05de\u05d4 \u05d1\u05d0\u05d5\u05e4\u05df \u05de...", "\ud83c\udfac", "\u05d4\u05d9\u05d5\u05dd \u05dc\u05e4\u05e0\u05d9 37 \u05e9\u05e0\u05d9\u05dd: \u05d1\u05e8\u05db\u05ea\u05d5 \u05e9\u05dc \u05d4\u05e8\u05d1\u05d9 \u05de\u05dc\u05d9\u05d5\u05d1\u05d0\u05d5\u05d5\u05d9\u05d8\u05e9 \u05dc\u05d1\u05d9\u05ea \u05e9\u05de\u05e9", "\ud83d\uddbc \ud83c\udfa5 \u05d4\u05ea\u05d9\u05e2\u05d5\u05d3 \u05d5\u05d4\u05ea\u05de\u05d5\u05e0\u05d5\u05ea \u05d1\u05d0\u05d3\u05d9\u05d1\u05d5\u05ea JEM.", "\ud83c\udfac \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d9\u05d5\u05d0\u05dc\u05d9 \u05d1\u05e8\u05d9\u05dd yoeli brim", "\u05de\u05d9\u05dc\u05df \u05e2\u05de\u05e8:", "\ud83d\uddbc \u05d9\u05db\u05d5\u05dc\u05d4 \u05dc\u05e2\u05d1\u05d5\u05d3 \u05d1\u05de\u05e9\u05de\u05e8\u05d5\u05ea \u05de\u05d2\u05d5\u05d5\u05e0\u05d5\u05ea? \u05de\u05d7\u05e4\u05e9\u05ea \u05d0\u05ea \u05d4\u05de\u05e9\u05e8\u05d4 \u05d4\u05d1\u05d0\u05d4?\ud83c\udf96\ufe0f", "\u05e9\u05d5\u05d1 \u05d3\u05d9\u05d5\u05d5\u05d7 \u05e2\u05dc \u05e4\u05d9\u05e6\u05d5\u05e6\u05d9\u05dd \u05d1\u05d0\u05d9\u05e8\u05d0\u05df.", "\u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05dc\u05d0\u05d7\u05e8 \u05e7\u05d1\u05dc\u05ea \u05d0\u05d9\u05e9\u05d5\u05e8 \u05d4\u05de\u05e9\u05d8\u05e8\u05d4, \u05d7\u05e1\u05d9\u05d3\u05d5\u05ea \u05d2\u05d5\u05e8 \u05ea\u05e7\u05d9\u05d9\u05dd \u05de\u05d7\u05e8 \u05d1\u05e9\u05e2\u05d4 21:30 \u05e2\u05e6\u05e8\u05ea \u05ea\u05e4\u05d9\u05dc\u05d4 \u05d5\u05de\u05d7\u05d0\u05d4 \u05de\u05d5\u05dc \u05e9...", "\ud83d\uddbc \u05e1\u05d9\u05d5\u05e2 \u05d1\u05d0\u05d9\u05ea\u05d5\u05e8 \u05e0\u05e2\u05d3\u05e8", "\u05db\u05e4\u05d9 \u05e9\u05e4\u05d5\u05e8\u05e1\u05dd \u05dc\u05e8\u05d0\u05e9\u05d5\u05e0\u05d4 \u05d1\u05d4\u05e2\u05e8\u05d9\u05e0\u05d2: \u05de\u05d7\u05e8 \u05d1\u05dc\u05d9\u05dc\u05d4 \u05e6\u05e4\u05d5\u05d9\u05d9\u05dd \u05d4\u05de\u05d5\u05e0\u05d9 \u05d7\u05e1\u05d9\u05d3\u05d9 \u05d2\u05d5\u05e8 \u05dc\u05d4\u05ea\u05db\u05e0\u05e1 \u05dc\u05e2\u05e6\u05e8\u05ea \u05ea\u05e4\u05d9\u05dc\u05d4 \u05de\u05e8...", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d9\u05d0\u05d9\u05e8 \u05dc\u05d5\u05d9", "\ud83d\uddbc *\u05d9\u05e9 \u05dc\u05d4\u05df \u05d0\u05d1\u05df \u05d0\u05d7\u05ea \u05de\u05d9\u05d5\u05d7\u05d3\u05ea, \u05d5\u05d0\u05ea \u05d6\u05d4 \u05d4\u05df \u05dc\u05d0 \u05de\u05d7\u05dc\u05d9\u05e4\u05d5\u05ea.*", "\ud83c\udfac \u05e9\u05e8 \u05d4\u05d7\u05d5\u05e5 \u05d4\u05d0\u05d9\u05e8\u05d0\u05e0\u05d9 \u05e2\u05d1\u05d0\u05e1 \u05e2\u05e8\u05d0\u05e7\u05d2'\u05d9 \u05de\u05db\u05d4 \u05e2\u05dc \u05d7\u05d8\u05d0:", "\ud83d\uddbc \ud83d\udd11 \u05e8\u05e4\u05d0\u05dc \u05d4\u05de\u05e0\u05e2\u05d5\u05dc\u05df \u2013 \u05de\u05e7\u05e6\u05d5\u05e2\u05d9\u05d5\u05ea, \u05d0\u05de\u05d9\u05e0\u05d5\u05ea \u05d5\u05e9\u05d9\u05e8\u05d5\u05ea \u05dc\u05dc\u05d0 \u05e4\u05e9\u05e8\u05d5\u05ea!", "\ud83c\udfac \u05d9\u05d5\u05dd \u05de\u05e2\u05e0\u05d9\u05d9\u05df \u05d4\u05d9\u05d5\u05dd \u05dc\u05de\u05d1\u05dc\u05d9\u05dd \u05d1\u05d0\u05d9\u05dc\u05ea: \u05e6\u05d5\u05dc\u05dc\u05ea \u05e9\u05dc \u05d7\u05d9\u05dc \u05d4\u05d9\u05dd \u05e0\u05e6\u05e4\u05ea\u05d4 \u05d1\u05d0\u05d5\u05e4\u05df \u05e0\u05d3\u05d9\u05e8 \u05de\u05e2\u05dc \u05d4\u05de\u05d9\u05dd \u05d5\u05e7\u05e8\u05d5\u05d1 \u05de...", "\ud83d\uddbc \u05d4\u05e2\u05e8\u05d9\u05e0\u05d2: \u05dc\u05d0\u05df \u05d4\u05dd \u05e2\u05d5\u05d6\u05d1\u05d9\u05dd? \u05de\u05e1\u05ea\u05d1\u05e8 \u05e9\u05d4\u05d7\u05d9\u05d9\u05dc\u05d9\u05dd \u05d4\u05d0\u05de\u05e8\u05d9\u05e7\u05d0\u05d9\u05dd \u05d9\u05e6\u05d0\u05d5 \u05de\u05d4\u05de\u05dc\u05d5\u05df \u05d1\u05d4\u05e8\u05e6\u05dc\u05d9\u05d4 \u05d1\u05e9\u05d9\u05d0 \u05d4\u05d1\u05d0\u05dc\u05d2\u05df...", "\ud83c\udfac \u05e2\u05e8\u05d5\u05e6\u05d9\u05dd \u05e9\u05d9\u05e2\u05d9\u05dd \u05de\u05e4\u05e8\u05e1\u05de\u05d9\u05dd \u05ea\u05d9\u05e2\u05d5\u05d3 \u05d9\u05e9\u05e8\u05d0\u05dc\u05d9 (\u05e0\u05d3\u05d9\u05e8) \u05e9\u05dc \u05e6\u05d5\u05dc\u05dc\u05ea \u05d9\u05e9\u05e8\u05d0\u05dc\u05d9\u05ea \u05d1\u05de\u05e4\u05e8\u05e5 \u05d0\u05d9\u05dc\u05ea.", "\ud83d\uddbc \u05d1\u05df \u05d2\u05d5\u05dc\u05d3\u05e4\u05e8\u05d9\u05d9\u05e0\u05d3", "\u05de\u05d1\u05d6\u05e7\u05df 12", "\u05e9\u05e8\u05d5\u05df \u05e7\u05e0\u05d5\u05d1\u05dc\u05d9\u05da", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05ea\u05d9\u05e2\u05d5\u05d3: \u05d4\u05e0\u05e2\u05e8\u05d9\u05dd \u05e9\u05e4\u05e8\u05e6\u05d5 \u05d1\u05e9\u05d1\u05ea \u05dc\u05e2\u05d9\u05e8\u05d9\u05d9\u05ea \u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7", "\u05ea\u05d5\u05d3\u05d4 \u05e2\u05e0\u05e7\u05d9\u05ea \u05dc\u05db\u05dc \u05d4\u05de\u05ea\u05e0\u05d3\u05d1\u05d9\u05dd/\u05d5\u05ea \u05e9\u05d9\u05e6\u05d0\u05d5 \u05dc\u05e2\u05d6\u05d5\u05e8 \u05d1\u05d7\u05d9\u05e4\u05d5\u05e9\u05d9\u05dd. \u05d1\u05d6\u05db\u05d5\u05ea \u05d4\u05e2\u05e8\u05e0\u05d5\u05ea \u05e9\u05dc\u05db\u05dd \u05d4\u05e0\u05e2\u05d3\u05e8 \u05d0\u05d5\u05ea\u05e8 \u05d1\u05e8\u05d9\u05d0...", "\ud83c\udfac \u05e4\u05d9\u05e7\u05d5\u05d3 \u05d4\u05de\u05e8\u05db\u05d6 \u05e9\u05dc \u05d0\u05e8\u05d4\u05f4\u05d1 \u05e2\u05dd \u05ea\u05d9\u05e2\u05d5\u05d3 \u05d7\u05d3\u05e9 \u05e9\u05dc \u05de\u05d8\u05d5\u05e1\u05d9 F35 \u05de\u05de\u05e8\u05d9\u05d0\u05d9\u05dd \u05de\u05d4USS Boxer \u05d1\u05d9\u05dd \u05d4\u05e2\u05e8\u05d1\u05d9", "\ud83d\uddbc \u05d4\u05de\u05e9\u05d8\u05e8\u05d4 \u05d4\u05e1\u05d9\u05e8\u05d4 34 \u05de\u05e6\u05dc\u05de\u05d5\u05ea \u05dc\u05d0 \u05d7\u05d5\u05e7\u05d9\u05d5\u05ea \u05d1\u05db\u05e4\u05e8 \u05e7\u05e8\u05e2 \u05e9\u05d1\u05e6\u05e4\u05d5\u05df.", "\u00b0\u05ea\u05d5\u05db\u05df \u05e9\u05d9\u05d5\u05d5\u05e7\u05d9", "*\u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05e1\u05e7\u05d5\u05e4\u05d9\u05dd*", "\u05d1\u05e8\u05d2\u05e2 \u05d4\u05d0\u05d7\u05e8\u05d5\u05df: \u05d1\u05d5\u05d8\u05dc \u05d4\u05e8\u05d0\u05d9\u05d5\u05df \u05e9\u05dc \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05d1\u05e4\u05d5\u05e7\u05e1 \u05e0\u05d9\u05d5\u05d6.", "\ud83d\uddbc \u05d7\u05d1\u05e8\u05ea \u05e4\u05dc\u05e1\u05df \u05de\u05e7\u05d9\u05d1\u05d5\u05e5 \u05e1\u05d0\u05e1\u05d0 \u05e4\u05d9\u05ea\u05d7\u05d4 \u05de\u05e1\u05e4\u05e8 \u05db\u05dc\u05d9 \u05e8\u05db\u05d1 \u05de\u05de\u05d5\u05d2\u05e0\u05d9\u05dd \u05d9\u05d9\u05d7\u05d5\u05d3\u05d9\u05d9\u05dd \u05de\u05d1\u05d5\u05e1\u05e1\u05d9\u05dd \u05e2\u05dc \u05e9\u05dc\u05d3\u05d5\u05ea \u05d9\u05e6\u05e8\u05e0...", "*\u05d5\u05e2\u05d3\u05ea \u05d4\u05db\u05dc\u05db\u05dc\u05d4 \u05d0\u05d9\u05e9\u05e8\u05d4 \u05dc\u05e7\u05e8\u05d9\u05d0\u05d4 \u05e9\u05e0\u05d9\u05d9\u05d4 \u05d5\u05e9\u05dc\u05d9\u05e9\u05d9\u05ea \u05d7\u05d5\u05e7 \u05e9\u05d9\u05d7\u05d9\u05d9\u05d1 \u05e2\u05e1\u05e7\u05d9\u05dd \u05dc\u05d4\u05e7\u05dc\u05d9\u05d8 \u05e9\u05d9\u05d7\u05d5\u05ea \u05d1\u05e2\u05e1\u05e7\u05d0\u05d5\u05ea \u05de\u05e1\u05d5...", "\ud83d\uddbc *\u05d2\u05dd \u05d0\u05e6\u05dc\u05da \u05d4\u05d7\u05d5\u05e4\u05e9 \u05e2\u05dd \u05d4\u05de\u05ea\u05d1\u05d2\u05e8\u05d5\u05ea \u05de\u05e8\u05d2\u05d9\u05e9 \u05db\u05de\u05d5 \u05de\u05e8\u05d5\u05e5 \u05d1\u05dc\u05ea\u05d9 \u05e0\u05d2\u05de\u05e8?*", "\u05e8\u05d0\u05d9\u05d5\u05df \u05e9\u05dc \u05e8\u05d4\u05f4\u05de \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05d1\u05e4\u05d5\u05e7\u05e1 \u05e0\u05d9\u05d5\u05d6 \u05d1\u05d5\u05d8\u05dc \u05d1\u05de\u05e4\u05ea\u05d9\u05e2.", "\ud83d\uddbc \u05e2\u05dd \u05d9\u05e9\u05e8\u05d0\u05dc \u05d4\u05d9\u05e7\u05e8,", "\ud83d\uddbc \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05e0\u05d4\u05d5\u05e8\u05d0\u05d9 \u05d0\u05d1\u05e8\u05d2'\u05dc \u05de\u05e9\u05ea\u05e3 \u05d0\u05ea \u05d4\u05ea\u05d9\u05e2\u05d5\u05d3 \u05e9\u05dc \u05d1\u05d7\u05d5\u05e8\u05d9 \u05d4\u05d9\u05e9\u05d9\u05d1\u05d4 \u05d4\u05d0\u05e8\u05d2\u05e0\u05d8\u05d9\u05e0\u05d0\u05d9\u05dd \u05e9\u05e9\u05e8\u05d9\u05dd \u05de\u05e9\u05de\u05d7\u05d4: \"\u05d0...", "\ud83d\uddbc \u05dc\u05d7\u05d5\u05d1\u05d1\u05d9 \u05d4\u05d6'\u05d0\u05e0\u05e8 - \u05de\u05d9\u05d8\u05d9\u05d1\u05d9 \u05dc\u05db\u05ea", "\ud83c\udfac *\u05d4\u05d6\u05e2\u05e7\u05d4 \u05e9\u05dc \u05d5\u05d5\u05e2\u05dc\u05d5\u05d5\u05d0* | \u05d4\u05d9\u05dc\u05d3\u05d9\u05dd \u05e9\u05dc\u05e0\u05d5 \u05de\u05d5\u05e1\u05ea\u05d9\u05dd \u05dc\u05d0\u05dc\u05d9\u05de\u05d5\u05ea \u05de\u05d9 \u05d9\u05e2\u05e6\u05d5\u05e8 \u05d0\u05ea \u05d6\u05d4?", "\ud83c\udfac \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05e0\u05d6\u05e3 \u05d1\u05e8\u05d0\u05e9\u05d9 \u05e8\u05e9\u05d5\u05d9\u05d5\u05ea \u05de\u05d4\u05dc\u05d9\u05db\u05d5\u05d3 \u05e2\u05dc \u05e9\u05d0\u05d9\u05e0\u05dd \u05de\u05db\u05d9\u05e8\u05d9\u05dd \u05d0\u05ea \u05d4\u05de\u05e1\u05e8\u05d9\u05dd \u05e0\u05d2\u05d3 \u05d0\u05d9\u05d6\u05e0\u05e7\u05d5\u05d8 \u2014 \u05e9\u05d4\u05ea\u05e0\u05d2\u05d3 ...", "\ud83d\uddbc \u05e7\u05d5\u05e0\u05d4 \u05db\u05dc\u05d9 \u05db\u05e1\u05e3 \u05d5\u05d6\u05d4\u05d1 \u05d1\u05de\u05d7\u05d9\u05e8\u05d9\u05dd \u05d4\u05d8\u05d5\u05d1\u05d9\u05dd \u05d1\u05e9\u05d5\u05e7", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d1\u05d7\u05d5\u05e8 \u05d1\u05df 15 \u05e9\u05dc\u05d5\u05de\u05d3 \u05de\u05d0\u05d6 \u05d4\u05d1\u05e8 \u05de\u05e6\u05d5\u05d5\u05d4 \u05e2\u05dd \u05e8' \u05d0\u05dc\u05d9 \u05e1\u05d8\u05e4\u05e0\u05e1\u05e7\u05d9 \u05d1\u05e9\u05d9\u05e2\u05d5\u05e8 \u05d1\u05d0\u05e0\u05d2\u05dc\u05d9\u05ea, \u05d5\u05dc\u05de\u05d3 \u05db\u05d1\u05e8 70...", "\ud83d\uddbc \u05e8\u05d0\u05e9 \u05d4\u05de\u05de\u05e9\u05dc\u05d4 \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05d5\u05d4\u05e9\u05e8\u05d9\u05dd \u05d1\u05d4\u05db\u05e0\u05d5\u05ea \u05d0\u05d7\u05e8\u05d5\u05e0\u05d5\u05ea.", "\u05d4\u05d9\u05e8\u05d9 \u05de\u05d0\u05d9\u05e8\u05d0\u05df \u05dc\u05d9\u05e8\u05d3\u05df: \u05e9\u05d1\u05e8\u05d9 \u05d9\u05d9\u05e8\u05d5\u05d8 \u05e0\u05e4\u05dc\u05d5 \u05d1\u05e6\u05e4\u05d5\u05df \u05d0\u05d9\u05dc\u05ea \u05d5\u05d1\u05d4\u05e8\u05d9\u05dd, \u05d0\u05d9\u05df \u05e0\u05e4\u05d2\u05e2\u05d9\u05dd.", "\ud83d\uddbc \u05e2\u05d5\u05d3 \u05d9\u05e9\u05d9\u05d1\u05d4 \u05e9\u05dc \u05d4\u05dc\u05d9\u05db\u05d5\u05d3 \u05d1\u05e1\u05d0\u05d2\u05d4 \u05e9\u05d0\u05d9\u05e0\u05d4 \u05e0\u05d2\u05de\u05e8\u05ea", "\u05d9\u05e2\u05dc \u05d0\u05d5\u05d3\u05dd", "\ud83d\uddbc \u05d3\u05e4\u05e0\u05d4 \u05dc\u05d9\u05d0\u05dc"]}