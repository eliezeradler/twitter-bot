u05e8\u05d1 \u05e9\u05d1\u05d9\u05e6\u05e2 \u05d0\u05ea\u05de\u05d5\u05dc \u05d1\u05e6\u05e4\u05d5\u05df \u05d4\u05de\u05d3\u05d9\u05e0\u05d4 \u05d7\u05d5\u05e1\u05dc\u05d5 \u05d5\u05e0\u05e9\u05d1\u05d5 \u05e2\u05e9\u05e8\u05d5\u05ea \u05d7\u05d9\u05d9\u05dc\u05d9...", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d9\u05d5\u05e1\u05d9 \u05d0\u05dc\u05d9\u05d8\u05d5\u05d1 Yossi Elituv", "\u05d3\u05d5\u05d1\u05e8 \u05e6\u05d4\"\u05dc: \u05d1\u05d4\u05de\u05e9\u05da \u05dc\u05e9\u05d9\u05d2\u05d5\u05e8\u05d9\u05dd \u05e9\u05d1\u05d5\u05e6\u05e2\u05d5 \u05dc\u05e2\u05d1\u05e8 \u05d9\u05e8\u05d3\u05df, \u05e9\u05d5\u05d2\u05e8\u05d5 \u05de\u05e1\u05e4\u05e8 \u05de\u05d9\u05d9\u05e8\u05d8\u05d9\u05dd \u05dc\u05e2\u05d1\u05e8 \u05e9\u05d1\u05e8\u05d9 \u05d9\u05d9\u05e8\u05d5\u05d8 \u05e2\u05dc \u05de...", "\u05d3\u05d9\u05df \u05e4\u05d9\u05e9\u05e8", "\ud83d\uddbc \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d4\u05e4\u05e1\u05d3 \u05e9\u05dc \u05de\u05d0\u05d5\u05ea \u05d0\u05dc\u05e4\u05d9 \u05e9\u05e7\u05dc\u05d9\u05dd \u05dc\u05e8\u05d5\u05db\u05e9\u05d9\u05dd \u05d1\u05e4\u05e8\u05d5\u05d9\u05d9\u05e7\u05d8 \u05d4\u05d7\u05e8\u05d3\u05d9 \u05db\u05ea\u05e8 \u05d4\u05e8\u05de\u05d4 \u05d1\u05d1\u05d9\u05ea \u05e9\u05de\u05e9.", "\ud83c\udfac *\u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05e1\u05e7\u05d5\u05e4\u05d9\u05dd*", "*\u05d7\u05e9\u05d3 \u05dc\u05d0\u05d9\u05e8\u05d5\u05e2 \u05dc\u05d0\u05d5\u05de\u05e0\u05d9: \u05de\u05d8\u05d5\u05e1 \u05d9\u05e9\u05e8\u05d0\u05d9\u05d9\u05e8 \u05e0\u05e4\u05d2\u05e2 \u05d1\u05e9\u05d3\u05d4 \u05ea\u05e2\u05d5\u05e4\u05d4*", "\ud83d\uddbc \ud83d\udd1e\ud83d\udd1e", "\ud83d\uddbc \u05e2\u05d5\u05de\u05e8 \u05e9\u05d0\u05d3\u05d9 \u05e2\u05d0\u05d6\u05dd, \u05d1\u05df 8 \u05de\u05d8\u05d9\u05d9\u05d1\u05d4, \u05e0\u05e4\u05d2\u05e2 \u05d1\u05e9\u05d9\u05e9\u05d9 \u05d4\u05d0\u05d7\u05e8\u05d5\u05df \u05d1\u05d0\u05d5\u05e8\u05d7 \u05d0\u05e0\u05d5\u05e9 \u05de\u05e7\u05d5\u05e8\u05e7\u05d9\u05e0\u05d8 \u05d7\u05e9\u05de\u05dc\u05d9 - \u05d5\u05de\u05d5\u05ea\u05d5 \u05e0...", "\ud83c\udfac \u05d0\u05d5\u05d4\u05d3\u05d9 \u05d0\u05e8\u05d2\u05e0\u05d8\u05d9\u05e0\u05d4 \u05db\u05d5\u05d1\u05e9\u05d9\u05dd \u05d0\u05ea \u05d4\u05ea\u05e4\u05d5\u05d7 \u05d4\u05d2\u05d3\u05d5\u05dc\ud83c\udde6\ud83c\uddf7\ud83d\uddfd", "\u21a9\ufe0f \u05d7\u05e9\u05d3 \u05dc\u05d0\u05d9\u05e8\u05d5\u05e2 \u05dc\u05d0\u05d5\u05de\u05e0\u05d9: \u05d0\u05d7\u05e8\u05d9 \u05e9\u05d4\u05d8\u05d9\u05e1\u05d4 \u05e9\u05dc \u05d9\u05e9\u05e8\u05d0\u05d9\u05d9\u05e8 \u05d1\u05d5\u05d8\u05dc\u05d4 \u05d1\u05d2\u05dc\u05dc \u05e4\u05d2\u05d9\u05e2\u05d4 \u05e9\u05dc \u05e8\u05db\u05d1 \u05e9\u05d9\u05e8\u05d5\u05ea \u05e9\u05e4\u05d2\u05e2 \u05d1\u05de\u05d8...", "\u05dc\u05d9 \u05e0\u05e2\u05d9\u05dd", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d4\u05e2\u05d9\u05ea\u05d5\u05e0\u05d0\u05d9\u05ea \u05d4\u05d7\u05e8\u05d3\u05d9\u05ea \u05e9\u05e8\u05d9 \u05e8\u05d5\u05d8 \u05d4\u05d5\u05d6\u05de\u05e0\u05d4 \u05dc\u05e2\u05e8\u05d5\u05e5 12 \u05d0\u05d7\u05e8\u05d9 \u05e9\u05d4\u05ea\u05d2\u05d0\u05ea\u05d4 \u05e9\u05d1\u05e0\u05d4 \u05e2\u05e8\u05d9\u05e7 \u05d5\u05d7\u05d9\u05d9\u05dc \u05d1\u05e6...", "\ud83d\uddbc \u05dc\u05e7\u05e8\u05d0\u05ea \u05e4\u05ea\u05d9\u05d7\u05ea \u05d4\u05e1\u05d3\u05e0\u05d4 \u05dc\u05d2\u05de\u05d9\u05dc\u05d4 \u05de\u05e2\u05d9\u05e9\u05d5\u05df \u05d1\u05e2\u05d9\u05e8 \u05d0\u05dc\u05e2\u05d3 \u05e9\u05dc \u05d7\u05d1\u05e8\u05ea '\u05d0\u05dc\u05df \u05e7\u05d0\u05e8' \u05d1\u05e1\u05d1\u05e1\u05d5\u05d3 \u05d4\u05e2\u05d9\u05e8\u05d9\u05d9\u05d4, \u05d4\u05d2\u05d9\u05e2...", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d7\u05d9\u05d9\u05dd \u05d2\u05d5\u05dc\u05d3\u05d1\u05e8\u05d2", "*\u05d2\u05d5\u05e8\u05de\u05d9 \u05d1\u05d9\u05d8\u05d7\u05d5\u05df \u05de\u05e1\u05d1\u05d9\u05e8\u05d9\u05dd \u05e9\u05e9\u05e8\u05d9\u05e7\u05ea \u05d4\u05e1\u05d9\u05d5\u05dd \u05e9\u05dc \u05d4\u05d8\u05d5\u05e8\u05e0\u05d9\u05e8 \u05d4\u05e2\u05d5\u05dc\u05de\u05d9 \u05d1\u05d0\u05e8\u05d4\"\u05d1 \u05ea\u05d5\u05d1\u05d9\u05dc \u05dc\u05d4\u05e1\u05e8\u05ea \u05d4\u05d0\u05d9\u05e4\u05d5\u05e7 \u05d1\u05de\u05d6...", "\ud83d\uddbc \u05e9\u05dc\u05d5\u05dd, \u05e9\u05de\u05d9 \u05e0\u05e4\u05ea\u05dc\u05d9 \u05d9\u05e4\u05d4. \u05ea\u05d5\u05e9\u05d1 \u05d7\u05d5\u05d5\u05ea \u05d2\u05dc\u05e2\u05d3", "\ud83d\uddbc \u05e4\u05d9\u05e0\u05d9 \u05d0\u05d9\u05d9\u05e0\u05d4\u05d5\u05e8\u05df \u05d1\u05e1\u05d2\u05d9\u05e8\u05d5\u05ea \u05d0\u05d7\u05e8\u05d5\u05e0\u05d5\u05ea \u05dc\u05e7\u05e8\u05d0\u05ea \u05d4\u05de\u05d5\u05e4\u05e2 \u05d4\u05de\u05d3\u05d5\u05d1\u05e8 \u05e9\u05dc \u05d4\u05e2\u05d5\u05e0\u05d4 \u05d1\u05d1\u05e0\u05d9\u05d9\u05e0\u05d9 \u05d4\u05d0\u05d5\u05de\u05d4 \u05e2\u05dd \u05d4\u05de\u05e0...", "\u05d4\u05d0\u05d9\u05e9 \u05e9\u05ea\u05de\u05d9\u05d3 \u05d9\u05d5\u05d3\u05e2: \u05d7\"\u05db \u05e0\u05d9\u05e1\u05d9\u05dd \u05d5\u05d0\u05d8\u05d5\u05e8\u05d9 \u05e8\u05d5\u05de\u05d6: \"\u05e6\u05e4\u05d5\u05d9\u05d4 \u05de\u05e2\u05e8\u05db\u05d4 \u05e7\u05e9\u05d4 - \u05e0\u05e9\u05d5\u05d1 \u05dc\u05dc\u05d7\u05d9\u05de\u05d4 \u05d1\u05d0\u05d5\u05e4\u05df \u05de\u05dc\u05d0\". (14)", "\ud83d\uddbc \u05dc\u05d1\u05e0\u05ea\u05d9\u05d9\u05dd \u05ea\u05e4\u05d9\u05dc\u05d5\u05ea \u05dc\u05d4\u05e6\u05dc\u05d7\u05ea \u05d0\u05e8\u05d2\u05e0\u05d8\u05d9\u05e0\u05d4 \u05d1\u05de\u05e9\u05d7\u05e7 \u05d4\u05e2\u05e8\u05d1", "*\u05d1\u05de\u05d4\u05dc\u05da \u05d4\u05dc\u05d9\u05dc\u05d4: \u05e6\u05d4\"\u05dc \u05ea\u05e7\u05e3 \u05d5\u05d4\u05e9\u05de\u05d9\u05d3 \u05ea\u05e9\u05ea\u05d9\u05d5\u05ea \u05d8\u05e8\u05d5\u05e8 \u05e9\u05dc \u05d0\u05e8\u05d2\u05d5\u05df \u05d4\u05d8\u05e8\u05d5\u05e8 \u05d7\u05de\u05d0\u05e1 \u05d1\u05e8\u05e6\u05d5\u05e2\u05ea \u05e2\u05d6\u05d4*", "\u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05d2\u05d9\u05dc\u05d4 \u05e9\u05e8\u05d0\u05e9\u05d9 \u05d4\u05e8\u05e9\u05d5\u05d9\u05d5\u05ea \u05d1\u05dc\u05d9\u05db\u05d5\u05d3 \u05dc\u05d0 \u05de\u05db\u05d9\u05e8\u05d9\u05dd \u05d4\u05ea\u05d1\u05d8\u05d0\u05d5\u05d9\u05d5\u05ea \u05e9\u05dc \u05d0\u05d9\u05d6\u05e0\u05e7\u05d5\u05d8 \u05d1\u05d3\u05d1\u05e8 \u05d4\u05e6\u05d5\u05e8\u05da \u05dc\u05d4\u05d2\u05d9\u05e2 ...", "\u05e0\u05d9\u05e8 \u05d3\u05d1\u05d5\u05e8\u05d9", "\ud83d\uddbc \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05de\u05d5\u05e0\u05d3\u05d9\u05d0\u05dc \u05d1\u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7", "\u05d9\u05e9\u05e8\u05d0\u05dc \u05d7\u05d9\u05e1\u05dc\u05d4 \u05d0\u05ea \u05d0\u05d7\u05d9\u05d5 \u05e9\u05dc \u05d4\u05d1\u05db\u05d9\u05e8 \u05db\u05d3\u05d9 \u05dc\u05de\u05e9\u05d5\u05da \u05d0\u05d5\u05ea\u05d5 \u05dc\u05d4\u05dc\u05d5\u05d5\u05d9\u05d4 | \u05dc\u05e4\u05d9 \u05de\u05e7\u05d5\u05e8\u05d5\u05ea \u05d1\u05e2\u05d6\u05d4, \u05d4\u05d9\u05e2\u05d3 \u05d4\u05d0\u05de\u05d9\u05ea\u05d9 \u05d4...", "\u05e6\u05d4\"\u05dc \u05ea\u05e7\u05e3 \u05d5\u05d4\u05e9\u05de\u05d9\u05d3 \u05d1\u05de\u05d4\u05dc\u05da \u05d4\u05dc\u05d9\u05dc\u05d4 \u05ea\u05e9\u05ea\u05d9\u05d5\u05ea \u05d8\u05e8\u05d5\u05e8 \u05e9\u05dc \u05d7\u05de\u05d0\u05e1 \u05d1\u05e2\u05d6\u05d4, \u05d5\u05d1\u05d4\u05dd \u05de\u05d7\u05e1\u05df \u05d0\u05de\u05e6\u05e2\u05d9 \u05dc\u05d7\u05d9\u05de\u05d4, \u05ea\u05e9\u05ea\u05d9\u05ea \u05dc...", "\ud83d\uddbc \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d4\u05d0\u05d3\u05de\u05d5\"\u05e8 \u05e6\u05d9\u05e0\u05d5\u05e8 \u05d4\u05e9\u05e4\u05e2 \u05d1\u05e7\u05e8\u05d9\u05d0\u05ea \"\u05e9\u05d5\u05d5\u05e2\u05e8\u05e2 \u05e7\u05d5\u05d5\u05d9\u05d8\u05dc\" (\u05e7\u05d5\u05d5\u05d9\u05d8\u05dc \u05e7\u05e9\u05d4) \u05d1\u05d1\u05d9\u05e9\u05d8\u05e0\u05d0 \u05e2\u05dd \u05e9\u05de\u05d5 \u05e9\u05dc \u05d4...", "\ud83d\uddbc \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d4\u05db\u05d9\u05d1\u05d5\u05d3 \u05d1\u05e7\u05d1\u05e8 \u05d4\u05d0\u05e8\"\u05d9", "\u05e6\u05d4\u05f4\u05dc \u05ea\u05e7\u05e3 \u05d4\u05dc\u05d9\u05dc\u05d4 \u05d1\u05e8\u05e6\u05d5\u05e2\u05ea \u05e2\u05d6\u05d4 \u05d5\u05d4\u05e9\u05de\u05d9\u05d3 \u05de\u05d7\u05e1\u05df \u05d0\u05de\u05e6\u05e2\u05d9 \u05dc\u05d7\u05d9\u05de\u05d4, \u05ea\u05e9\u05ea\u05d9\u05ea \u05dc\u05d9\u05d9\u05e6\u05d5\u05e8 \u05d0\u05de\u05dc\u05f4\u05d7 \u05d5\u05d0\u05ea\u05e8 \u05e9\u05d9\u05d2\u05d5\u05e8 \u05e9...", "\ud83c\udfac \u05e9\u05d5\"\u05ea \u05de\u05d9\u05d5\u05d7\u05d3 \u05e2\u05dd \u05de\u05e0\u05d4\u05d9\u05d2 \u05d4\u05d3\u05d5\u05e8 \u05de\u05e8\u05df \u05d4\u05d2\u05e8\"\u05d3 \u05dc\u05e0\u05d3\u05d5 \u05e2\u05dc \u05d4\u05db\u05e0\u05ea \u05d5\u05d4\u05d3\u05e8\u05db\u05ea \u05d1\u05d7\u05d5\u05e8\u05d9 \u05d9\u05e9\u05d9\u05d1\u05d5\u05ea.", "\u05d3\u05d5\u05d1\u05e8 \u05e6\u05d4\"\u05dc \u05de\u05e2\u05d3\u05db\u05df: \u05d1\u05d4\u05de\u05e9\u05da \u05dc\u05e9\u05d9\u05d2\u05d5\u05e8\u05d9\u05dd \u05e9\u05d1\u05d5\u05e6\u05e2\u05d5 \u05de\u05d5\u05e7\u05d3\u05dd \u05d9\u05d5\u05ea\u05e8 \u05d4\u05d9\u05d5\u05dd \u05de\u05d0\u05d9\u05e8\u05d0\u05df \u05dc\u05e2\u05d1\u05e8 \u05d9\u05e8\u05d3\u05df, \u05e9\u05d5\u05d2\u05e8\u05d5 \u05de\u05e1\u05e4\u05e8...", "\ud83c\udfac \u05d0\u05d9\u05e8\u05d5\u05e2 \u05d7\u05e8\u05d9\u05d2 \u05d5\u05d9\u05d5\u05e6\u05d0 \u05d3\u05d5\u05e4\u05df \u05e0\u05e8\u05e9\u05dd \u05d1\u05d7\u05d5\u05e4\u05d9 \u05d0\u05d9\u05dc\u05ea, \u05db\u05d0\u05e9\u05e8 \u05e6\u05d5\u05dc\u05dc\u05ea \u05de\u05d7\u05d9\u05dc \u05d4\u05d9\u05dd, \u05de\u05d3\u05d2\u05dd \"\u05d3\u05d5\u05dc\u05e4\u05d9\u05df\", \u05e0\u05e6\u05e4\u05ea\u05d4 \u05db...", "\ud83c\udfac \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d9\u05e2\u05e7\u05d1 \u05d4\u05e8\u05e9\u05e7\u05d5\u05d1\u05d9\u05e5 | Yaakov hershkowitz", "\ud83c\udfac \u05d4\u05e8\u05d1 \u05d3\u05d5\u05d3 \u05e9\u05d8\u05e8\u05d9\u05ea \u05e9\u05dc\u05d9\u05d8\u05d0", "\ud83d\uddbc \u05d4\u05dc\u05db\u05dc\u05d5\u05da \u05d4\u05d9\u05d4 \u05db\u05dc \u05db\u05da \u05e2\u05d1\u05d4 \u05e9\u05d4\u05d9\u05d4 \u05e6\u05e8\u05d9\u05da \u05dc\u05d2\u05e8\u05d3 \u05e2\u05dd \u05d4\u05e6\u05d9\u05e4\u05d5\u05e8\u05df", "\ud83d\uddbc \u05d1\u05e9\u05e0\u05ea 1474, \u05d1\u05ea\u05e7\u05d5\u05e4\u05ea \u05d9\u05de\u05d9 \u05d4\u05d1\u05d9\u05e0\u05d9\u05d9\u05dd \u05d4\u05ea\u05e7\u05d9\u05d9\u05dd \u05d1\u05e2\u05d9\u05e8 \u05d1\u05d6\u05dc \u05e9\u05d1\u05e9\u05d5\u05d5\u05d9\u05e5 \u05d0\u05d7\u05d3 \u05d4\u05de\u05e9\u05e4\u05d8\u05d9\u05dd \u05d4\u05de\u05d5\u05d6\u05e8\u05d9\u05dd \u05d1\u05d9\u05d5\u05ea\u05e8 \u05d1...", "`[\u05d4\u05de\u05e9\u05da \u05de\u05d4\u05d5\u05d3\u05e2\u05d4 \u05e7\u05d5\u05d3\u05de\u05ea \ud83d\udc46]`", "\ud83d\uddbc \u05ea\u05e2\u05e6\u05e8\u05d5 \u05d4\u05db\u05dc, \u05db\u05d9 \u05d0\u05ea\u05dd \u05e4\u05e9\u05d5\u05d8 \u05d7\u05d9\u05d9\u05d1\u05d9\u05dd \u05dc\u05d4\u05db\u05d9\u05e8 \u05d0\u05ea \u05e7\u05e6\u05d9\u05df \u05d4\u05d2\u05e9\u05e9\u05d9\u05dd \u05d4\u05d2\u05d9\u05d1\u05d5\u05e8 \u05e9\u05d4\u05ea\u05d7\u05d6\u05d4 \u05dc\u05de\u05d7\u05d1\u05dc \u05db\u05d3\u05d9 \u05dc\u05d4\u05e6\u05d9\u05dc...", "\u05de\u05e0\u05d4\u05dc \u05e8\u05e9\u05d5\u05ea \u05d4\u05de\u05d9\u05e1\u05d9\u05dd \u05e9\u05d9 \u05d0\u05d4\u05e8\u05d5\u05e0\u05d5\u05d1\u05d9\u05e5' \u05d5\u05e8\u05d0\u05e9 \u05d4\u05e2\u05d9\u05e8 \u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7 \u05d7\u05e0\u05d5\u05da \u05d6\u05d9\u05d9\u05d1\u05e8\u05d8 \u05e1\u05d9\u05db\u05de\u05d5 \u05db\u05d9 \u05e2\u05d5\u05d1\u05d3\u05d9 \u05d4\u05e8\u05e9\u05d5\u05ea \u05d9...", "\ud83c\udfac \u05e1\u05e4\u05e8\u05d3: \u05e9\u05e8\u05d9\u05e4\u05d5\u05ea \u05e2\u05e0\u05e7 - \u05de\u05d4\u05d2\u05d3\u05d5\u05dc\u05d5\u05ea \u05e9\u05d9\u05d3\u05e2\u05d4 \u05e1\u05e4\u05e8\u05d3, \u05db\u05d9\u05dc\u05d5 \u05d9\u05d5\u05ea\u05e8 \u05de\u05be250 \u05d0\u05dc\u05e3 \u05d3\u05d5\u05e0\u05dd \u05e9\u05dc \u05d9\u05e2\u05e8\u05d5\u05ea", "\u21a9\ufe0f \u05e8\u05e7 \u05e9\u05e8\u05d0\u05e9 \u05de\u05de\u05e9\u05dc\u05ea \u05e1\u05e4\u05e8\u05d3 \u05dc\u05d0 \u05d9\u05d0\u05e9\u05d9\u05dd \u05d0\u05ea \u05d9\u05e9\u05e8\u05d0\u05dc \u05d2\u05dd \u05d1\u05d6\u05d4...", "\u21a9\ufe0f\ud83c\udfac \u05ea\u05d7\u05e0\u05ea \u05d4\u05db\u05d5\u05d7 \u05d0-\u05e6\u05d1\u05d9\u05d4 \u05d1\u05db\u05d5\u05d5\u05d9\u05ea \u05d0\u05d7\u05e8\u05d9 \u05d8\u05d9\u05dc \u05d0\u05d9\u05e8\u05d0\u05e0\u05d9", "\ud83d\uddbc \u05d6\u05e7\u05d5\u05e7\u05d9\u05dd \u05dc\u05d1\u05d3\u05d9\u05e7\u05ea MRI? \u05d1\u05dc\u05d0\u05d5\u05de\u05d9\u05ea \u05ea\u05d7\u05db\u05d5 \u05e4\u05d7\u05d5\u05ea!", "\ud83c\udfac \u05e0\u05e9\u05d9\u05d0 \u05d1\u05d9\u05ea \u05d4\u05de\u05e9\u05e4\u05d8 \u05d4\u05e2\u05dc\u05d9\u05d5\u05df \u05dc\u05e9\u05e2\u05d1\u05e8 \u05d0\u05d4\u05e8\u05df \u05d1\u05e8\u05e7: \"\u05dc\u05d5\u05de\u05d3\u05d9 \u05ea\u05d5\u05e8\u05d4 \u05de\u05e1\u05db\u05e0\u05d9\u05dd, \u05e2\u05d5\u05e6\u05e8\u05d9\u05dd \u05d0\u05d5\u05ea\u05dd\".", "\u05d7\u05e9\u05d3 \u05dc\u05d0\u05d9\u05e8\u05d5\u05e2 \u05dc\u05d0\u05d5\u05de\u05e0\u05d9: \u05d8\u05d9\u05e1\u05d4 \u05e9\u05dc \u05d9\u05e9\u05e8\u05d0\u05d9\u05d9\u05e8 \u05d1\u05d5\u05d8\u05dc\u05d4 \u05dc\u05d0\u05d7\u05e8 \u05e9\u05e8\u05db\u05d1 \u05e9\u05d9\u05e8\u05d5\u05ea \u05e4\u05d2\u05e2 \u05d1\u05de\u05d8\u05d5\u05e1 - \u05d5\u05d4\u05d7\u05e9\u05d3 \u05d1\u05d9\u05e9\u05e8\u05d0\u05dc \u05db...", "\ud83d\uddbc \u05d0\u05d7\u05e8\u05d9 26 \u05e9\u05e0\u05d9\u05dd \u05d1\u05e2\u05d9\u05e8\u05d9\u05d9\u05ea \u05d1\u05d9\u05ea \u05e9\u05de\u05e9: \u05d0\u05e1\u05e3 \u05de\u05d8\u05e8\u05d9 \u05e0\u05e4\u05e8\u05d3 \u05d1\u05d8\u05e7\u05e1 \u05de\u05e8\u05d2\u05e9 \u05d1\u05d4\u05e9\u05ea\u05ea\u05e4\u05d5\u05ea \u05dc\u05de\u05e2\u05dc\u05d4 \u05de-100 \u05e2\u05d5\u05d1\u05d3\u05d9\u05dd \u05d5...", "\ud83d\uddbc \u05d4\u05e2\u05e8\u05d9\u05e0\u05d2: \u05d4\u05de\u05e7\"\u05e7\u05d9\u05dd \u05d1\u05d9\u05e9\u05d9\u05d1\u05d5\u05ea \u05d4\u05e2\u05dc\u05d5 \u05db\u05d5\u05e0\u05e0\u05d5\u05ea \u05dc\u05e7\u05e8\u05d0\u05ea \u05e1\u05d3\u05d9\u05d9\u05e8 \u05d2\u05d9\u05de\u05dc.", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05de\u05e8\u05d3\u05db\u05d9 \u05d4\u05dc\u05e4\u05e8\u05d9\u05df", "\ud83c\udfac \u05ea\u05d7\u05e0\u05ea \u05d4\u05db\u05d5\u05d7 \u05d0-\u05e6\u05d1\u05d9\u05d4 \u05d1\u05db\u05d5\u05d5\u05d9\u05ea \u05d0\u05d7\u05e8\u05d9 \u05d8\u05d9\u05dc \u05d0\u05d9\u05e8\u05d0\u05e0\u05d9.", "*\u05d1\u05de\u05e2\u05e8\u05db\u05ea \u05d4\u05d1\u05d9\u05d8\u05d7\u05d5\u05df \u05de\u05e2\u05e8\u05d9\u05db\u05d9\u05dd: \u05d1\u05db\u05d9\u05e8\u05d9\u05dd \u05d0\u05d9\u05e8\u05d0\u05e0\u05d9\u05dd \u05d9\u05d5\u05e8\u05d5 \u05dc\u05ea\u05e7\u05d5\u05e3 \u05d0\u05ea \u05d9\u05e9\u05e8\u05d0\u05dc \u05d1\u05d8\u05d9\u05dc\u05d9\u05dd*", "\u05e9\u05e8 \u05d4\u05d0\u05e0\u05e8\u05d2\u05d9\u05d4 \u05d4\u05d0\u05de\u05e8\u05d9\u05e7\u05d0\u05d9, \u05db\u05e8\u05d9\u05e1 \u05e8\u05d9\u05d9\u05d8 \u05d1\u05e8\u05d9\u05d0\u05d9\u05d5\u05df \u05dc-ABC: \u05d4\u05e0\u05e9\u05d9\u05d0 \u05d8\u05e8\u05d0\u05de\u05e4 \u05e8\u05d5\u05e6\u05d4 \u05dc\u05e1\u05d9\u05d9\u05dd \u05d0\u05ea \u05d6\u05d4 (\u05d0\u05d9\u05e8\u05d0\u05df) \u05d1\u05d4\u05e1...", "\u05d5\u05e2\u05d3\u05ea \u05d4\u05d7\u05d5\u05e7\u05d4 \u05e9\u05dc \u05d4\u05dc\u05d9\u05db\u05d5\u05d3 \u05d0\u05d9\u05e9\u05e8\u05d4:", "\u05e2\u05de\u05d9\u05ea \u05e1\u05d2\u05dc", "\u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d3\u05d9\u05d5\u05d5\u05d7 \u05e2\u05dc \u05d9\u05e8\u05d9 \u05d1\u05d1\u05e0\u05d9\u05d9\u05df \u05d1\u05e8\u05d7\u05d5\u05d1 \u05e8\u05e9\"\u05d9 2. \u05db\u05d5\u05d7\u05d5\u05ea \u05d4\u05e6\u05dc\u05d4 \u05d5\u05de\u05e9\u05d8\u05e8\u05d4 \u05d1\u05d3\u05e8\u05db\u05dd. \u05dc\u05d0 \u05d1\u05e8\u05d5\u05e8 \u05de\u05d4 \u05d0\u05d5\u05e4\u05d9 \u05d4\u05d0...", "\u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d1\u05d4\u05de\u05e9\u05da \u05dc\u05d0\u05d9\u05e8\u05d5\u05e2 \u05d1\u05e8\u05d7\u05d5\u05d1 \u05e8\u05e9\"\u05d9: \u05d2\u05d1\u05e8 \u05e0\u05e4\u05e6\u05e2 \u05de\u05d9\u05e8\u05d9 \u05d1\u05ea\u05d5\u05da \u05d1\u05d9\u05ea\u05d5 \u05d5\u05e4\u05d5\u05e0\u05d4 \u05d1\u05de\u05e6\u05d1 \u05d1\u05d9\u05e0\u05d5\u05e0\u05d9 \u05e2\u05dd \u05e4\u05e6\u05d9\u05e2\u05d4 ...", "\u05de\u05e0\u05db\"\u05dc \u05d0\u05e8\u05e7\u05d9\u05e2: \"\u05dc\u05d0 \u05e0\u05ea\u05e7\u05dc\u05e0\u05d5 \u05d1\u05d1\u05d9\u05e7\u05d5\u05e9 \u05d9\u05d5\u05e6\u05d0 \u05d3\u05d5\u05e4\u05df \u05dc\u05d8\u05d9\u05e1\u05d5\u05ea \u05dc\u05e7\u05e8\u05d0\u05ea \u05d4\u05d1\u05d7\u05d9\u05e8\u05d5\u05ea, \u05d0\u05e0\u05d7\u05e0\u05d5 \u05dc\u05d0 \u05e8\u05d5\u05d0\u05d9\u05dd \u05e9\u05d4\u05de\u05d8\u05d5...", "\ud83c\udfac \u05d1\u05d6\u05de\u05df \u05e9\u05e1\u05d9\u05e7\u05e8 \u05d0\u05ea \u05d4\u05e9\u05e8\u05d9\u05e4\u05d4 \u05d1\u05d7\u05d5\u05d5\u05ea \u05d2\u05dc\u05e2\u05d3 - \u05db\u05ea\u05d1 \u05db\u05d0\u05df \u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05d5\u05ea\u05e7\u05e3 \u05d5\u05e0\u05e9\u05d3\u05d3 \u05e2\u05dc \u05d9\u05d3\u05d9 \u05e4\u05d5\u05e8\u05e2\u05d9\u05dd \u05d9\u05d4\u05d5\u05d3\u05d9\u05dd.", "\u05d4\u05e2\u05d9\u05e8\u05d9\u05d9\u05d4 \u05d4\u05ea\u05e7\u05e4\u05dc\u05d4: \u05d4\u05e1\u05ea\u05d9\u05d9\u05de\u05d4 \u05d4\u05e4\u05d2\u05d9\u05e9\u05d4 \u05d1\u05d9\u05df \u05de\u05e0\u05d4\u05dc \u05e8\u05e9\u05d5\u05ea \u05d4\u05de\u05d9\u05e1\u05d9\u05dd \u05e9\u05d9 \u05d0\u05d4\u05e8\u05d5\u05e0\u05d5\u05d1\u05d9\u05e5' \u05dc\u05e8\u05d4\"\u05e2 \u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7, \u05d7\u05e0...", "\u05d3\u05d9\u05d5\u05d5\u05d7 \u05e8\u05d0\u05e9\u05d5\u05e0\u05d9 \u05e2\u05dc \u05d9\u05e8\u05d9 \u05d1\u05ea\u05d5\u05da \u05d1\u05d9\u05ea \u05d1\u05e2\u05d9\u05e8 \u05d0\u05dc\u05e2\u05d3 \u05e4\u05e6\u05d5\u05e2 \u05e7\u05e9\u05d4 \u05d1\u05de\u05e7\u05d5\u05dd \u05db\u05d5\u05d7\u05d5\u05ea \u05d4\u05e6\u05dc\u05d4 \u05d1\u05d3\u05e8\u05db\u05dd \u05dc\u05d6\u05d9\u05e8\u05d4 (\u05d4\u05e2\u05e8\u05d9\u05e0...", "*\u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05e1\u05e7\u05d5\u05e4\u05d9\u05dd*", "\u05d5\u05d5\u05e2\u05d3\u05ea \u05d7\u05d5\u05e7\u05d4 \u05e9\u05dc \u05d4\u05dc\u05d9\u05db\u05d5\u05d3 \u05d0\u05d9\u05e9\u05e8\u05d4 \u05d0\u05ea \u05d4\u05e6\u05e2\u05ea \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05d4\u05d7\u05d3\u05e9\u05d4 \u05dc\u05e9\u05e8\u05d9\u05d5\u05e0\u05d9\u05dd + \u05d0\u05e4\u05e9\u05e8\u05d5\u05ea \u05dc\u05d1\u05d8\u05dc \u05d0\u05ea \u05d4\u05e4\u05e8\u05d9\u05d9\u05de\u05e8\u05d9...", "\ud83c\udfac \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05de\u05e9\u05d4 \u05d5\u05d9\u05e1\u05d1\u05e8\u05d2", "\u05d5\u05e2\u05d3\u05ea \u05d4\u05d7\u05d5\u05e7\u05d4 \u05e9\u05dc \u05d4\u05dc\u05d9\u05db\u05d5\u05d3 \u05d0\u05d9\u05e9\u05e8\u05d4 \u05d0\u05ea \u05d4\u05e6\u05e2\u05ea \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05d4\u05d7\u05d3\u05e9\u05d4 \u05dc\u05e9\u05d1\u05e2 \u05e9\u05e8\u05d9\u05d5\u05e0\u05d9\u05dd \u05d9\u05d7\u05d3 \u05e2\u05dd \u05d0\u05e4\u05e9\u05e8\u05d5\u05ea \u05dc\u05d1\u05d8\u05dc \u05d0\u05ea ...", "\ud83d\uddbc *\ud83c\udf7d\ufe0f\u05d4\u05de\u05e0\u05d4 \u05e8\u05e7 \u05de\u05d5\u05d2\u05e9\u05ea*", "\u05d3\u05e4\u05e0\u05d4 \u05dc\u05d9\u05d0\u05dc", "\ud83d\uddbc \u05d3\u05d9\u05df \u05e4\u05d9\u05e9\u05e8", "\u05d5\u05e2\u05d3\u05ea \u05d4\u05d7\u05d5\u05e7\u05d4 \u05e9\u05dc \u05d4\u05dc\u05d9\u05db\u05d5\u05d3 \u05d0\u05d9\u05e9\u05e8\u05d4 7 \u05e9\u05e8\u05d9\u05d5\u05e0\u05d9\u05dd \u05dc\u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 - \u05d1-29 \u05d4\u05de\u05e7\u05d5\u05de\u05d5\u05ea \u05d4\u05e8\u05d0\u05e9\u05d5\u05e0\u05d9\u05dd \u2022 \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05dc\u05d7\u05d1\u05e8\u05d9 \u05d5...", "\ud83c\udfac \u05d1\u05de\u05d5\u05e6\u05d0\u05d9 \u05e9\u05d1\u05ea \u05d4\u05e7\u05e8\u05d5\u05d1 \u05d6\u05d4 \u05e7\u05d5\u05e8\u05d4 \u23f1\ufe0f \u05db\u05e8\u05d8\u05d9\u05e1\u05d9\u05dd \u05d0\u05d7\u05e8\u05d5\u05e0\u05d9\u05dd!!!", "\ud83d\uddbc \u05e9\u05dc\u05d7\u05d5 \u05d0\u05ea \u05d4\u05de\u05d9\u05dc\u05d4 \u05de\u05d2\u05d6\u05d9\u05df", "\ud83d\uddbc \u05ea\u05d5\u05e9\u05d1 \u05d0\u05dc\u05e2\u05d3 \u05d1\u05de\u05e6\u05d1 \u05d1\u05d9\u05e0\u05d5\u05e0\u05d9 \u05e2\u05d3 \u05e7\u05e9\u05d4 \u05de\u05d9\u05e8\u05d9 \u05d1\u05d1\u05d9\u05ea \u05d1\u05e2\u05d9\u05e8. \u05d4\u05e8\u05e7\u05e2 \u05db\u05db\u05dc \u05d4\u05e0\u05e8\u05d0\u05d4 \u05e4\u05dc\u05d9\u05dc\u05d9.", "\ud83d\uddbc \u05ea\u05d5\u05e9\u05d1 \u05d0\u05dc\u05e2\u05d3 \u05d1\u05df 27 \u05e0\u05e4\u05d2\u05e2 \u05d1\u05d0\u05d9\u05e8\u05d5\u05e2 \u05d0\u05dc\u05d9\u05de\u05d5\u05ea \u05d1\u05e8\u05d7\u05d5\u05d1 \u05e8\u05e9\u05d9. \u05e6\u05d5\u05d5\u05ea\u05d9 \u05d0\u05d9\u05d7\u05d5\u05d3 \u05d4\u05e6\u05dc\u05d4 \u05d4\u05d2\u05d9\u05e2\u05d5 \u05e8\u05d0\u05e9\u05d5\u05e0\u05d9\u05dd \u05dc\u05de\u05e7\u05d5...", "\ud83d\uddbc *\u05db\u05db\u05d4 \u05e0\u05e8\u05d0\u05d9\u05dd \u05d1\u05ea\u05d9\u05dd \u05e9\u05dc \u05de\u05dc\u05d9\u05d5\u05df \u05d3\u05d5\u05dc\u05e8 \u05d1\u05e2\u05d5\u05dc\u05dd*", "\ud83c\udfac \u05d4\u05d2\u05d0\u05d5\u05df \u05d4\u05d2\u05d3\u05d5\u05dc \u05d4\u05e8\u05d1 \u05d9\u05e6\u05d7\u05e7 \u05db\u05d4\u05df \u05e9\u05dc\u05d9\u05d8\"\u05d0", "\ud83d\uddbc *\u05d4\u05d0\u05d5\u05d9\u05d1 \u05e9\u05d1\u05ea\u05d5\u05db\u05e0\u05d5*", "\ud83c\udfac *100,488 \u05e9\"\u05d7 \u05d9\u05db\u05d5\u05dc\u05d9\u05dd \u05dc\u05d4\u05d9\u05db\u05e0\u05e1 \u05d0\u05dc\u05d9\u05db\u05dd \u05dc\u05d7\u05e9\u05d1\u05d5\u05df \u05d1\u05e0\u05e7 - \u05d0\u05dd \u05e8\u05e7 \u05ea\u05d1\u05d3\u05e7\u05d5 \u05d6\u05db\u05d0\u05d5\u05ea\u203c\ufe0f*", "\u05de\u05d1\u05d6\u05e7\u05df 12", "\ud83d\uddbc \u05e0\u05e4\u05dc \u05d1\u05d2\u05d9\u05e0\u05d4: \u05db\u05d5\u05d7\u05d5\u05ea \u05d4\u05e6\u05dc\u05d4 \u05d4\u05d5\u05d6\u05e2\u05e7\u05d5 \u05d1\u05e9\u05e2\u05d4 18:10 \u05dc\u05d2\u05d9\u05e0\u05ea \u05e4\u05e8\u05d3\u05d5 \u05d1\u05e2\u05d9\u05e8, \u05d1\u05e2\u05e7\u05d1\u05d5\u05ea \u05d3\u05d9\u05d5\u05d5\u05d7 \u05e2\u05dc \u05e4\u05e2\u05d5\u05d8 \u05db\u05d1\u05df \u05e9...", "\ud83d\uddbc \u05d1\u05e2\u05e7\u05d1\u05d5\u05ea \u05ea\u05e7\u05d9\u05e4\u05ea \u05e4\u05e7\u05d7\u05d9 \u05e8\u05e9\u05d5\u05ea \u05d4\u05de\u05d9\u05e1\u05d9\u05dd \u05d1\u05e9\u05d9\u05db\u05d5\u05df \u05d5\u05d9\u05d6'\u05e0\u05d9\u05e5 \u05d1\u05e2\u05d9\u05e8, \u05e0\u05e2\u05e8\u05db\u05d4 \u05d4\u05d9\u05d5\u05dd \u05e4\u05d2\u05d9\u05e9\u05d4 \u05d1\u05d9\u05df \u05de\u05e0\u05d4\u05dc \u05e8\u05e9\u05d5...", "\ud83d\uddbc \u05dc\u05d0\u05d7\u05e8 \u05d4\u05de\u05d4\u05d5\u05de\u05d4 \u05e1\u05d1\u05d9\u05d1 \u05e4\u05e7\u05d7\u05d9 \u05de\u05e1 \u05d4\u05db\u05e0\u05e1\u05d4, \u05e8\u05d0\u05e9 \u05d4\u05e2\u05d9\u05e8 \u05d7\u05e0\u05d5\u05da \u05d6\u05d9\u05d9\u05d1\u05e8\u05d8 \u05d0\u05d9\u05e8\u05d7 \u05d4\u05d9\u05d5\u05dd \u05d1\u05dc\u05e9\u05db\u05ea\u05d5 \u05dc\u05d1\u05d9\u05e7\u05d5\u05e8 \u05e8\u05e9\u05de...", "\ud83d\uddbc *\u05d4\u05e8\u05de\u05d8\u05db\u201d\u05dc \u05dc\u05de\u05e4\u05e7\u05d3\u05d9\u05dd \u05d1\u05d9\u05d4\u05d5\u05d3\u05d4 \u05d5\u05e9\u05d5\u05de\u05e8\u05d5\u05df: \u05f4\u05dc\u05e6\u05d3 \u05d4\u05dc\u05d7\u05d9\u05de\u05d4 \u05d4\u05de\u05ea\u05de\u05e9\u05db\u05ea \u05e0\u05d2\u05d3 \u05d4\u05d8\u05e8\u05d5\u05e8 \u05d1\u05d9\u05d5\u05f4\u05e9 \u05d0\u05e0\u05d7\u05e0\u05d5 \u05e2\u05d5\u05e7\u05d1...", "\u05d4\u05e8\u05de\u05d8\u05db\u05f4\u05dc: \u05d0\u05e0\u05d7\u05e0\u05d5 \u05e2\u05d5\u05e7\u05d1\u05d9\u05dd \u05de\u05e7\u05e8\u05d5\u05d1 \u05d0\u05d7\u05e8 \u05d4\u05d4\u05ea\u05e4\u05ea\u05d7\u05d5\u05d9\u05d5\u05ea \u05d1\u05d0\u05d9\u05e8\u05d0\u05df \u05d5\u05e9\u05d5\u05de\u05e8\u05d9\u05dd \u05e2\u05dc \u05d3\u05e8\u05d9\u05db\u05d5\u05ea \u05d2\u05d1\u05d5\u05d4\u05d4 - \u05d0\u05e0\u05d7\u05e0\u05d5 ...", "\ud83c\udfac \u05e0\u05d9\u05e6\u05df \u05e9\u05e4\u05d9\u05e8\u05d0", "\ud83d\uddbc \u05de\u05ea\u05d3\u05dc\u05e7\u05d9\u05dd \u05d0\u05de\u05e8\u05d9\u05e7\u05d0\u05d9\u05d9\u05dd \u05d1\u05e2\u05e7\u05d1\u05d4.", "\u05dc\u05e4\u05e0\u05d9 \u05d6\u05de\u05df \u05e7\u05e6\u05e8, \u05d7\u05d9\u05dc \u05d4\u05d0\u05d5\u05d5\u05d9\u05e8 \u05d9\u05d9\u05e8\u05d8 \u05db\u05dc\u05d9 \u05d8\u05d9\u05e1 \u05d1\u05dc\u05ea\u05d9 \u05de\u05d0\u05d5\u05d9\u05e9 \u05e9\u05d6\u05d5\u05d4\u05d4 \u05d1\u05de\u05e8\u05d7\u05d1 \u05d2\u05d1\u05d5\u05dc \u05e1\u05d5\u05e8\u05d9\u05d4.", "\u05d2\u05d5\u05e8\u05dd \u05d1\u05d9\u05d8\u05d7\u05d5\u05e0\u05d9: \u05d0\u05e8\u05d4\u05f4\u05d1 \u05d4\u05de\u05ea\u05d9\u05e0\u05d4 \u05dc\u05e1\u05d9\u05d5\u05dd \u05d4\u05de\u05d5\u05e0\u05d3\u05d9\u05d0\u05dc. \u05db\u05e2\u05ea \u05d4\u05d1\u05dc\u05de\u05d9\u05dd \u05d4\u05d5\u05e1\u05e8\u05d5 \u05d5\u05d4\u05e1\u05d9\u05db\u05d5\u05d9\u05d9\u05dd \u05dc\u05d4\u05e1\u05dc\u05de\u05d4 \u05de\u05d6\u05e0\u05e7...", "\ud83d\udd01 \u05e4\u05e8\u05e1\u05d5\u05dd - \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05dc\u05d7\u05d1\u05e8\u05d9 \u05d5\u05e2\u05d3\u05ea \u05d7\u05d5\u05e7\u05d4 \u05e9\u05dc \u05d4\u05dc\u05d9\u05db\u05d5\u05d3: \u05f4\u05d0\u05e0\u05d9 \u05d1\u05e2\u05d3 \u05e4\u05e8\u05d9\u05d9\u05de\u05e8\u05d9\u05d6 \u05d0\u05d1\u05dc \u05d9\u05e9 \u05d0\u05e4\u05e9\u05e8\u05d5\u05ea \u05e9\u05e0\u05e7\u05dc\u05e2 \u05dc...", "\u05d5\u05d1\u05e7\u05d9\u05e6\u05d5\u05e8, \u05db\u05dc \u05d4\u05e1\u05dc\u05de\u05d4 \u05de\u05e2\u05db\u05e9\u05d9\u05d5 \u05d5\u05d1\u05d7\u05d5\u05d3\u05e9 \u05d4\u05e7\u05e8\u05d5\u05d1 \u05ea\u05d5\u05d1\u05d9\u05dc \u05dc\u05d1\u05d9\u05d8\u05d5\u05dc \u05d4\u05e4\u05e8\u05d9\u05d9\u05de\u05e8\u05d9\u05d6.", "\u05d4\u05e8\u05de\u05d8\u05db\"\u05dc: \"\u05e2\u05d5\u05e7\u05d1\u05d9\u05dd \u05de\u05e7\u05e8\u05d5\u05d1 \u05d0\u05d7\u05e8 \u05d4\u05d4\u05ea\u05e4\u05ea\u05d7\u05d5\u05d9\u05d5\u05ea \u05d1\u05d0\u05d9\u05e8\u05d0\u05df \u05d5\u05e9\u05d5\u05de\u05e8\u05d9\u05dd \u05e2\u05dc \u05d3\u05e8\u05d9\u05db\u05d5\u05ea \u05d2\u05d1\u05d5\u05d4\u05d4. \u05e2\u05e8\u05d5\u05db\u05d9\u05dd \u05dc\u05d7\u05d6\u05e8\u05d4 ...", "\ud83d\uddbc \u05d1\u05d9\u05e9\u05e8\u05d0\u05dc \u05e0\u05e2\u05e8\u05db\u05d9\u05dd: \u05d4\u05d0\u05de\u05e8\u05d9\u05e7\u05e0\u05d9\u05dd \u05e6\u05e4\u05d5\u05d9\u05d9\u05dd \u05dc\u05d4\u05e0\u05d7\u05d5\u05ea \u05e2\u05dc \u05d4\u05d2\u05e2\u05d4 \u05e9\u05dc \u05de\u05d8\u05d5\u05e1\u05d9 \u05ea\u05d3\u05dc\u05d5\u05e7 \u05e0\u05d5\u05e1\u05e4\u05d9\u05dd. \u05d4\u05de\u05d5\u05e0\u05d9 \u05d8\u05d9\u05e1...", "\u05d7\u05d9\u05dc \u05d4\u05d0\u05d5\u05d5\u05d9\u05e8 \u05d9\u05d9\u05e8\u05d8 \u05db\u05dc\u05d9 \u05d8\u05d9\u05e1 \u05d1\u05dc\u05ea\u05d9 \u05de\u05d0\u05d5\u05d9\u05e9 \u05e9\u05d6\u05d5\u05d4\u05d4 \u05d1\u05de\u05e8\u05d7\u05d1 \u05d2\u05d1\u05d5\u05dc \u05e1\u05d5\u05e8\u05d9\u05d4. \u05de\u05e6\u05d4\"\u05dc \u05e0\u05de\u05e1\u05e8 \u05e9\u05de\u05e7\u05d5\u05e8 \u05d4\u05e9\u05d9\u05d2\u05d5\u05e8 ...", "\ud83d\uddbc \u05d4\u05e8\u05de\u05d8\u05db\u201d\u05dc \u05d6\u05de\u05d9\u05e8 \u05dc\u05de\u05e4\u05e7\u05d3\u05d9\u05dd \u05d1\u05d9\u05d4\u05d5\u05d3\u05d4 \u05d5\u05e9\u05d5\u05de\u05e8\u05d5\u05df: \"\u05d0\u05e0\u05d7\u05e0\u05d5 \u05e2\u05d5\u05e7\u05d1\u05d9\u05dd \u05de\u05e7\u05e8\u05d5\u05d1 \u05d0\u05d7\u05e8 \u05d4\u05d4\u05ea\u05e4\u05ea\u05d7\u05d5\u05d9\u05d5\u05ea \u05d1\u05d0\u05d9\u05e8\u05d0\u05df ...", "\u05e9\u05d9\u05dc\u05d4 \u05e4\u05e8\u05d9\u05d3: \u05d4\u05e2\u05d5\u05e0\u05e9 \u05e0\u05d2\u05de\u05e8: \u05e7\u05e8\u05df \u05d4\u05e4\u05d9\u05e6\u05d5\u05d9\u05d9\u05dd \u05e9\u05dc \u05e8\u05e9\u05d5\u05ea \u05d4\u05de\u05e1\u05d9\u05dd \u05ea\u05de\u05e9\u05d9\u05da \u05dc\u05ea\u05ea \u05e9\u05d9\u05e8\u05d5\u05ea \u05dc\u05ea\u05d5\u05e9\u05d1\u05d9 \u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7 \u05e9\u05d1...", "\u05d3\u05d5\u05d1\u05e8 \u05e6\u05d4\"\u05dc: \u05dc\u05e4\u05e0\u05d9 \u05d6\u05de\u05df \u05e7\u05e6\u05e8, \u05d7\u05d9\u05dc \u05d4\u05d0\u05d5\u05d5\u05d9\u05e8 \u05d9\u05d9\u05e8\u05d8 \u05db\u05dc\u05d9 \u05d8\u05d9\u05e1 \u05d1\u05dc\u05ea\u05d9 \u05de\u05d0\u05d5\u05d9\u05e9 \u05e9\u05d6\u05d5\u05d4\u05d4 \u05d1\u05de\u05e8\u05d7\u05d1 \u05d2\u05d1\u05d5\u05dc \u05e1\u05d5\u05e8\u05d9\u05d4. \u05de...", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05e9\u05d9\u05dc\u05d4 \u05e4\u05e8\u05d9\u05d3\ud83c\uddee\ud83c\uddf1"]}