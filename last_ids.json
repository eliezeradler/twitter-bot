//t.me/N12chat/218018", "https://t.me/N12chat/218019", "https://t.me/N12chat/218020", "https://t.me/N12chat/218021", "https://t.me/N12chat/218022", "https://t.me/N12chat/218023", "https://t.me/N12chat/218026", "https://t.me/N12chat/218028"], "global_seen_titles": ["\u26a0\ufe0f \u05d4\u05d4\u05d5\u05d3\u05e2\u05d4 \u05d4\u05d6\u05d0\u05ea \u05dc\u05d0 \u05de\u05d9\u05d5\u05e2\u05d3\u05ea \u05dc\u05db\u05d5\u05dc\u05dd", "\ud83c\udfac \u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05e1\u05e7\u05d5\u05e4\u05d9\u05dd", "\ud83d\uddbc \u05de\u05d1\u05e6\u05e2 \u05de\u05e2\u05d5\u05dc\u05d4, \u05e7\u05e0\u05d9\u05ea\u05d9 4 \u05de\u05e7\u05e8\u05e8\u05d9\u05dd.", "\ud83c\udfac \u05ea\u05e7\u05d9\u05e4\u05d5\u05ea \u05d8\u05d9\u05dc\u05d9\u05dd \u05d0\u05d9\u05e8\u05d0\u05e0\u05d9\u05d5\u05ea \u05d2\u05e8\u05de\u05d5 \u05dc\u05e0\u05d6\u05e7 \u05db\u05d1\u05d3 \u05dc\u05d0\u05e7\u05d3\u05de\u05d9\u05d4 \u05dc\u05d1\u05d9\u05d8\u05d7\u05d5\u05df \u05d1\u05db\u05d5\u05d5\u05d9\u05ea.", "\ud83d\uddbc *\u05db\u05e9\u05d0\u05de\u05d1\u05dc\u05d4 \u05d0\u05d3\u05de\u05d9, \u05d9\u05dc\u05d3\u05d4 \u05d1\u05ea 11 \u05e2\u05dd \u05ea\u05e1\u05de\u05d5\u05e0\u05ea \u05d3\u05d0\u05d5\u05df \u05de\u05e6\u05e4\u05d5\u05df \u05de\u05e7\u05d3\u05d5\u05e0\u05d9\u05d4, \u05e1\u05d1\u05dc\u05d4 \u05de\u05d4\u05d3\u05e8\u05d4 \u05d1\u05d1\u05d9\u05ea \u05d4\u05e1\u05e4\u05e8 \u05d0\u05d7\u05e8\u05d9 ...", "\ud83d\uddbc \u05e9\u05dc\u05de\u05d4 \u05d2\u05d6\u05d9\u05ea \u05d9\u05d5\u05e2\u05e5 \u05d7\"\u05db \u05d9\u05e2\u05e7\u05d1 \u05de\u05e8\u05d2\u05d9 \u05e0\u05e4\u05e8\u05d3 \u05de\u05de\u05e0\u05d5..", "\ud83c\udfac *\u05ea\u05e9\u05e2\u05d4 \u05d1\u05d0\u05d1:*", "\u05dc\u05e7\u05e8\u05d0\u05ea \u05d2\u05de\u05e8 \u05d4\u05de\u05d5\u05e0\u05d3\u05d9\u05d0\u05dc: \u05de\u05e1\u05e4\u05e8 \u05d9\u05e9\u05d9\u05d1\u05d5\u05ea \u05d4\u05d5\u05d3\u05d9\u05e2\u05d5 \u05dc\u05d1\u05d7\u05d5\u05e8\u05d9\u05dd \u05e2\u05dc \u05e0\u05d5\u05db\u05d7\u05d5\u05ea \u05d7\u05d5\u05d1\u05d4 \u05d1\u05e1\u05d3\u05e8 \u05d2\u05f3 \u05d1\u05d9\u05de\u05d9\u05dd \u05d4\u05e7\u05e8\u05d5\u05d1\u05d9...", "\ud83d\uddbc \u05e8\u05d9\u05de\u05d5\u05df \u05d4\u05dc\u05dd \u05d4\u05d5\u05e9\u05dc\u05da \u05dc\u05e2\u05d1\u05e8 \u05d1\u05e0\u05d9\u05d9\u05df \u05de\u05d2\u05d5\u05e8\u05d9\u05dd \u05d1\u05e2\u05d9\u05e8 \u05e0\u05ea\u05e0\u05d9\u05d4. \u05d0\u05d9\u05df \u05e0\u05e4\u05d2\u05e2\u05d9\u05dd \u05d1\u05d2\u05d5\u05e3", "\ud83d\uddbc *\u05d1\u05e7\u05d9\u05e5 \u05d4\u05d6\u05d4 \u05db\u05d5\u05dc\u05e0\u05d5 \u05d1\u05de\u05d5\u05d6\u05d9\u05d0\u05d5\u05df \u05d2\u05d5\u05e9 \u05e7\u05d8\u05d9\u05e3 \u05d1\u05d9\u05e8\u05d5\u05e9\u05dc\u05d9\u05dd\ud83e\udde1*", "\u05d4\u05db\u05d5\u05e0\u05e0\u05d5\u05ea \u05d1\u05d9\u05e9\u05e8\u05d0\u05dc \u05dc\u05d4\u05e8\u05d7\u05d1\u05ea \u05d4\u05dc\u05d7\u05d9\u05de\u05d4: \u05d9\u05e9\u05e8\u05d0\u05dc \u05de\u05e2\u05d5\u05e8\u05d1\u05ea \u05d1\u05d2\u05d9\u05d1\u05d5\u05e9 \u05d4\u05ea\u05d5\u05db\u05e0\u05d9\u05d5\u05ea \u05d4\u05d0\u05de\u05e8\u05d9\u05e7\u05e0\u05d9\u05d5\u05ea \u05dc\u05d4\u05de\u05e9\u05da \u05d4\u05dc\u05d7\u05d9...", "\ud83d\uddbc \u05d3\u05e8\u05db\u05d9 \u05e4\u05e8\u05d9\u05d6 \u05d0\u05d1\u05dc\u05d5\u05ea", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05de\u05e0\u05d7\u05dd \u05e7\u05d5\u05dc\u05d3\u05e6\u05e7\u05d9", "\ud83d\uddbc \u05e2\u05e8\u05d5\u05e6\u05d9 \u05d0\u05d5\u05e4\u05d5\u05d6\u05d9\u05e6\u05d9\u05d4 \u05d0\u05d9\u05e8\u05d0\u05e0\u05d9\u05dd: \u05d4\u05e8\u05e4\u05d5\u05d1\u05dc\u05d9\u05e7\u05d4 \u05d4\u05d0\u05e1\u05dc\u05d0\u05de\u05d9\u05ea \u05de\u05e9\u05d7\u05e7\u05ea \u05d1\u05d7\u05d9\u05d9 \u05d0\u05d3\u05dd \u05db\u05d0\u05dc\u05d5 \u05de\u05d3\u05d5\u05d1\u05e8 \u05d1\u05de\u05e9\u05d7\u05e7 \u05e4\u05d0...", "\ud83d\uddbc \u05d3\u05d1 \u05d0\u05d9\u05d9\u05db\u05dc\u05e8 \u05de\u05e6\u05d8\u05d8 \u05d0\u05ea \u05e2\u05de\u05d9\u05d7\u05d9 \u05d0\u05ea\u05d0\u05dc\u05d9", "\ud83c\udfac \u05dc\u05de\u05d9 \u05e9\u05d6\u05d4 \u05dc\u05d0 \u05e7\u05e8\u05d4 \u05d0\u05d9\u05df \u05dc\u05d5 \u05de\u05d9\u05e0\u05d9\u05d1\u05e8 \u05d1\u05d1\u05d9\u05ea", "\ud83d\uddbc *\u05d0\u05e0\u05e9\u05d9 \u05d0\u05de\u05d5\u05e0\u05d4 |* \u05ea\u05e8\u05d0\u05d5 \u05d0\u05ea \u05e2\u05d5\u05e6\u05de\u05d5\u05ea \u05d4\u05e0\u05e4\u05e9 \u05d4\u05d0\u05d3\u05d9\u05e8\u05d5\u05ea \u05e9\u05d9\u05e9 \u05dc\u05d0\u05e0\u05e9\u05d9\u05dd \u05d1\u05d7\u05d5\u05d5\u05ea \u05d2\u05dc\u05e2\u05d3!", "\ud83d\uddbc \u05e4\u05e9\u05d5\u05d8 \u05d7\u05d5\u05e6\u05e4\u05d4!!!!!\ud83d\ude05", "\ud83c\udfac \u05d0\u05dc\u05d9\u05d4 \u05d0\u05d1\u05d9\u05d1:", "*\u05de\u05d4\u05d5\u05de\u05d5\u05ea \u05d1\u05d0\u05dc\u05e2\u05d3 |* \u05d1\u05d7\u05d5\u05e8 \u05de\u05d9\u05e9\u05d9\u05d1\u05ea \u05ea\u05d5\u05e8\u05d4 \u05d1\u05ea\u05e4\u05d0\u05e8\u05ea\u05d4 \u05e0\u05d3\u05e8\u05e1 \u05d1\u05dc\u05d9\u05dc \u05e9\u05d1\u05ea \u05d1\u05de\u05d4\u05dc\u05da \u05de\u05d7\u05d0\u05d5\u05ea \u05e0\u05d2\u05d3 \u05d7\u05d9\u05dc\u05d5\u05dc\u05d9 \u05d4\u05e9\u05d1\u05ea ...", "\ud83d\uddbc \ud83c\udfe1 \u05ea\u05d0\u05e8\u05d9\u05db\u05d9\u05dd \u05d0\u05d7\u05e8\u05d5\u05e0\u05d9\u05dd \u05dc\u05d1\u05d9\u05df \u05d4\u05d6\u05de\u05e0\u05d9\u05dd \u05d1\"\u05d5\u05d9\u05dc\u05d4 \u05e0\u05d5\u05e3 \u05d4\u05d2\u05d1\u05e2\u05d4\"! \ud83c\udfe1", "\ud83c\udfac \u05d0\u05e1\u05e3 \u05e8\u05d5\u05d6\u05e0\u05e6\u05d5\u05d9\u05d9\u05d2", "\ud83d\uddbc \u05d4\u05d4\u05d6\u05d3\u05de\u05e0\u05d5\u05ea \u05dc\u05d4\u05d2\u05d9\u05e2 \u05dc\u05d3\u05d9\u05e8\u05d4 \u05de\u05e9\u05dc\u05db\u05dd \u05d1\u05de\u05e8\u05db\u05d6 \u05d4\u05d0\u05e8\u05e5!", "\u05dc\u05d9\u05dc\u05d4 \u05e9\u05de\u05d9\u05e0\u05d9 \u05d1\u05e8\u05e6\u05d9\u05e4\u05d5\u05ea: \u05e6\u05d1\u05d0 \u05d0\u05e8\u05d4\"\u05d1 \u05d4\u05d5\u05d3\u05d9\u05e2 \u05e9\u05e4\u05ea\u05d7 \u05d1\u05d2\u05dc \u05ea\u05e7\u05d9\u05e4\u05d5\u05ea \u05d1\u05d0\u05d9\u05e8\u05d0\u05df", "\ud83c\udfac *\u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05e1\u05e7\u05d5\u05e4\u05d9\u05dd*", "\u05d4\u05e9\u05de\u05d5\u05e2\u05d4 \u05d4\u05d9\u05d0 \u05e9\u05d7\u05d1\u05d9\u05d9\u05e8 \u05de\u05d9\u05dc\u05d9\u05d9 \u05de\u05d2\u05d9\u05e2 \u05e9\u05d5\u05d1 \u05dc\u05d7\u05d1\u05e8\u05d5\u05df \u05d4\u05e4\u05e2\u05dd \u05db\u05d3\u05d9 \u05dc\u05e8\u05d0\u05d5\u05ea \u05d0\u05ea \u05d4\u05de\u05e9\u05d7\u05e7 \ud83d\ude09", "\u05dc\u05d9\u05dc\u05d4 \u05e9\u05de\u05d9\u05e0\u05d9 \u05d1\u05e8\u05e6\u05d9\u05e4\u05d5\u05ea: \u05e6\u05d1\u05d0 \u05d0\u05e8\u05d4\"\u05d1 \u05d4\u05d5\u05d3\u05d9\u05e2 \u05e9\u05e4\u05ea\u05d7 \u05d1\u05d2\u05dc \u05ea\u05e7\u05d9\u05e4\u05d5\u05ea \u05d1\u05d0\u05d9\u05e8\u05d0\u05df.", "\u05d1\u05df \u05d2\u05d5\u05dc\u05d3\u05e4\u05e8\u05d9\u05d9\u05e0\u05d3", "\ud83d\uddbc *\u05d0\u05d7\u05e8\u05d9 \u05e0\u05e4\u05d9\u05dc\u05ea\u05dd \u05e9\u05dc \u05d4\u05d7\u05d9\u05d9\u05dc\u05d9\u05dd \u05d4\u05d0\u05de\u05e8\u05d9\u05e7\u05d0\u05d9\u05dd: \u05e6\u05d1\u05d0 \u05d0\u05e8\u05d4\"\u05d1 \u05e4\u05ea\u05d7 \u05d1\u05d2\u05dc \u05ea\u05e7\u05d9\u05e4\u05d5\u05ea \u05d1\u05d0\u05d9\u05e8\u05d0\u05df.*", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d9\u05e9\u05e8\u05d0\u05dc \u05db\u05d4\u05df", "\ud83d\udd01\ud83c\udfac \u05e1\u05d0\u05d2\u05ea \u05d4\u05de\u05ea\u05d3\u05dc\u05e7\u05d9\u05dd \u05d1\u05e0\u05ea\u05d1\"\u05d2. \u05e9\u05e8\u05ea \u05d4\u05ea\u05d7\u05d1\u05d5\u05e8\u05d4 \u05e8\u05d2\u05d1 \u05de\u05d3\u05d1\u05e8\u05ea. \u05e2\u05db\u05e9\u05d9\u05d5 14.", "\ud83d\uddbc \u05e1\u05d9\u05d5\u05e2 \u05d3\u05d7\u05d5\u05e3 \u05d1\u05d0\u05d9\u05ea\u05d5\u05e8 \u05e0\u05e2\u05d3\u05e8", "\u05d3\u05e1\u05e7 \u05d4\u05d7\u05d5\u05e5", "\u05d1\u05d4\u05de\u05e9\u05da \u05dc\u05e0\u05e2\u05d3\u05e8 \u05d0\u05dc\u05d9\u05d4\u05d5 \u05d0\u05d1\u05d0 \u05e9\u05d0\u05d5\u05dc \u05de\u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7, \u05d4\u05d5\u05d0 \u05d0\u05d5\u05ea\u05e8 \u05dc\u05e4\u05e0\u05d9 \u05d6\u05de\u05df \u05e7\u05e6\u05e8, \u05ea\u05d5\u05d3\u05d4 \u05dc\u05db\u05d5\u05dc\u05dd.", "\u05d0\u05d9\u05dc\u05e0\u05d9\u05ea \u05d0\u05d3\u05dc\u05e8", "\ud83d\uddbc \u05e8\u05de\u05ea \u05d2\u05df, \u05d4\u05ea\u05e4\u05d5\u05e6\u05d5\u05ea, \u05e9\u05e8\u05d9\u05e4\u05d4 \u05d1\u05d7\u05e6\u05e8 \u05d1\u05d9\u05ea, \u05dc\u05dc\u05d0 \u05e0\u05e4\u05d2\u05e2\u05d9\u05dd, \u05e2\u05e9\u05df \u05e0\u05e8\u05d0\u05d4 \u05de\u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7.", "\u05d1\u05d4\u05ea\u05d0\u05dd \u05dc\u05d4\u05e2\u05e8\u05db\u05ea \u05d4\u05de\u05e6\u05d1, \u05d4\u05d5\u05d7\u05dc\u05d8 \u05e2\u05dc \u05d4\u05d8\u05dc\u05ea \u05e6\u05d5 \u05e9\u05d8\u05d7 \u05e6\u05d1\u05d0\u05d9 \u05e1\u05d2\u05d5\u05e8, \u05d4\u05d7\u05dc \u05de\u05d4\u05d9\u05d5\u05dd \u05d1\u05e9\u05e2\u05d4 08:00 \u05d5\u05e2\u05d3 \u05de\u05d7\u05e8 \u05d1\u05e9\u05e2\u05d4 08:0...", "\ud83c\udfac \u05e2\u05dc \u05e8\u05e7\u05e2 \u05e6\u05e2\u05d3\u05d4 \u05d2\u05d3\u05d5\u05dc\u05d4 \u05d4\u05de\u05ea\u05d5\u05db\u05e0\u05e0\u05ea \u05dc\u05ea\u05d5\u05da \u05e8\u05e6\u05d5\u05e2\u05ea \u05e2\u05d6\u05d4, \u05d0\u05dc\u05d5\u05e3 \u05e4\u05d9\u05e7\u05d5\u05d3 \u05d4\u05d3\u05e8\u05d5\u05dd \u05d9\u05e0\u05d9\u05d1 \u05e2\u05e9\u05d5\u05e8, \u05e7\u05d1\u05e2 \u05e6\u05d5 \u05e9\u05d8\u05d7...", "\u05e0\u05d9\u05e6\u05df \u05e9\u05e4\u05d9\u05e8\u05d0", "\u05d4\u05e9\u05d1\u05d5\u05e2 \u05e6\u05e4\u05d5\u05d9 \u05dc\u05d4\u05d9\u05d5\u05ea \u05d4\u05e9\u05d1\u05d5\u05e2 \u05d4\u05db\u05d9 \u05d7\u05dd \u05d1\u05d9\u05e9\u05e8\u05d0\u05dc \u05e9\u05d4\u05d9\u05d4 \u05e2\u05d3 \u05db\u05d4 \u05de\u05ea\u05d7\u05d9\u05dc\u05ea \u05d4\u05e7\u05d9\u05e5. \u05d4\u05d9\u05d5\u05dd \u05ea\u05d5\u05e8\u05d2\u05e9 \u05e2\u05dc\u05d9\u05d9\u05d4 \u05e0\u05d5\u05e1\u05e4\u05ea...", "\ud83d\uddbc \u05e8\u05d1\u05d9 \u05d0\u05dc\u05d9\u05de\u05dc\u05da \u05d1\u05d9\u05d3\u05e8\u05de\u05df \u05dc\u05e4\u05e0\u05d5\u05ea \u05d1\u05d5\u05e7\u05e8 \u05d1\u05e6\u05d9\u05d5\u05df \u05d4\u05d0\u05e8\"\u05d9 \u05d1\u05e6\u05e4\u05ea. (\u05d5\u05d9\u05e1\u05d1\u05e8\u05d2).", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05de\u05e9\u05d4 \u05d5\u05d9\u05e1\u05d1\u05e8\u05d2", "\u21a9\ufe0f\ud83d\uddbc \u05d4\u05d4\u05e1\u05dc\u05de\u05d4 \u05e2\u05dd \u05d0\u05d9\u05e8\u05d0\u05df \u05de\u05de\u05e9\u05d9\u05db\u05d4: \u05e6\u05d1\u05d0 \u05d0\u05e8\u05e6\u05d5\u05ea \u05d4\u05d1\u05e8\u05d9\u05ea \u05d4\u05d5\u05d3\u05d9\u05e2 \u05e2\u05dc \u05d2\u05dc \u05ea\u05e7\u05d9\u05e4\u05d5\u05ea \u05e0\u05d5\u05e1\u05e3 \u05d1\u05d0\u05d9\u05e8\u05d0\u05df.", "\u05d1\u05d9\u05ea \u05e9\u05de\u05e9 \u05d7\u05d3\u05e9\u05d5\u05ea", "\u05de\u05d1\u05d6\u05e7\u05df 12", "*\u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05e1\u05e7\u05d5\u05e4\u05d9\u05dd*", "\ud83d\uddbc \u05d7\u05d7\u05d7\u05d7\u05d7\u05d7\u05d7\u05d7 \u05d7\u05d3\u05de\"\u05e9 \ud83d\ude02", "\ud83d\uddbc *\u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05e1\u05e7\u05d5\u05e4\u05d9\u05dd*", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d7\u05d3\u05e9\u05d5\u05ea \u05d1\u05d7\u05d3\u05e8\u05d9 \u05d7\u05e8\u05d3\u05d9\u05dd", "\ud83d\uddbc *\u05d0\u05d9\u05e8\u05d0\u05df \u05d9\u05d5\u05e8\u05d4 \u05e2\u05dc \u05db\u05d5\u05dc\u05dd \u05d7\u05d5\u05e5 \u05de\u05d9\u05e9\u05e8\u05d0\u05dc.*", "\ud83d\uddbc *\u05de\u05de\u05e9\u05e4\u05d7\u05d5\u05ea \u05d0\u05d9\u05e8\u05d0\u05df, \u05d7\u05de\u05d0\u05e1 \u05d5\u05d7\u05d9\u05d6\u05d1\u05d0\u05dc\u05dc\u05d4*", "\ud83d\uddbc \u05de\u05d1\u05d6\u05e7\u05df 12", "\ud83c\udfac \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05de\u05e9\u05d4 \u05d5\u05d9\u05e1\u05d1\u05e8\u05d2", "\u05dc\u05e7\u05e8\u05d0\u05ea \u05e6\u05e2\u05d3\u05ea \u05e2\u05e0\u05e7 \u05dc\u05e2\u05d6\u05d4 \u05d1\u05d4 \u05e6\u05e4\u05d5\u05d9\u05d9\u05dd \u05dc\u05d4\u05e9\u05ea\u05ea\u05e3 \u05e9\u05d5\u05e8\u05d4 \u05e9\u05dc \u05e9\u05e8\u05d9\u05dd \u05d5\u05d7\u05d1\u05e8\u05d9 \u05db\u05e0\u05e1\u05ea \u05d1\u05db\u05d9\u05e8\u05d9\u05dd, \u05e6\u05d4\"\u05dc \u05d4\u05d8\u05d9\u05dc \u05de\u05d2\u05d1\u05dc...", "\ud83d\uddbc \ud83d\udd25\ud83d\udd25\ud83d\udd25", "\u05d8\u05e8\u05d0\u05de\u05e4 \u05d1\u05ea\u05d2\u05d5\u05d1\u05d4 \u05dc\u05d4\u05db\u05e8\u05d6\u05ea \u05d0\u05d9\u05e8\u05d0\u05df \u05e9\u05d0\u05d9\u05e0\u05d4 \u05de\u05d7\u05d5\u05d9\u05d1\u05ea \u05e2\u05d5\u05d3 \u05dc\u05d4\u05e1\u05db\u05dd \u05de\u05d6\u05db\u05e8 \u05d4\u05d4\u05d1\u05e0\u05d5\u05ea: \"\u05de\u05de\u05e9 \u05dc\u05d0 \u05d0\u05db\u05e4\u05ea \u05dc\u05d9\".", "\u05e0\u05d9\u05d5 \u05d9\u05d5\u05e8\u05e7 \u05d8\u05d9\u05d9\u05de\u05e1: \u05e2\u05e9\u05e8\u05d5\u05ea \u05d7\u05d9\u05d9\u05dc\u05d9\u05dd \u05d0\u05de\u05e8\u05d9\u05e7\u05e0\u05d9\u05dd \u05e0\u05e4\u05d2\u05e2\u05d5 \u05d1\u05dc\u05e4\u05d7\u05d5\u05ea 4 \u05ea\u05e7\u05d9\u05e4\u05d5\u05ea \u05d0\u05d9\u05e8\u05d0\u05e0\u05d9\u05d5\u05ea \u05d1\u05d9\u05e8\u05d3\u05df \u05d1\u05e9\u05d1\u05d5\u05e2 \u05d4...", "\ud83c\udfac \u05ea\u05d2 \u05de\u05d7\u05d9\u05e8 \u05dc\u05d9\u05d3 \u05d7\u05d1\u05e8\u05d5\u05df", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05de\u05e8\u05d3\u05db\u05d9 \u05d4\u05dc\u05e4\u05e8\u05d9\u05df", "\u05d3\u05e4\u05e0\u05d4 \u05dc\u05d9\u05d0\u05dc", "\u05dc\u05de\u05e8\u05d5\u05ea \u05d4\u05d0\u05d9\u05d5\u05dd: \u05d1\u05e2\u05d9\u05e8\u05d9\u05d9\u05ea \u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7 \u05d4\u05d7\u05dc\u05d9\u05d8\u05d5 \u05db\u05e8\u05d2\u05e2 \u05e9\u05dc\u05d0 \u05dc\u05d4\u05d2\u05d9\u05d1 \u05dc\u05d3\u05e8\u05d9\u05e9\u05ea \u05de\u05e0\u05d4\u05dc \u05e8\u05e9\u05d5\u05ea \u05d4\u05de\u05d9\u05e1\u05d9\u05dd \u05dc\u05d2\u05e0\u05d5\u05ea \u05d0...", "\u05d1\u05d2\"\u05e5 \u05d4\u05d5\u05e6\u05d9\u05d0 \u05e6\u05d5 \u05d0\u05e8\u05e2\u05d9 \u05e0\u05d2\u05d3 \u05d7\u05d5\u05e7 \u05d4\u05ea\u05e7\u05e9\u05d5\u05e8\u05ea \u05e9\u05dc \u05e7\u05e8\u05e2\u05d9 \u05d4\u05de\u05e2\u05db\u05d1 \u05d0\u05ea \u05db\u05e0\u05d9\u05e1\u05ea\u05df \u05dc\u05ea\u05d5\u05e7\u05e3 \u05e9\u05dc \u05d4\u05d5\u05e8\u05d0\u05d5\u05ea \u05d7\u05d5\u05e7 \u05d4\u05e9\u05d9\u05d3...", "\u05e2\u05d5\u05d3 \u05d7\u05d5\u05e7 \u05e9\u05e0\u05d1\u05dc\u05dd \u05d1\u05d1\u05d2\u05f4\u05e6: \u05d1\u05d2\u05f4\u05e5 \u05d4\u05d5\u05e6\u05d9\u05d0 \u05e6\u05d5 \u05d0\u05e8\u05e2\u05d9 \u05e0\u05d2\u05d3 \u05d7\u05d5\u05e7 \u05d4\u05ea\u05e7\u05e9\u05d5\u05e8\u05ea \u05e9\u05dc \u05e7\u05e8\u05e2\u05d9 \u05d4\u05de\u05e2\u05db\u05d1 \u05d0\u05ea \u05db\u05e0\u05d9\u05e1\u05ea\u05df \u05dc\u05ea\u05d5...", "\u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05e1\u05d9\u05db\u05d5\u05dd \u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05dc\u05d9\u05dc\u05d4:", "\ud83d\uddbc \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d4\u05e0\u05e2\u05d3\u05e8 \u05d0\u05dc\u05d9\u05d4\u05d5 \u05d9\u05e9\u05e8\u05d0\u05dc \u05d0\u05d1\u05d0 \u05e9\u05d0\u05d5\u05dc, \u05d1\u05df \u05d4-60 \u05de\u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7, \u05d0\u05d5\u05ea\u05e8 \u05dc\u05dc\u05d0 \u05e8\u05d5\u05d7 \u05d7\u05d9\u05d9\u05dd \u05d1\u05e8\u05de\u05ea \u05d2\u05df", "\ud83c\udfac \u05d3\u05d9\u05d5\u05d5\u05d7 \u05e4\u05dc\u05e1\u05d8\u05d9\u05e0\u05d9: \u05e6\u05e2\u05d9\u05e8\u05d9\u05dd \u05d9\u05d4\u05d5\u05d3\u05d9\u05dd \u05d4\u05e6\u05d9\u05ea\u05d5 \u05d4\u05dc\u05d9\u05dc\u05d4 \u05de\u05e1\u05d2\u05d3, \u05d1\u05ea\u05d9\u05dd \u05d5\u05e8\u05db\u05d1 \u05d1\u05db\u05e4\u05e8 \u05ea\u05d5\u05d0\u05e0\u05d4 \u05e9\u05d1\u05d3\u05e8\u05d5\u05dd \u05d4\u05e8 \u05d7\u05d1...", "\ud83c\udfac \u05d1\u05e0\u05d9\u05d9\u05df \u05e9\u05d4\u05d5\u05ea\u05e7\u05e3 \u05d1\u05d1\u05d9\u05d9\u05e8\u05d5\u05ea \u05d1\u05e2\u05d1\u05e8 \u05e0\u05e4\u05dc \u05d4\u05dc\u05d9\u05dc\u05d4", "\u05d3\u05d9\u05df \u05e4\u05d9\u05e9\u05e8", "\ud83d\uddbc \u05d3\u05e4\u05e0\u05d4 \u05dc\u05d9\u05d0\u05dc", "\ud83d\uddbc \u05d8\u05e8\u05d2\u05d3\u05d9\u05d4: \u05dc\u05d0\u05d7\u05e8 \u05d7\u05d9\u05e4\u05d5\u05e9\u05d9\u05dd \u05d4\u05e0\u05e2\u05d3\u05e8 \u05d4\u05e8\u05d1 \u05d0\u05dc\u05d9\u05d4\u05d5 \u05d9\u05e9\u05e8\u05d0\u05dc \u05d0\u05d1\u05d0 \u05e9\u05d0\u05d5\u05dc \u05d1\u05df 59 \u05de\u05e8\u05d7\u05d5\u05d1 \u05d1\u05df \u05d6\u05db\u05d0\u05d9 \u05d1\u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7 \u05d0...", "\u05d1\u05e9\u05dc \u05e9\u05e8\u05d9\u05e4\u05d4 \u05dc\u05d9\u05d3 \u05d4\u05de\u05e1\u05d9\u05dc\u05d4: \u05d4\u05d5\u05e4\u05e1\u05e7\u05d4 \u05d6\u05de\u05e0\u05d9\u05ea \u05ea\u05e0\u05d5\u05e2\u05ea \u05d4\u05e8\u05db\u05d1\u05d5\u05ea \u05d1\u05d9\u05df \u05ea\u05d7\u05e0\u05d5\u05ea \u05dc\u05d5\u05d3, \u05e8\u05d7\u05d5\u05d1\u05d5\u05ea \u05d5\u05d0\u05e9\u05e7\u05dc\u05d5\u05df \u05d5\u05d1\u05d9\u05df ...", "\ud83d\uddbc \u05d9\u05e9\u05d9 \u05db\u05d4\u05df \u05de\u05e6\u05d8\u05d8 \u05d0\u05ea \u05d9\u05e9\u05d9 \u05db\u05d4\u05df", "\ud83d\uddbc \u05f4\u05d8\u05e2\u05e0\u05d5\u05ea \u05db\u05d1\u05d3\u05d5\u05ea \u05de\u05e9\u05e7\u05dc\u05f4 \u2022 \u05d1\u05d2\u05f4\u05e5 \u05d1\u05e6\u05d5 \u05d4\u05de\u05e7\u05e4\u05d9\u05d0 \u05d0\u05ea \u05db\u05e0\u05d9\u05e1\u05ea \u05d7\u05d5\u05e7 \u05d4\u05ea\u05e7\u05e9\u05d5\u05e8\u05ea \u05e9\u05dc \u05e7\u05e8\u05e2\u05d9 \u05dc\u05ea\u05d5\u05e7\u05e3", "\u05d9\u05e2\u05e0\u05e7\u05d9 \u05e4\u05e8\u05d1\u05e8: \u05d2\u05d1\u05e8 \u05e2\u05dd \"\u05e4\u05d8\u05d9\u05e9 \u05d7\u05d9\u05e8\u05d5\u05dd\" \u05e9\u05d0\u05d9\u05d9\u05dd \u05e2\u05dc \u05d7\u05e8\u05d3\u05d9\u05dd \u05d1\u05d0\u05e0\u05d8\u05d5\u05d5\u05e8\u05e4\u05df, \u05e0\u05e2\u05e6\u05e8 \u05dc\u05d0\u05d7\u05e8 \u05e9\u05d7\u05d9\u05d9\u05dc\u05d9\u05dd \u05e9\u05d4\u05d5\u05e6\u05d1\u05d5 \u05dc...", "\u05d1\u05e9\u05dc \u05e9\u05e8\u05d9\u05e4\u05d4 \u05d1\u05e7\u05e8\u05d1\u05ea \u05d4\u05de\u05e1\u05d9\u05dc\u05d4 \u05d1\u05d0\u05d6\u05d5\u05e8 \u05d1\u05d0\u05e8 \u05d9\u05e2\u05e7\u05d1, \u05d4\u05d5\u05e4\u05e1\u05e7\u05d4 \u05d6\u05de\u05e0\u05d9\u05ea \u05ea\u05e0\u05d5\u05e2\u05ea \u05d4\u05e8\u05db\u05d1\u05d5\u05ea \u05d1\u05d9\u05df \u05ea\u05d7\u05e0\u05d5\u05ea \u05dc\u05d5\u05d3, \u05e8\u05d7\u05d5...", "\u05e4\u05e8\u05d1\u05e8 \u05d1'\u05d1\u05d7\u05d3\u05e8\u05d9': \u05d2\u05d1\u05e8 \u05e2\u05dd \"\u05e4\u05d8\u05d9\u05e9 \u05d7\u05d9\u05e8\u05d5\u05dd\" \u05e9\u05d0\u05d9\u05d9\u05dd \u05e2\u05dc \u05d7\u05e8\u05d3\u05d9\u05dd \u05d1\u05d0\u05e0\u05d8\u05d5\u05d5\u05e8\u05e4\u05df, \u05e0\u05e2\u05e6\u05e8 \u05dc\u05d0\u05d7\u05e8 \u05e9\u05d7\u05d9\u05d9\u05dc\u05d9\u05dd \u05e9\u05d4\u05d5\u05e6\u05d1...", "\ud83c\udfac \u05d4\u05e4\u05e2\u05dc\u05ea \u05de\u05e2\u05e8\u05db\u05ea \"\u05e4\u05d8\u05e8\u05d9\u05d5\u05d8\" \u05d5\"\u05e1\u05d9\u05e8\u05dd\" \u05dc\u05d9\u05d9\u05e8\u05d5\u05d8 \u05db\u05dc\u05d9 \u05d8\u05d9\u05e1 \u05d1\u05dc\u05ea\u05d9 \u05de\u05d0\u05d5\u05d9\u05e9\u05d9\u05dd \u05d1\u05d0\u05e8\u05d1\u05d9\u05dc.", "\ud83c\udfac\ud83d\uddbc \u05ea\u05e7\u05d9\u05e4\u05d5\u05ea \u05d0\u05de\u05e8\u05d9\u05e7\u05d0\u05d9\u05d5\u05ea \u05d1\u05d4\u05d9\u05e7\u05e3 \u05de\u05e6\u05d5\u05de\u05e6\u05dd \u05d4\u05dc\u05d9\u05dc\u05d4 \u05d1\u05d0\u05d9\u05e8\u05d0\u05df", "\ud83d\uddbc \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d1\u05de\u05d4\u05dc\u05da \u05d4\u05dc\u05d9\u05dc\u05d4 \u05e0\u05e4\u05e8\u05e5 \u05d1\u05e0\u05d9\u05d9\u05df \u05e2\u05d9\u05e8\u05d9\u05d9\u05ea \u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7. \u05dc\u05e4\u05d9 \u05d4\u05de\u05d9\u05d3\u05e2 \u05d4\u05e8\u05d0\u05e9\u05d5\u05e0\u05d9, \u05d4\u05e4\u05d5\u05e8\u05e6\u05d9\u05dd \u05d7\u05d3\u05e8\u05d5 \u05dc...", "\ud83d\uddbc \u05d3\u05e8\u05de\u05d4 \u05d1\u05e2\u05d9\u05e8\u05d9\u05d9\u05ea \u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7: \u05d1\u05de\u05d4\u05dc\u05da \u05d4\u05dc\u05d9\u05dc\u05d4 \u05d0\u05d9\u05e8\u05e2\u05d4 \u05e4\u05e8\u05d9\u05e6\u05d4 \u05dc\u05d1\u05e0\u05d9\u05d9\u05df \u05d4\u05e2\u05d9\u05e8\u05d9\u05d9\u05d4. \u05e2\u05dc \u05e4\u05d9 \u05d4\u05de\u05d9\u05d3\u05e2 \u05d4\u05e8\u05d0\u05e9\u05d5\u05e0...", "\ud83c\udfac \u05e9\u05e0\u05d2\u05d7\u05d0\u05d9 \u05de\u05d0\u05e8\u05d7\u05ea \u05ea\u05e2\u05e8\u05d5\u05db\u05d4 \u05e2\u05d5\u05dc\u05de\u05d9\u05ea \u05e9\u05dc \u05e8\u05d5\u05d1\u05d5\u05d8\u05d9\u05dd \u05d5\u05d7\u05d9\u05d3\u05d5\u05e9\u05d9\u05dd \u05d1\u05ea\u05d7\u05d5\u05dd \u05d4\u05d1\u05d9\u05e0\u05d4 \u05d4\u05de\u05dc\u05d0\u05db\u05d5\u05ea\u05d9\u05ea.", "\ud83c\udfac \u05de\u05e0\u05d2\u05d3, \u05d2\u05dd \u05d0\u05d9\u05e8\u05d0\u05df \u05e6\u05de\u05e6\u05de\u05d4 \u05d4\u05dc\u05d9\u05dc\u05d4 \u05d0\u05ea \u05d4\u05d9\u05e7\u05e3 \u05ea\u05e7\u05d9\u05e4\u05d5\u05ea\u05d9\u05d4 - \u05d4\u05df \u05d4\u05ea\u05e8\u05db\u05d6\u05d5 \u05d1\u05e2\u05d9\u05e7\u05e8 \u05d1\u05d0\u05d6\u05d5\u05e8 \u05d0\u05e8\u05d1\u05d9\u05dc \u05d1\u05d7\u05d1\u05dc \u05db\u05d5...", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05e4\u05e7\u05e7 \u05db\u05d1\u05d3 \u05d1\u05e9\u05e2\u05d4 04:00 \u05dc\u05e4\u05e0\u05d5\"\u05d1 \u05d1\u05d3\u05e8\u05da \u05dc\u05d0\u05e8\"\u05d9 \u05d1\u05e6\u05e4\u05ea. \u05d1\u05d2\u05dc\u05dc \u05de\u05d7\u05e1\u05d5\u05dd \u05de\u05e9\u05d8\u05e8\u05ea\u05d9", "\ud83d\uddbc \u05d0\u05e8\u05d4\"\u05d1 \u05d4\u05e9\u05dc\u05d9\u05de\u05d4 \u05e1\u05d1\u05d1 \u05ea\u05e7\u05d9\u05e4\u05d5\u05ea \u05dc\u05d9\u05dc\u05d9 \u05d1\u05d0\u05d9\u05e8\u05d0\u05df, \u05e4\u05d9\u05e6\u05d5\u05e6\u05d9\u05dd \u05e0\u05e9\u05de\u05e2\u05d5 \u05d1\u05d1\u05e0\u05d3\u05e8 \u05e2\u05d1\u05d0\u05e1 \u05d5\u05d1\u05d0\u05d9 \u05e7\u05e9\u05dd \u05e1\u05de\u05d5\u05da \u05dc\u05de\u05e6\u05e8...", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d9\u05d5\u05e1\u05d9 \u05d0\u05dc\u05d9\u05d8\u05d5\u05d1 Yossi Elituv", "\ud83d\uddbc \u05de\u05e9\u05e8\u05d3 \u05d4\u05d7\u05d5\u05e5 \u05d4\u05d0\u05de\u05e8\u05d9\u05e7\u05d0\u05d9 \u05de\u05e4\u05e8\u05e1\u05dd \u05d4\u05dc\u05d9\u05dc\u05d4 \u05dc\u05d0\u05d6\u05e8\u05d7\u05d9 \u05d0\u05e8\u05d4\"\u05d1 \u05d0\u05d6\u05d4\u05e8\u05ea \u05de\u05e1\u05e2 \u05db\u05dc\u05dc-\u05e2\u05d5\u05dc\u05de\u05d9\u05ea:", "\u05d0\u05d5\u05e8 \u05e8\u05d1\u05d9\u05d3", "\ud83c\udfac \u05e2\u05de\u05d5\u05d3\u05d9 \u05d4\u05e9\u05e2\u05e8 \u05d1\u05e2\u05d9\u05ea\u05d5\u05e0\u05d9 \u05d4\u05d1\u05d5\u05e7\u05e8 \u2022 \u05d9\u05d5\u05dd \u05e8\u05d0\u05e9\u05d5\u05df / \u05d4' \u05d0\u05d1 / 19.07.2026", "\u05d3\u05d5\u05e8\u05d5\u05df \u05e7\u05d3\u05d5\u05e9 \u05d1\u05d2\u05dc\"\u05e6: \u05d1\u05d2\u05dc\u05dc \u05de\u05d7\u05e1\u05d5\u05e8 \u05d1\u05ea\u05e7\u05e6\u05d9\u05d1 11 \u05de\u05d5\u05e6\u05d1\u05d9\u05dd \u05d1\u05d2\u05d1\u05d5\u05dc \u05dc\u05d1\u05e0\u05d5\u05df \u05dc\u05d0 \u05de\u05de\u05d5\u05d2\u05e0\u05d9\u05dd \u05db\u05e8\u05d0\u05d5\u05d9 \u05de\u05e8\u05d7\u05e4\u05e0\u05d9 \u05e0\u05e4...", "\ud83c\udfac \u05d4\u05d0\u05d9\u05e8\u05d0\u05e0\u05d9\u05dd \u05de\u05ea\u05db\u05d5\u05e0\u05e0\u05d9\u05dd \u05d1\u05e8\u05e6\u05d9\u05e0\u05d5\u05ea \u05dc\u05de\u05dc\u05d7\u05de\u05d4 \u05d0\u05e8\u05d5\u05db\u05d4 \u05d5\u05e7\u05e9\u05d4.", "\u21a9\ufe0f\ud83c\udfac\ud83d\uddbc \u05ea\u05d9\u05e2\u05d5\u05d3 \u05e4\u05d2\u05d9\u05e2\u05ea \u05d4\u05d8\u05d9\u05dc\u05d9\u05dd \u05d1\u05d1\u05e1\u05d9\u05e1 \u05d4\u05d0\u05d5\u05d5\u05d9\u05e8\u05d9 \u05de\u05d5\u05d5\u05e4\u05e7 \u05e1\u05dc\u05d8\u05d9 \u05d1\u05d9\u05e8\u05d3\u05df \u05d1 - 17 \u05dc\u05d9\u05d5\u05dc\u05d9 \u05d4\u05e4\u05d2\u05d9\u05e2\u05d4 \u05e9\u05d2\u05e8\u05de\u05d4 \u05dc...", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05ea\u05d0\u05d5\u05e0\u05d4 \u05dc\u05d9\u05dc\u05d9\u05ea \u05d1\u05d0\u05dc\u05e2\u05d3 \u05dc\u05dc\u05d0 \u05e0\u05e4\u05d2\u05e2\u05d9\u05dd", "\u05d1\u05d5\u05e7\u05e8 \u05d8\u05d5\u05d1\u2764\ufe0f", "\u05d4\u05ea\u05d7\u05d6\u05d9\u05ea \u05dc\u05d4\u05d9\u05d5\u05dd \u05d9\u05d5\u05dd \u05e8\u05d0\u05e9\u05d5\u05df: \u05d4\u05d9\u05d5\u05dd \u05ea\u05d7\u05d5\u05dc \u05e2\u05dc\u05d9\u05d4 \u05e7\u05dc\u05d4 \u05d1\u05d8\u05de\u05e4\u05e8\u05d8\u05d5\u05e8\u05d5\u05ea, \u05d5\u05ea\u05d5\u05e8\u05d2\u05e9 \u05d4\u05db\u05d1\u05d3\u05d4 \u05d1\u05e2\u05d5\u05de\u05e1\u05d9 \u05d4\u05d7\u05d5\u05dd, \u05d9\u05e2...", "\u05e9\u05d2\u05e8\u05d9\u05e8 \u05d0\u05e8\u05e6\u05d5\u05ea \u05d4\u05d1\u05e8\u05d9\u05ea \u05d1\u05d0\u05d5\"\u05dd \u05de\u05d9\u05d9\u05e7 \u05d5\u05d5\u05dc\u05e5 \u05d4\u05d2\u05d9\u05d1 \u05dc\u05d4\u05e6\u05d4\u05e8\u05ea \u05e8\u05d0\u05e9 \u05d4\u05e2\u05d9\u05e8 \u05e0\u05d9\u05d5 \u05d9\u05d5\u05e8\u05e7 \u05d6\u05d5\u05d4\u05e8\u05d0\u05df \u05de\u05de\u05d3\u05d0\u05e0\u05d9, \u05d5\u05db\u05ea\u05d1...", "\u05e1\u05d5\u05e3 \u05e2\u05e6\u05d5\u05d1 \u05dc\u05d7\u05d9\u05e4\u05d5\u05e9\u05d9\u05dd: \u05ea\u05d5\u05e9\u05d1 \u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7 \u05d0\u05d5\u05ea\u05e8 \u05dc\u05dc\u05d0 \u05e8\u05d5\u05d7 \u05d7\u05d9\u05d9\u05dd \u05d1\u05e4\u05d0\u05e8\u05e7 \u05e6\u05d9\u05d1\u05d5\u05e8\u05d9 \u05d1\u05e8\u05de\u05ea \u05d2\u05df", "\u05e8\u05d9\u05de\u05d5\u05df \u05d4\u05dc\u05dd \u05d4\u05d5\u05e9\u05dc\u05da \u05d4\u05dc\u05d9\u05dc\u05d4 \u05d1\u05e1\u05de\u05d5\u05da \u05dc\u05d1\u05d9\u05ea \u05e4\u05e8\u05d8\u05d9 \u05d1\u05e9\u05db\u05d5\u05e0\u05ea \u05e6\u05d4\u05dc\u05d4 \u05d1\u05e6\u05e4\u05d5\u05df \u05ea\u05dc \u05d0\u05d1\u05d9\u05d1. \u05d1\u05e9\u05db\u05d5\u05e0\u05d4 \u05d2\u05e8\u05d9\u05dd \u05d4\u05e8\u05d1 \u05d7\u05d9...", "\ud83d\uddbc \u05d0\u05e1\u05d5\u05df: \u05e8\u05f3 \u05d0\u05dc\u05d9\u05d4\u05d5 \u05d9\u05e9\u05e8\u05d0\u05dc \u05d0\u05d1\u05d0 \u05e9\u05d0\u05d5\u05dc \u05d6\"\u05dc, \u05ea\u05d5\u05e9\u05d1 \u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7 \u05d1\u05df 59, \u05d4\u05ea\u05de\u05d5\u05d8\u05d8 \u05d5\u05e0\u05e4\u05d8\u05e8 \u05de\u05d3\u05d5\u05dd \u05dc\u05d1. \u05d1\u05de\u05d4\u05dc\u05da \u05d4...", "\ud83d\uddbc \u05d4\u05d1\u05d7\u05d9\u05e8\u05d5\u05ea \u05d4\u05d7\u05d5\u05d6\u05e8\u05d5\u05ea \u05dc\u05d4\u05e0\u05d4\u05d2\u05ea \u05d4\u05dc\u05e9\u05db\u05d4 \u05d4\u05de\u05d3\u05d9\u05e0\u05d9\u05ea \u05e9\u05dc \u05d7\u05de\u05d0\u05e1: \u05d0\u05dc\u05d7\u05d9\u05d4 Vs \u05de\u05e9\u05e2\u05dc", "\u05d9\u05d5\u05dc\u05df \u05db\u05d4\u05df"]}