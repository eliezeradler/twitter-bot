5d9\u05d0 \u05de...", "\u05d4\u05de\u05d6\u05e8\u05d7\u05df \u05d3\"\u05e8 \u05d0\u05d3\u05d9 \u05db\u05d4\u05df \u05d1\u05d7\u05e6\u05d5\u05ea \u05d1\u05d6\u05d9\u05e8\u05ea \u05d4\u05d7\u05d3\u05e9\u05d5\u05ea: \u05d0\u05d9\u05df \u05de\u05ea\u05d5\u05e0\u05d9\u05dd \u05d5\u05e7\u05d9\u05e6\u05d5\u05e0\u05d9\u05dd \u05d1\u05d0\u05d9\u05e8\u05d0\u05df, \u05db\u05d5\u05dc\u05dd \u05d2\u05e0\u05e8\u05dc\u05d9\u05dd \u05e9\u05de\u05e9\u05d7...", "\u05d1\u05df \u05d2\u05d5\u05dc\u05d3\u05e4\u05e8\u05d9\u05d9\u05e0\u05d3", "\ud83d\uddbc *\ud83c\udf99\ufe0f \u05d5\u05d5\u05d0\u05d8\u05e1\u05d0\u05e4 \u05de\u05e9\u05d3\u05e8\u05d2\u05ea \u05d0\u05ea \u05d4\u05d4\u05d5\u05d3\u05e2\u05d5\u05ea \u05d4\u05e7\u05d5\u05dc\u05d9\u05d5\u05ea*", "\u05d4\u05ea\u05d7\u05d6\u05d9\u05ea \u05dc\u05de\u05d7\u05e8 - \u05d9\u05d5\u05dd \u05e9\u05e0\u05d9: \u05d1\u05d4\u05d9\u05e8, \u05d7\u05dd \u05de\u05d4\u05e8\u05d2\u05d9\u05dc \u05d5\u05d9\u05d1\u05e9 \u05d1\u05d4\u05e8\u05d9\u05dd \u05d5\u05d1\u05e4\u05e0\u05d9\u05dd \u05d4\u05d0\u05e8\u05e5, \u05d4\u05d1\u05d9\u05dc \u05d1\u05de\u05d9\u05e9\u05d5\u05e8 \u200f\u05d4\u05d7\u05d5\u05e3.\u200f", "\ud83c\udfac \u05d4\u05e2\u05e8\u05d9\u05e0\u05d2: \u05e1\u05d3\u05e8 \u05e9\u05dc\u05d9\u05e9\u05d9 \u05e2\u05d1\u05e8 \u05dc\u05e4\u05d0\u05e8\u05e7 \u05d4\u05dc\u05d0\u05d5\u05de\u05d9 \u2022 \u05e6\u05d9\u05dc\u05d5\u05dd: \u05d0\u05dc\u05e2\u05d6\u05e8 \u05e9\u05dc\u05d5\u05dd", "\ud83d\uddbc \u05de\u05d5\u05d9\u05e9\u05d9 \u05db\u05de\u05e2\u05d8 \u05d1\u05df 3", "\ud83d\uddbc \u05d4\u05ea\u05d5\u05e9\u05d1\u05d9\u05dd \u05e4\u05d5\u05e0\u05d5 \u05de\u05d4\u05d1\u05e0\u05d9\u05d9\u05df: \u05e6\u05d5\u05d5\u05ea\u05d9 \u05db\u05d9\u05d1\u05d5\u05d9 \u05d4\u05d5\u05d6\u05e2\u05e7\u05d5 \u05d4\u05d1\u05d5\u05e7\u05e8 \u05dc\u05e8\u05d7\u05d5\u05d1 \u05d1\u05e8 \u05d0\u05d9\u05dc\u05df \u05d1\u05e2\u05d9\u05e8, \u05d1\u05e2\u05e7\u05d1\u05d5\u05ea \u05d7\u05e9\u05e9 \u05dc\u05de...", "\ud83d\uddbc \u05d7\u05de\u05d9\u05e9\u05d4 \u05d9\u05ea\u05d5\u05de\u05d9\u05dd \u05e9\u05d1\u05d5\u05e8\u05d9\u05dd, \u05de\u05d0\u05d5\u05ea \u05d0\u05dc\u05e4\u05d9 \u05e9\u05e7\u05dc\u05d9\u05dd \u05d7\u05d5\u05d1 \u05dc\u05ea\u05e8\u05d5\u05e4\u05d5\u05ea \u05e9\u05dc\u05d0 \u05d1\u05e1\u05dc \u05d4\u05d1\u05e8\u05d9\u05d0\u05d5\u05ea - \u05d5\u05de\u05e7\u05e8\u05e8 \u05e8\u05d9\u05e7 \u05de\u05d0\u05d5...", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d0\u05d1\u05e8\u05d4\u05dd \u05d2\u05e8\u05d9\u05e0\u05e6\u05d9\u05d9\u05d2", "\u05d3\u05e7\u05d4 95': \u05e1\u05e4\u05e8\u05d3 \u05db\u05d5\u05d1\u05e9\u05ea, \u05d0\u05da \u05d4\u05e9\u05e2\u05e8 \u05e0\u05e4\u05e1\u05dc \u05d1\u05d2\u05dc\u05dc \u05e2\u05d1\u05d9\u05e8\u05d4 \u05e1\u05e4\u05e8\u05d3\u05d9\u05ea \u05d1\u05e8\u05d7\u05d1\u05d4 \u05d4\u05d0\u05e8\u05d2\u05e0\u05d8\u05d9\u05e0\u05d0\u05d9\u05ea", "*\u05d8\u05d5\u05e2\u05e0\u05d9\u05dd \u05e9\u05d4\u05e9\u05d5\u05e2\u05e8 \u05d4\u05e1\u05e4\u05e8\u05d3\u05d9 \u05e8\u05d5\u05d0\u05d4 \u05d0\u05ea \u05d4\u05de\u05d5\u05e0\u05d3\u05d9\u05d0\u05dc \u05de\u05d4\u05e4\u05dc\u05e4\u05d5\u05df*", "\ud83d\uddbc \u05de\u05ea\u05d9???", "\ud83c\udfac \u05d4\u05d0\u05d9\u05e8\u05d0\u05e0\u05d9\u05dd \u05d8\u05d5\u05e2\u05e0\u05d9\u05dd \u05e9\u05d4\u05e4\u05d9\u05dc\u05d5 \u05db\u05d8\u05d1\"\u05dd \u05e9\u05dc \u05d0\u05e8\u05e6\u05d5\u05ea \u05d4\u05d1\u05e8\u05d9\u05ea \u05d1\u05d3\u05e8\u05d5\u05dd \u05d4\u05de\u05d3\u05d9\u05e0\u05d4.", "\ud83d\uddbc \u200b\"\u05d0\u05e0\u05d9 \u05db\u05d5\u05ea\u05d1\u05ea \u05d0\u05ea \u05d4\u05de\u05d9\u05dc\u05d9\u05dd \u05d4\u05d0\u05dc\u05d4 \u05d1\u05d3\u05de\u05e2\u05d5\u05ea \u05e9\u05dc \u05d1\u05d5\u05e9\u05d4. \u05d1\u05d1\u05e7\u05e9\u05d4, \u05d0\u05dc \u05ea\u05d3\u05dc\u05d2\u05d5\ud83d\udc94\"", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d9\u05e9\u05d9 \u05db\u05d4\u05df", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d0\u05e8\u05d9\u05d4 \u05d0\u05e8\u05dc\u05d9\u05da A. Erlich", "\u05e8\u05d2\u05e2 \u05d0\u05d7\u05e8\u05d5\u05df \u05d4\u05de\u05d5\u05df \u05d4\u05de\u05d5\u05df \u05ea\u05e4\u05d9\u05dc\u05d5\u05ea", "\ud83c\udfac \u05d7\u05e8\u05d3\u05d9 \u05d1\u05de\u05e9\u05d7\u05e7 \u05d1\u05e0\u05d9\u05d5 \u05d2\u05e8\u05d6\u05d9", "*\u05dc\u05de\u05e8\u05d5\u05ea \u05e9\u05dc\u05d9\u05d8\u05d4 \u05de\u05d5\u05d7\u05dc\u05d8\u05ea \u05e9\u05dc \u05e1\u05e4\u05e8\u05d3 \u05d1\u05db\u05d3\u05d5\u05e8 \u05d5\u05d1\u05de\u05e9\u05d7\u05e7*", "\ud83c\udfac \u05e9\u05d7\u05e7\u05df \u05d0\u05e8\u05d2\u05e0\u05d8\u05d9\u05e0\u05d0\u05d9 \u05de\u05e2\u05d9\u05e3 \u05e1\u05e4\u05e8\u05d3\u05d9 \u05d1\u05d0\u05d5\u05d5\u05d9\u05e8..", "\ud83c\udfac \u05d4\u05dc\u05da \u05d4\u05de\u05e9\u05d7\u05e7..", "\ud83c\udfac \u05dc\u05d0 \u05dc\u05e0\u05e1\u05d5\u05ea \u05dc\u05db\u05d1\u05d5\u05ea \u05d0\u05ea \u05d4\u05de\u05e9\u05d7\u05e7 \u05dc\u05d7\u05d1\u05e8 \ud83e\udd26\u200d\u2642\ufe0f\ud83d\ude05", "*\u05d1\u05d5\u05dd\u05dd*", "\ud83d\uddbc \u05d1\u05e0\u05ea\u05d9\u05d9\u05dd \u05d1\u05e8\u05e9\u05ea", "\u21a9\ufe0f\ud83c\udfac 1:0 \u05dc\u05e1\u05e4\u05e8\u05d3 \u05d1\u05d3\u05e7\u05d4 106: \u05e4\u05e8\u05d0\u05df \u05d8\u05d5\u05e8\u05e1 \u05d4\u05d1\u05e7\u05d9\u05e2 \u05d2\u05d5\u05dc \u05d1\u05d3\u05e7\u05d4 106, \u05db\u05e9\u05d0\u05e8\u05d2\u05e0\u05d8\u05d9\u05e0\u05d4 \u05de\u05e9\u05d7\u05e7\u05ea \u05e2\u05dd 10 \u05e9\u05d7\u05e7\u05e0\u05d9\u05dd \u05d1\u05dc\u05d1\u05d3 ...", "*\u05d1\u05e0\u05ea\u05d9\u05d9\u05dd \u05d1\u05e8\u05e9\u05ea \u05d3\u05d0\u05d7\u05e7\u05d5\u05ea..*", "\ud83c\udfac \u05dc\u05d0\u05d5\u05d4\u05d3\u05d9\u05dd \u05d4\u05de\u05e9\u05d5\u05d1\u05e2\u05d9\u05dd", "\ud83d\uddbc \ud83d\ude05\ud83d\ude05\ud83d\ude05\ud83d\ude05", "*\u05db\u05e8\u05d2\u05e2 \u05d1\u05e2\u05d5\u05dc\u05dd \u05d9\u05e9 21 \u05d0\u05e0\u05e9\u05d9\u05dd \u05e9\u05e8\u05e6\u05d9\u05dd \u05d5\u05db\u05dc \u05d4\u05e9\u05d0\u05e8 \u05e2\u05dc \u05d4\u05e1\u05e4\u05d4* \ud83d\ude02", "\ud83c\udfac \u05d0\u05dc\u05d9\u05d4 \u05d0\u05d1\u05d9\u05d1 | \u05e8\u05d0\u05e9\u05d5\u05e0\u05d9 - \u05d0\u05d9\u05e8\u05d5\u05e2 \u05de\u05e9\u05de\u05e2\u05d5\u05ea\u05d9 \u05d1\u05db\u05e4\u05e8 \u05d3\u05d9\u05e8 \u05d2\u05f3\u05e8\u05d9\u05e8 \u05e9\u05d1\u05d1\u05e0\u05d9\u05de\u05d9\u05df, \u05dc\u05e4\u05e0\u05d9 \u05db\u05e9\u05d1\u05d5\u05e2\u05d9\u05d9\u05dd \u05de\u05d7\u05d1\u05dc\u05d9\u05dd ...", "\ud83c\udfac \u05d1\u05df \u05d2\u05d1\u05d9\u05e8 \u05d5\u05d4\u05de\u05d5\u05e0\u05d3\u05d9\u05d0\u05dc..", "*\u05d3\u05e7\u05d4 106*", "\u21a9\ufe0f \u05d0\u05db\u05d6\u05d1\u05d4: \u05e1\u05e4\u05e8\u05d3 \u05d0\u05dc\u05d5\u05e4\u05ea \u05d4\u05e2\u05d5\u05dc\u05dd \u05d1\u05e4\u05e2\u05dd \u05d4\u05e9\u05e0\u05d9\u05d9\u05d4 \u05d1\u05ea\u05d5\u05dc\u05d3\u05d5\u05ea\u05d9\u05d4 \u05d0\u05d7\u05e8\u05d9 \u05e0\u05d9\u05e6\u05d7\u05d5\u05df \u05e2\u05dc \u05d0\u05e8\u05d2\u05e0\u05d8\u05d9\u05e0\u05d4 \u05d1\u05d2\u05de\u05e8", "*\u05e1\u05e4\u05e8\u05d3 \u05de\u05e0\u05e6\u05d7\u05ea \u05d1\u05de\u05e9\u05d7\u05e7 \u05d4\u05de\u05d5\u05e0\u05d3\u05d9\u05d0\u05dc \u05de\u05d5\u05dc \u05d0\u05e8\u05d2\u05e0\u05d8\u05d9\u05e0\u05d4 \u05d1\u05e4\u05e2\u05dd \u05d4\u05e9\u05e0\u05d9\u05d4 \u05d1\u05ea\u05d5\u05dc\u05d3\u05d5\u05ea\u05d9\u05d4*", "\ud83d\uddbc \u05e1\u05e4\u05e8\u05d3 \u05e0\u05d9\u05e6\u05d7\u05d4", "\ud83d\uddbc *\u05d9\u05db\u05d5\u05dc \u05dc\u05d4\u05d9\u05d5\u05ea \u05e9\u05de\u05d2\u05d9\u05e2 \u05dc\u05d9\u05dc\u05d3 \u05e9\u05dc\u05db\u05dd \u05db\u05e1\u05e3 \u2013 \u05d5\u05d0\u05ea\u05dd \u05d1\u05db\u05dc\u05dc \u05dc\u05d0 \u05d9\u05d5\u05d3\u05e2\u05d9\u05dd \u05e2\u05dc \u05d6\u05d4* \ud83e\udee3", "\u05dc\u05e4\u05e0\u05d9 \u05d6\u05de\u05df \u05e7\u05e6\u05e8, \u05dc\u05d5\u05d7\u05de\u05d9\u05e0\u05d5 \u05de\u05d7\u05d8\u05d9\u05d1\u05ea \u05d1\u05e0\u05d9\u05de\u05d9\u05df \u05d1\u05e4\u05d9\u05e7\u05d5\u05d3\u05d5 \u05e2\u05dc \u05d0\u05dc\u05f4\u05de \u05e2\u05e0\u05d0\u05df \u05e4\u05d0\u05e8\u05e1, \u05e0\u05db\u05e0\u05e1\u05d5 \u05dc\u05db\u05e4\u05e8 \u05d3\u05d9\u05e8 \u05d2\u05f3\u05e8\u05d9\u05e8...", "\ud83d\uddbc *\u05d4\u05d9\u05dc\u05d3 \u05d1\u05d5\u05d3\u05e7 \u05db\u05dc \u05d1\u05d9\u05e1?*", "\ud83d\uddbc \u05e1\u05e4\u05e8\u05d3 \u05e0\u05d9\u05e6\u05d7\u05d4 \u05d0\u05ea \u05d4\u05de\u05d5\u05e0\u05d3\u05d9\u05d0\u05dc \ud83c\uddea\ud83c\uddf8", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05de\u05e0\u05d3\u05d9 \u05e8\u05d9\u05d6\u05dc", "\u21a9\ufe0f\ud83c\udfac \u05de\u05d0\u05d5\u05ea \u05d9\u05e6\u05d0\u05d5 \u05de\u05d0\u05d5\u05db\u05d6\u05d1\u05d9\u05dd \u05de\u05d4\u05e6\u05e4\u05d9\u05d9\u05d4 \u05d4\u05de\u05e9\u05d5\u05ea\u05e4\u05ea \u05d1\u05e4\u05d0\u05e8\u05e7 \u05d4\u05dc\u05d0\u05d5\u05de\u05d9 \u05d1\u05e8\u05de\u05ea \u05d2\u05df \u05dc\u05d0\u05d7\u05e8 \u05e9\u05e1\u05e4\u05e8\u05d3 \u05e0\u05d9\u05e6\u05d7\u05d4 \u05d0\u05ea \u05d0...", "\u21a9\ufe0f\ud83c\udfac \u05dc\u05de\u05e8\u05d5\u05ea \u05d4\u05d4\u05e4\u05e1\u05d3 \u05d0\u05d5\u05d4\u05d3\u05d9 \u05d0\u05e8\u05d2\u05e0\u05d8\u05d9\u05e0\u05d4 \u05de\u05e2\u05d5\u05d3\u05d3\u05d9\u05dd \u05d0\u05ea \u05d4\u05e7\u05d1\u05d5\u05e6\u05d4 \u05d1\u05d8\u05d9\u05d9\u05de\u05e1 \u05e1\u05e7\u05d5\u05d5\u05e8", "\u05de\u05d1\u05d6\u05e7\u05df 12", "\ud83d\uddbc \u05de\u05e1\u05d9 \u05de\u05e1\u05d9\u05d9\u05dd \u05e7\u05e8\u05d9\u05d9\u05e8\u05ea \u05db\u05d3\u05d5\u05e8\u05d2\u05dc \u05d1\u05d4\u05e4\u05e1\u05d3 \u05e6\u05d5\u05e8\u05dd.\ud83d\ude2d", "\ud83d\uddbc \u05d4\u05d3\u05d0\u05d7\u05e7\u05d5\u05ea \u05d1\u05e8\u05e9\u05ea \u05d0\u05d7\u05e8\u05d9 \u05d4\u05d4\u05e4\u05e1\u05d3 \u05e9\u05dc \u05d0\u05e8\u05d2\u05e0\u05d8\u05d9\u05e0\u05d4", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05de\u05e0\u05d7\u05dd \u05e7\u05d5\u05dc\u05d3\u05e6\u05e7\u05d9", "\u05d3\u05e8\u05de\u05d4 \u05d1\u05d2\u05d5\u05e8: \u05d4\u05d0\u05d3\u05de\u05d5\"\u05e8 \u05de\u05d2\u05d5\u05e8 \u05d4\u05d5\u05e8\u05d4 \u05e9\u05db\u05dc\u05dc \u05ea\u05dc\u05de\u05d9\u05d3\u05d9 \u05db\u05d9\u05ea\u05ea \u05d4\u05de\u05e2\u05d1\u05e8 \u05de\u05d4\u05d7\u05d9\u05d9\u05d3\u05e8 \u05dc\u05de\u05ea\u05d9\u05d1\u05ea\u05d0 \u05d9\u05e2\u05d1\u05e8\u05d5 \u05dc\u05e4\u05e0\u05d9\u05d5 \u05d8\u05e8...", "\ud83c\udfac \u05e9\u05d4\u05d7\u05d9\u05d9\u05e0\u05d5 \u05d5\u05e7\u05d9\u05d9\u05de\u05e0\u05d5 \u05d5\u05d4\u05d2\u05e2\u05e0\u05d5 \u05dc\u05d6\u05de\u05df \u05d4\u05d6\u05d4 \ud83d\udca5", "\u05d0\u05e1\u05e3 \u05e8\u05d5\u05d6\u05e0\u05e6\u05d5\u05d9\u05d9\u05d2", "\ud83d\uddbc \u05de\u05e9\u05d4 \u05d5\u05d9\u05e1\u05d1\u05e8\u05d2 \u05de\u05e6\u05d8\u05d8 \u05d0\u05ea \u05de\u05e9\u05d4 \u05d5\u05d9\u05e1\u05d1\u05e8\u05d2", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d7\u05e8\u05d3\u05d9\u05dd10", "\ud83d\uddbc \u05d1\u05db\u05d4 \u05ea\u05d1\u05db\u05d4 \u05d1\u05dc\u05d9\u05dc\u05d4", "\ud83c\udfac *\u05de\u05e4\u05d7\u05d9\u05d3! \u05de\u05e8\u05df \u05e8\u05e9\u05db\u05d1\u05d4\u05f4\u05d2 \u05e9\u05e8 \u05d4\u05ea\u05d5\u05e8\u05d4 \u05e8\u05d1\u05d9 \u05d7\u05d9\u05d9\u05dd \u05e7\u05e0\u05d9\u05d9\u05d1\u05e1\u05e7\u05d9 \u05d6\u05e6\u05d5\u05e7\u05f4\u05dc \u05d1\u05d5\u05d9\u05d3\u05d9\u05d0\u05d5 \u05e0\u05d3\u05d9\u05e8 \u05d5\u05d0\u05e7\u05d8\u05d5\u05d0\u05dc\u05d9 \u05de\u05d0\u05d9 ...", "\ud83d\uddbc \u05de\u05d7\u05e8 \u05d1\u05d9\u05ea\u05d3", "\ud83d\uddbc \u05d0\u05e1\u05e3 \u05e8\u05d5\u05d6\u05e0\u05e6\u05d5\u05d9\u05d9\u05d2", "\ud83c\udfac \u05de\u05d1\u05e7\u05e8 \u05d4\u05e4\u05e0\u05d9\u05dd \u05e9\u05dc \u05de\u05e4\u05dc\u05d2\u05ea \u05d4\u05dc\u05d9\u05db\u05d5\u05d3, \u05e2\u05d5\"\u05d3 \u05e9\u05d9 \u05d2\u05dc\u05d9\u05dc\u05d9, \u05d0\u05e6\u05dc \u05e0\u05d3\u05d1 \u05d0\u05dc\u05d9\u05de\u05dc\u05da \u05d1\"\u05d4\u05d9\u05e9\u05e8\u05d0\u05dc\u05d9\u05dd\": \"\u05d4\u05e2\u05e8\u05db\u05d4 \u05e9\u05dc\u05d9, ...", "\u05e6\u05d1\u05d0 \u05d0\u05e8\u05d4\u05f4\u05d1 \u05e4\u05ea\u05d7 \u05d1\u05d2\u05dc \u05ea\u05e7\u05d9\u05e4\u05d5\u05ea \u05e0\u05d5\u05e1\u05e3 \u05d1\u05d0\u05d9\u05e8\u05d0\u05df. \u05d3\u05d9\u05d5\u05d5\u05d7\u05d9\u05dd \u05e2\u05dc \u05e4\u05d9\u05e6\u05d5\u05e6\u05d9\u05dd \u05d1\u05ea\u05d1\u05e8\u05d9\u05d6 \u05d5\u05d1\u05d7\u05f3\u05d5\u05e8\u05de\u05d0\u05d1\u05d0\u05d3.", "\ud83c\udfac *\u05ea\u05d9\u05e2\u05d5\u05d3 \u05de\u05ea\u05e7\u05d9\u05e4\u05d4 \u05d0\u05de\u05e8\u05d9\u05e7\u05e0\u05d9\u05ea \u05d1\u05ea\u05d1\u05e8\u05d9\u05d6*", "\ud83c\udfac \u05d4\u05e0\u05e9\u05d9\u05d0 \u05e9\u05dc\u05d0 \u05de\u05e4\u05e1\u05e4\u05e1 \u05e9\u05d5\u05dd \u05d4\u05d6\u05d3\u05de\u05e0\u05d5\u05ea \u05dc\u05e4\u05e8\u05e1\u05d5\u05dd- \u05d4\u05d2\u05d9\u05e2 \u05dc\u05d1\u05e8\u05da \u05d0\u05ea \u05e1\u05e4\u05e8\u05d3 \ud83c\udfa5", "\u05e6\u05d1\u05d0 \u05d0\u05e8\u05d4\"\u05d1: \u05e4\u05ea\u05d7\u05e0\u05d5 \u05d1\u05d2\u05dc \u05ea\u05e7\u05d9\u05e4\u05d5\u05ea \u05d1\u05d0\u05d9\u05e8\u05d0\u05df", "\ud83d\uddbc \u05d0\u05d6\u05e2\u05e7\u05d5\u05ea \u05d1\u05db\u05e4\u05e8 \u05e2\u05d6\u05d4 \u05d5\u05e1\u05e2\u05d3", "\ud83c\udfac \u05de\u05e9\u05e2\u05e9\u05e2: \u05d8\u05e8\u05d0\u05de\u05e4 \u05e0\u05d3\u05d7\u05e3 \u05dc\u05ea\u05de\u05d5\u05e0\u05d4 \u05d4\u05e8\u05e9\u05de\u05d9\u05ea \u05e9\u05dc \u05e0\u05d1\u05d7\u05e8\u05ea \u05e1\u05e4\u05e8\u05d3", "\u05d1\u05d4\u05de\u05e9\u05da \u05dc\u05d4\u05ea\u05e8\u05e2\u05d5\u05ea \u05e9\u05d4\u05d5\u05e4\u05e2\u05dc\u05d5 \u05dc\u05e4\u05e0\u05d9 \u05d6\u05de\u05df \u05e7\u05e6\u05e8 \u05d1\u05de\u05e8\u05d7\u05d1 \u05db\u05e4\u05e8 \u05e2\u05d6\u05d4 \u05d5\u05e1\u05e2\u05d3, \u05de\u05d3\u05d5\u05d1\u05e8 \u05d1\u05d6\u05d9\u05d4\u05d5\u05d9 \u05e9\u05d5\u05d5\u05d0\u200c\u200b\u200b\u200b\u200b\u200c\u200b\u200b\u200d...", "\u05d3\u05d5\u05d1\u05e8 \u05e6\u05d4\"\u05dc:", "*\u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05e1\u05e7\u05d5\u05e4\u05d9\u05dd*", "\ud83c\udfac \u05d4\u05e0\u05e2\u05e8\u05d9\u05dd \u05e9\u05de\u05e9\u05d7\u05e7\u05d9\u05dd \u05d5\u05de\u05ea\u05e2\u05e9\u05e8\u05d9\u05dd \u05de\u05d4\u05d1\u05d5\u05e8\u05e1\u05d4. \u05db\u05d0\u05df \u05d7\u05d3\u05e9\u05d5\u05ea.", "\ud83c\udfac \u05d8\u05e8\u05d0\u05de\u05e4 \u05e9\u05d4\u05e2\u05e0\u05d9\u05e7 \u05d4\u05dc\u05d9\u05dc\u05d4 \u05d0\u05ea \u05d4\u05d2\u05d1\u05d9\u05e2 \u05dc\u05e1\u05e4\u05e8\u05d3 \u05d4\u05ea\u05d9\u05d9\u05d7\u05e1 \u05d0\u05d7\u05e8 \u05db\u05da \u05dc\u05ea\u05e7\u05d9\u05e4\u05d5\u05ea: \"\u05d4\u05db\u05e0\u05d5 \u05d1\u05d0\u05d9\u05e8\u05d0\u05df \u05d7\u05d6\u05e7 \u05de\u05d0\u05d5\u05d3\"", "\ud83d\uddbc \u05de\u05d1\u05d6\u05e7\u05df 12", "*\u05dc\u05e7\u05d8 \u05d3\u05d9\u05d5\u05d5\u05d7\u05d9\u05dd \u05de\u05d4\u05e9\u05e2\u05d4 \u05d4\u05d0\u05d7\u05e8\u05d5\u05e0\u05d4 \u05e2\u05dc \u05d4\u05ea\u05e7\u05d9\u05e4\u05d5\u05ea \u05d4\u05dc\u05d9\u05dc\u05d4 \u05d1\u05d0\u05d9\u05e8\u05d0\u05df \u05d5\u05d1\u05d2\u05d9\u05d6\u05e8\u05d4 \u05d1\u05db\u05dc\u05dc*", "\ud83c\udfac \u05d3\u05e1\u05e7 \u05d4\u05d7\u05d5\u05e5", "\u05d0\u05d9\u05dc\u05e0\u05d9\u05ea \u05d0\u05d3\u05dc\u05e8", "\ud83c\udfac \u05d0\u05e1\u05e3 \u05e8\u05d5\u05d6\u05e0\u05e6\u05d5\u05d9\u05d9\u05d2", "\ud83c\udfac \u05e1\u05e4\u05e8\u05d3 *vs* \u05d0\u05e8\u05d2\u05e0\u05d8\u05d9\u05e0\u05d4", "\u05e8\u05e2\u05d9\u05d3\u05ea \u05d0\u05d3\u05de\u05d4 \u05d1\u05e2\u05d5\u05e6\u05de\u05d4 5.5 \u05d1\u05e1\u05d5\u05dc\u05dd \u05e8\u05d9\u05db\u05d8\u05e8 \u05e4\u05e7\u05d3\u05d4 \u05d0\u05ea \u05de\u05e2\u05e8\u05d1 \u05d0\u05d9\u05e8\u05d0\u05df, \u05db\u05da \u05de\u05e1\u05e8 \u05d4\u05de\u05e8\u05db\u05d6 \u05d4\u05e1\u05d9\u05d9\u05e1\u05de\u05d5\u05dc\u05d5\u05d2\u05d9 \u05d4\u05d0\u05d9\u05e8\u05d5...", "\ud83d\uddbc *\u05e8\u05d5\u05e2\u05d9 \u05e7\u05d9\u05d9\u05e1:* \u05d4\u05e7\u05e8\u05d9\u05e7\u05d8\u05d5\u05e8\u05d9\u05e1\u05d8 \u05d4\u05e4\u05dc\u05e1\u05d8\u05d9\u05e0\u05d9 \u05e2\u05dc\u05d0\u05d0 \u05d0-\u05dc\u05e7\u05d8\u05d4 (\u05d4\u05de\u05d6\u05d5\u05d4\u05d4 \u05e2\u05dd \u05d7\u05de\u05d0\u05e1) \u05d7\u05d5\u05d2\u05d2 \u05d1\u05d3\u05e8\u05db\u05d5 \u05d0\u05ea \u05d4\u05d6\u05db\u05d9...", "\ud83c\udfac *\u05e8\u05d5\u05e2\u05d9 \u05e7\u05d9\u05d9\u05e1:* \u05d7\u05d2\u05d9\u05d2\u05d5\u05ea \u05d1\u05d3\u05d0\u05d7\u05d9\u05d4 \u05e9\u05dc \u05d1\u05d9\u05d9\u05e8\u05d5\u05ea, \u05de\u05e2\u05d5\u05d6 \u05d7\u05d9\u05d6\u05d1\u05d0\u05dc\u05dc\u05d4, \u05d1\u05e2\u05e7\u05d1\u05d5\u05ea \u05d4\u05d6\u05db\u05d9\u05d9\u05d4 \u05e9\u05dc \u05e1\u05e4\u05e8\u05d3 \u05d5\u05d4\u05d4\u05e4\u05e1\u05d3...", "\ud83c\udfac *\u05e8\u05d5\u05e2\u05d9 \u05e7\u05d9\u05d9\u05e1:* \u05d1\u05de\u05e6\u05e8\u05d9\u05dd \u05d7\u05d5\u05d2\u05d2\u05d9\u05dd \u05d0\u05ea \u05d4\u05d6\u05db\u05d9\u05d9\u05d4 \u05e9\u05dc \u05e1\u05e4\u05e8\u05d3 \u05d5\u05d1\u05e2\u05d9\u05e7\u05e8 \u05d0\u05ea \u05d4\u05d4\u05e4\u05e1\u05d3 \u05e9\u05dc \u05de\u05e1\u05d9", "\ud83c\udfac \u05e0\u05e9\u05d9\u05d0 \u05d0\u05e8\u05d4\"\u05d1 \u05d3\u05d5\u05e0\u05dc\u05d3 \u05d8\u05e8\u05d0\u05de\u05e4 \u05de\u05e2\u05e0\u05d9\u05e7 \u05de\u05d3\u05dc\u05d9\u05d5\u05ea \u05dc\u05e9\u05d5\u05e4\u05d8\u05d9 \u05de\u05e9\u05d7\u05e7\u05d9 \u05e4\u05d9\u05e4\"\u05d0 \ud83c\uddfa\ud83c\uddf8", "\u05d1\u05d9\u05ea \u05e9\u05de\u05e9 \u05d7\u05d3\u05e9\u05d5\u05ea", "\ud83c\udfac \u05e6\u05d1\u05d0 \u05d0\u05e8\u05d4\"\u05d1: \u05d4\u05e9\u05dc\u05de\u05e0\u05d5 \u05d1\u05d4\u05e6\u05dc\u05d7\u05d4 \u05d0\u05ea \u05e1\u05d1\u05d1 \u05d4\u05ea\u05e7\u05d9\u05e4\u05d5\u05ea \u05d4\u05ea\u05e9\u05d9\u05e2\u05d9 \u05e0\u05d2\u05d3 \u05d0\u05d9\u05e8\u05d0\u05df. \u05ea\u05e7\u05e4\u05e0\u05d5 \u05d1\u05d9\u05df \u05d4\u05d9\u05ea\u05e8 \u05de\u05e8\u05db\u05d6\u05d9 \u05e4\u05d9...", "\ud83d\uddbc \u05d4\u05e7\u05d8\u05dc \u05d1\u05d3\u05e8\u05db\u05d9\u05dd: \u05d1\u05df 19 \u05e0\u05d4\u05e8\u05d2, \u05e6\u05e2\u05d9\u05e8 \u05db\u05d1\u05df 20 \u05e0\u05e4\u05e6\u05e2 \u05e7\u05e9\u05d4 \u05d5\u05e2\u05d5\u05d3 \u05e9\u05e0\u05d9 \u05d2\u05d1\u05e8\u05d9\u05dd \u05d1\u05e0\u05d9 26 \u05d5-28 \u05e0\u05e4\u05e6\u05e2\u05d5 \u05d1\u05d9\u05e0\u05d5\u05e0\u05d9 \u05d1...", "\u05de\u05d6\u05d2 \u05d4\u05d0\u05d5\u05d9\u05e8 \u05d1\u05d9\u05e9\u05e8\u05d0\u05dc: \u05d4\u05d9\u05d5\u05dd \u05ea\u05d5\u05e8\u05d2\u05e9 \u05d9\u05e8\u05d9\u05d3\u05d4 \u05e7\u05dc\u05d4 \u05d1\u05d8\u05de\u05e4\u05e8\u05d8\u05d5\u05e8\u05d5\u05ea \u05d1\u05e2\u05d9\u05e7\u05e8 \u05d1\u05e4\u05e0\u05d9\u05dd \u05d4\u05d0\u05e8\u05e5 \u05d5\u05d1\u05d4\u05e8\u05d9\u05dd, \u05d0\u05da \u05de\u05d6\u05d2 \u05d4...", "\ud83d\uddbc \u05e0\u05d9\u05e8 \u05d3\u05d1\u05d5\u05e8\u05d9", "\u21a9\ufe0f \u05e2\u05d3\u05db\u05d5\u05df \u05e1\u05d9\u05d5\u05dd \u05d0\u05d9\u05e8\u05d5\u05e2 \u05e0\u05e2\u05d3\u05e8\u05ea \u05ea\u05de\u05d9 \u05d0\u05dc\u05e7\u05e8\u05d0\u05d8", "\ud83d\uddbc *\u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05e1\u05e7\u05d5\u05e4\u05d9\u05dd*", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d7\u05d3\u05e9\u05d5\u05ea \u05d1\u05d7\u05d3\u05e8\u05d9 \u05d7\u05e8\u05d3\u05d9\u05dd", "\u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05e1\u05d9\u05db\u05d5\u05dd \u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05dc\u05d9\u05dc\u05d4", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d0\u05d5\u05d4\u05d3 \u05d0\u05e8\u05d2\u05e0\u05d8\u05d9\u05e0\u05d0\u05d9 \u05de\u05e0\u05d9\u05d7 \u05ea\u05e4\u05d9\u05dc\u05d9\u05df \u05d1\u05de\u05d7\u05e6\u05d9\u05ea \u05dc\u05d4\u05e6\u05dc\u05d7\u05ea \u05de\u05e1\u05d9", "\ud83c\udfac \u05d4\u05d2\u05dc \u05d4-9 - \u05ea\u05e7\u05d9\u05e4\u05d5\u05ea \u05d1\u05d0\u05d9\u05e8\u05d0\u05df \u2022 \u05de\u05e7\u05d1\u05e5", "\ud83d\uddbc *\u05de\u05d9\u05d9\u05e7 \u05e7\u05d5\u05e4\u05de\u05df \u05e8\u05d0\u05e9 \u05e2\u05d9\u05e8\u05d9\u05d9\u05ea \u05d0\u05d5\u05e8\u05d5\u05e8\u05d4-\u05e7\u05d5\u05dc\u05d5\u05e8\u05d3\u05d5 \u05e9\u05d0\u05e8\u05e6\u05d5\u05ea \u05d4\u05d1\u05e8\u05d9\u05ea \u05d9\u05e9\u05df \u05e4\u05e2\u05dd \u05d1\u05e9\u05d1\u05d5\u05e2 \u05e2\u05dd \u05d4\u05d5\u05de\u05dc\u05e1\u05d9\u05dd*", "\u05d0\u05d3\u05e8 \u05d2\u05d9\u05e6\u05d9\u05e1", "\u05d0\u05d6\u05e2\u05e7\u05d5\u05ea \u05d4\u05d5\u05e4\u05e2\u05dc\u05d5 \u05d4\u05dc\u05d9\u05dc\u05d4 \u05d1\u05db\u05e4\u05e8 \u05e2\u05d6\u05d4 \u05d5\u05d1\u05e1\u05e2\u05d3, \u05de\u05d3\u05d5\u05d1\u05e8 \u05e6\u05d4\"\u05dc \u05e0\u05de\u05e1\u05e8 \u05e9\u05de\u05d3\u05d5\u05d1\u05e8 \u05d4\u05d9\u05d4 \u05d1\u05d6\u05d9\u05d4\u05d5\u05d9 \u05e9\u05d5\u05d5\u05d0.", "\ud83d\uddbc \u05db\u05d5\u05d7\u05d5\u05ea \u05d4\u05d1\u05d9\u05d8\u05d7\u05d5\u05df \u05e0\u05db\u05e0\u05e1\u05d5 \u05dc\u05db\u05e4\u05e8 \u05d3\u05d9\u05e8 \u05d2'\u05e8\u05d9\u05e8 \u05e2\u05dc \u05de\u05e0\u05ea \u05dc\u05d0\u05d1\u05d8\u05d7 \u05d9\u05e9\u05e8\u05d0\u05dc\u05d9\u05dd \u05e9\u05d7\u05d9\u05e4\u05e9\u05d5 \u05d1\u05e2\u05dc\u05d9 \u05d7\u05d9\u05d9\u05dd \u05d4\u05e9\u05d9\u05d9\u05db\u05d9...", "\u05dc\u05d9\u05dc\u05d4 \u05e7\u05d8\u05dc\u05e0\u05d9 \u05d1\u05db\u05d1\u05d9\u05e9\u05d9\u05dd: \u05d1\u05df 19 \u05e0\u05d4\u05e8\u05d2 \u05d1\u05ea\u05d0\u05d5\u05e0\u05d4 \u05d1\u05d9\u05df \u05db\u05de\u05d4 \u05db\u05dc\u05d9 \u05e8\u05db\u05d1 \u05e1\u05de\u05d5\u05da \u05dc\u05de\u05d7\u05dc\u05e3 \u05d2\u05dc\u05d9\u05dc\u05d5\u05ea, \u05d4\u05d5\u05dc\u05da \u05e8\u05d2\u05dc \u05db\u05d1\u05df...", "\u05d4\u05e4\u05e9\u05d9\u05e2\u05d4 \u05d1\u05d9\u05e9\u05e8\u05d0\u05dc: \u05d4\u05de\u05e9\u05d8\u05e8\u05d4 \u05e4\u05ea\u05d7\u05d4 \u05d1\u05d7\u05e7\u05d9\u05e8\u05ea \u05d7\u05e9\u05d3 \u05dc\u05d4\u05e9\u05dc\u05db\u05ea \u05e8\u05d9\u05de\u05d5\u05df \u05d4\u05dc\u05dd \u05e6\u05d4\"\u05dc\u05d9 \u05e1\u05de\u05d5\u05da \u05dc\u05d7\u05e6\u05e8 \u05d1\u05e0\u05d9\u05d9\u05df \u05d1\u05de\u05e8\u05db\u05d6 ...", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d9\u05e9\u05e8\u05d0\u05dc \u05db\u05d4\u05df", "\ud83d\uddbc *\u05e0\u05de\u05d0\u05e1 \u05dc\u05d5 \u05de\u05d0\u05e0\u05e9\u05d9\u05dd*", "\u05e1\u05e4\u05d9\u05e8 \u05dc\u05d9\u05e4\u05e7\u05d9\u05df"]}