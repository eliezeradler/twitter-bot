d0 \u05de\u05d3\u05d5\u05d1\u05e8 \u05d1\u05d0\u05d9\u05e8\u05d5\u05e2 \u05dc\u05d0\u05d5\u05de\u05e0\u05d9: \u05d4\u05e9\u05d1\"\u05db \u05d9\u05e6\u05d0 \u05de\u05d7\u05e7\u05d9\u05e8\u05ea \u05d4\u05e9\u05e8\u05d9\u05e4\u05d4 \u05d1\u05e9\u05d5\u05de\u05e8\u05d5\u05df \u05d5\u05d4\u05e2\u05d1\u05d9\u05e8 \u05d0\u05ea \u05d4\u05ea...", "\u05de\u05d1\u05e6\u05e2 \u05d0\u05db\u05d9\u05e4\u05d4 \u05e0\u05e8\u05d7\u05d1 \u05d1\u05db\u05d1\u05d9\u05e9\u05d9 \u05d4\u05d0\u05d6\u05d5\u05e8: 11 \u05d3\u05d5\u05d7\u05d5\u05ea \u05e0\u05e8\u05e9\u05de\u05d5 \u05e0\u05d2\u05d3 \u05e0\u05d4\u05d2\u05d9\u05dd \u05e9\u05d1\u05d9\u05e6\u05e2\u05d5 \u05e2\u05d1\u05d9\u05e8\u05d5\u05ea \u05de\u05e1\u05db\u05e0\u05d5\u05ea \u05d7\u05d9\u05d9\u05dd", "\u200f\u05de\u05e0\u05d4\u05dc \u05e8\u05e9\u05d5\u05ea \u05d4\u05de\u05e1\u05d9\u05dd \u05d1\u05f3\u05d2\u05dc\u05f4\u05e6\u05f3: \u05f4\u05d9\u05e9 \u05dc\u05d9 \u05e4\u05d2\u05d9\u05e9\u05d4 \u05e2\u05dd \u05e8\u05d0\u05e9 \u05d4\u05e2\u05d9\u05e8 \u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7 \u05d4\u05d9\u05d5\u05dd, \u05de\u05e7\u05d5\u05d5\u05d4 \u05e9\u05ea\u05e6\u05d0 \u05de\u05e9\u05dd \u05d0\u05de\u05d9\u05e8...", "\ud83c\udfac \u05d9\u05e9\u05e8\u05d0\u05dc \u05d1\u05d5\u05d7\u05e8\u05ea \u05e6\u05d3", "\ud83c\udfac \u05d0\u05d9\u05e8\u05d0\u05df \u05ea\u05d5\u05e7\u05e4\u05ea \u05d0\u05ea \u05d1\u05d7\u05e8\u05d9\u05d9\u05df \u05d1\u05e9\u05e2\u05d4 \u05d6\u05d5.", "\u00b0\u05ea\u05d5\u05db\u05df \u05e9\u05d9\u05d5\u05d5\u05e7\u05d9", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d4\u05e4\u05e8\u05d3\u05d4 \u05d1\u05d9\u05e9\u05d5\u05d1 \u05ea\u05e4\u05e8\u05d7. \u05ea\u05d7\u05e0\u05d4 \u05dc\u05e0\u05e9\u05d9\u05dd \u05ea\u05d7\u05e0\u05d4 \u05dc\u05d2\u05d1\u05e8\u05d9\u05dd", "\u05e9\u05d5\u05e7 \u05d4\u05d4\u05d9\u05de\u05d5\u05e8\u05d9\u05dd \u05d1\u05e2\u05d5\u05dc\u05dd \u05e1\u05d1\u05d9\u05d1 \u05d6\u05d4\u05d5\u05ea \u05d4\u05e0\u05d1\u05d7\u05e8\u05ea \u05e9\u05ea\u05e0\u05e6\u05d7 \u05d4\u05dc\u05d9\u05dc\u05d4 \u05d1\u05d2\u05de\u05e8 \u05d4\u05de\u05d5\u05e0\u05d3\u05d9\u05d0\u05dc \u05d7\u05e6\u05d4 \u05d0\u05ea \u05e8\u05e3 \u05d4-4 \u05de\u05d9\u05dc\u05d9\u05d0\u05e8\u05d3...", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05e2\u05de\u05d9\u05d0\u05dc \u05d9\u05e8\u05d7\u05d9", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05de\u05e8\u05d3\u05db\u05d9 \u05d4\u05dc\u05e4\u05e8\u05d9\u05df", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d7\u05d3\u05e9\u05d5\u05ea \u05d1\u05d7\u05d3\u05e8\u05d9 \u05d7\u05e8\u05d3\u05d9\u05dd", "\ud83d\uddbc \u05de\u05e8\u05d3\u05db\u05d9 \u05d4\u05dc\u05e4\u05e8\u05d9\u05df \u05de\u05d2\u05d9\u05d1 \u05dc-\u05d8\u05d5\u05d1\u05d9\u05d4 \u05d9\u05d2\u05dc\u05e0\u05d9\u05e7", "\ud83d\uddbc \u05d8\u05d5\u05d1\u05d9\u05d4 \u05d9\u05d2\u05dc\u05e0\u05d9\u05e7 \u05de\u05d2\u05d9\u05d1 \u05dc-\u05d8\u05d5\u05d1\u05d9\u05d4 \u05d9\u05d2\u05dc\u05e0\u05d9\u05e7", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d8\u05d5\u05d1\u05d9\u05d4 \u05d9\u05d2\u05dc\u05e0\u05d9\u05e7", "\u05de\u05db\u05d1\u05e1\u05d4 \u05d1\u05e9\u05d3\u05e8\u05ea \u05e7\u05d9\u05e0\u05d2\u05e1\u05d8\u05d5\u05df \u05d1\u05e9\u05db\u05d5\u05e0\u05ea \u05e7\u05e8\u05d0\u05d5\u05df \u05d4\u05d9\u05d9\u05d8\u05e1 \u05e9\u05d1\u05d1\u05e8\u05d5\u05e7\u05dc\u05d9\u05df \u05d4\u05d5\u05d3\u05d9\u05e2\u05d4 \u05db\u05d9 \u05ea\u05e4\u05e1\u05d9\u05e7 \u05dc\u05e4\u05e2\u05d5\u05dc \u05d1\u05e9\u05d1\u05ea\u05d5\u05ea. \u05d1...", "\u05e2\u05d9\u05e8\u05d9\u05d9\u05ea \u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7: \u05d1\u05de\u05d4\u05dc\u05da \u05d4\u05e9\u05d1\u05ea \u05e4\u05e8\u05e6\u05d5 \u05e0\u05e2\u05e8\u05d9 \u05e9\u05d5\u05dc\u05d9\u05d9\u05dd \u05dc\u05de\u05e1\u05e4\u05e8 \u05de\u05e9\u05e8\u05d3\u05d9\u05dd \u05d1\u05de\u05d1\u05e0\u05d4 \u05d4\u05e2\u05d9\u05e8\u05d9\u05d9\u05d4 \u05d5\u05d6\u05e8\u05e2\u05d5 \u05d4\u05e8\u05e1. \u05de...", "\ud83c\udfac \u05d4\u05e9\u05e8\u05d9\u05d3 \u05d4\u05d0\u05d7\u05e8\u05d5\u05df \u05de\u05d1\u05d9\u05df \u05d0\u05d7\u05d9\u05d9\u05e0\u05d9\u05d5 \u05e9\u05dc \u05d4\u05d7\u05d6\u05d5\u05df \u05d0\u05d9\u05e9 \u05d9\u05d5\u05e6\u05d0 \u05d1\u05d4\u05d5\u05d3\u05e2\u05d4 \u05de\u05e4\u05ea\u05d9\u05e2\u05d4", "\u05d0\u05d9\u05ea\u05d9 \u05d2\u05dc-\u05d0\u05d5\u05df", "\ud83d\uddbc \u05de\u05d7\u05e9\u05e9 \u05dc\u05e7\u05e8\u05d9\u05e1\u05d4: \u05d1\u05e0\u05d9\u05d9\u05df \u05de\u05d2\u05d5\u05e8\u05d9\u05dd \u05d1\u05e8\u05d7\u05d5\u05d1 \u05d1\u05e8 \u05d0\u05d9\u05dc\u05df \u05d1\u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7 \u05e4\u05d5\u05e0\u05d4 \u05de\u05d3\u05d9\u05d9\u05e8\u05d9\u05dd \u05e2\u05d3 \u05dc\u05d4\u05e9\u05dc\u05de\u05ea \u05d4\u05d8\u05d9\u05e4\u05d5\u05dc \u05d5...", "\ud83c\udfac \u05d4\u05e2\u05e8\u05d9\u05e0\u05d2: \u05e8\u05d0\u05e9 \u05d4\u05e2\u05d9\u05e8 \u05e9\u05de\u05d5\u05dc\u05d9\u05e7 \u05d2\u05e8\u05d9\u05e0\u05d1\u05e8\u05d2 \u05d9\u05d5\u05e8\u05d3 \u05dc\u05e9\u05d8\u05d7 \u05d1\u05e4\u05e8\u05d5\u05d9\u05e7\u05d8 \u05f3\u05de\u05d7\u05e6\u05dc\u05d5\u05ea \u05d1\u05dc\u05d9\u05dc\u05d5\u05ea\u05f3 \u05d1\u05d1\u05d9\u05ea \u05e9\u05de\u05e9, \u05dc\u05d0 \u05d1...", "\ud83d\uddbc \u05d9\u05d5\u05d0\u05dc\u05d9 \u05d1\u05e8\u05d9\u05dd yoeli brim \u05de\u05e6\u05d8\u05d8 \u05d0\u05ea \u05d9\u05d5\u05d0\u05dc\u05d9 \u05d1\u05e8\u05d9\u05dd yoeli brim", "\ud83d\uddbc \u05d8\u05d9\u05dc\u05d9\u05dd \u05de\u05db\u05d5\u05d5\u05d9\u05ea \u05d1\u05db\u05d9\u05d5\u05d5\u05df \u05d0\u05d9\u05e8\u05d0\u05df", "\ud83c\udfac \u05e2\u05d9\u05e8\u05d0\u05e7-\u05e1\u05d5\u05e4\u05d8\u05d9: \u05db\u05dc\u05d9 \u05ea\u05e7\u05e9\u05d5\u05e8\u05ea \u05d1\u05e2\u05d9\u05e8\u05d0\u05e7 \u05de\u05d3\u05d5\u05d5\u05d7\u05d9\u05dd \u05e2\u05dc \u05d7\u05e1\u05d9\u05de\u05ea \u05d4\u05db\u05d1\u05d9\u05e9 \u05d4\u05e8\u05d0\u05e9\u05d9 \u05d1\u05d2\u05d3\u05d0\u05d3-\u05e7\u05d9\u05e8\u05e7\u05d5\u05e7, \u05dc\u05d0\u05d7\u05e8 \u05e9...", "*\"\u05d6\u05b8\u05db\u05d5\u05b9\u05e8 \u05d0\u05b6\u05ea \u05d9\u05d5\u05b9\u05dd \u05d4\u05b7\u05e9\u05b7\u05bc\u05c1\u05d1\u05b8\u05bc\u05ea \u05dc\u05b0\u05e7\u05b7\u05d3\u05b0\u05bc\u05e9\u05c1\u05d5\u05b9\"*", "\ud83c\udfac *\u05d4\u05d3\u05e3 \u05d4\u05d9\u05d5\u05de\u05d9*\ud83d\udcd6 \u05d7\u05d5\u05dc\u05d9\u05df \u05d3\u05e3 \u05e4", "*\u05dc\u05e7\u05e8\u05d0\u05ea \u05d1\u05d9\u05e7\u05d5\u05e8\u05d5 \u05e9\u05dc \u05e0\u05e9\u05d9\u05d0 \u05dc\u05d1\u05e0\u05d5\u05df \u05d1\u05d0\u05e8\u05e6\u05d5\u05ea \u05d4\u05d1\u05e8\u05d9\u05ea \u05d5\u05e4\u05d2\u05d9\u05e9\u05ea\u05d5 \u05d4\u05d9\u05d5\u05dd \u05e2\u05dd \u05e9\u05e8 \u05d4\u05d7\u05d5\u05e5 \u05de\u05e8\u05e7\u05d5 \u05e8\u05d5\u05d1\u05d9\u05d5 \u05d5\u05d1\u05d9\u05d5\u05dd \u05e9...", "*\u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05e1\u05e7\u05d5\u05e4\u05d9\u05dd*", "\ud83c\udfac \u05d4\u05de\u05d5\u05d6\u05d9\u05e7\u05d0\u05d9 \u05e0\u05d8\u05e2 \u05d5\u05d9\u05e0\u05e8 \u05e0\u05e2\u05e6\u05e8 \u05dc\u05d1\u05d3\u05d9\u05e7\u05d4 \u05d1\u05e9\u05d3\u05d4 \u05ea\u05e2\u05d5\u05e4\u05d4 \u05d1\u05e4\u05e8\u05e0\u05e7\u05e4\u05d5\u05e8\u05d8 \u05d5\u05d4\u05ea\u05d1\u05e7\u05e9 \u05dc\u05d4\u05d5\u05db\u05d9\u05d7 \u05e9\u05d4\u05d0\u05e7\u05d5\u05e8\u05d3\u05d9\u05d5\u05df \u05e9\u05d1...", "\ud83d\uddbc *\u05d1\u05d9\u05df \u05d4\u05d6\u05de\u05e0\u05d9\u05dd - \u05d1\u05d9\u05df \u05d4\u05d2\u05dc\u05d9\u05dd*", "\ud83d\uddbc \u05e4\u05d9\u05e0\u05d5\u05d9 \u05d3\u05d9\u05d9\u05e8\u05d9\u05dd \u05de\u05de\u05d1\u05e0\u05d4 \u05de\u05e1\u05d5\u05db\u05df \u05d1\u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7", "\u05d0\u05dc\u05d9 \u05d4\u05d9\u05e8\u05e9\u05de\u05df", "\ud83d\uddbc \u05d0\u05dc\u05d9 \u05d4\u05d9\u05e8\u05e9\u05de\u05df", "\ud83d\uddbc \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d1\u05e2\u05e8\u05d5\u05e5 12 \u05e7\u05e6\u05ea \u05d4\u05ea\u05d1\u05dc\u05d1\u05dc\u05d5 \u05d0\u05d9\u05da \u05dc\u05db\u05ea\u05d5\u05d1 \u05d7\u05e1\u05d9\u05d3\u05d5\u05ea \"\u05e6\u05d0\u05e0\u05d6\"", "\ud83d\uddbc \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d2\u05dd \u05e2\u05e7\u05d9\u05d1\u05d0 \u05e0\u05d5\u05d1\u05d9\u05e7 \u05dc\u05d0 \u05de\u05d5\u05d5\u05ea\u05e8 \u05e2\u05dc \u05d0\u05d5\u05e9\u05e8 \u05e2\u05d3", "\ud83d\uddbc \u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7 - \u05e8\u05d7\u05d5\u05d1 \u05d1\u05df \u05d2\u05d5\u05e8\u05d9\u05d5\u05df / \u05d6'\u05d1\u05d5\u05d8\u05d9\u05e0\u05e1\u05e7\u05d9: \u05e9\u05d9\u05e9\u05d4 \u05e0\u05e4\u05d2\u05e2\u05d9\u05dd \u05d1\u05de\u05e6\u05d1 \u05e7\u05dc \u05dc\u05d0\u05d7\u05e8 \u05e9\u05e0\u05e4\u05d2\u05e2\u05d5 \u05d1\u05ea\u05d0\u05d5\u05e0\u05d4 \u05d1\u05d9\u05df ...", "\u05d1\u05e6\u05d4\"\u05dc \u05de\u05e2\u05e8\u05d9\u05db\u05d9\u05dd \u05e9\u05d0\u05d9\u05e8\u05d0\u05df \u05d0\u05d9\u05e0\u05d4 \u05de\u05ea\u05db\u05e0\u05e0\u05ea \u05db\u05e8\u05d2\u05e2 \u05d9\u05e8\u05d9 \u05dc\u05d9\u05e9\u05e8\u05d0\u05dc, \u05d0\u05da \u05de\u05d6\u05d4\u05d9\u05e8\u05d9\u05dd \u05de\u05ea\u05e8\u05d7\u05d9\u05e9 \u05db\u05de\u05d5 \u05ea\u05e7\u05d9\u05e4\u05ea \u05de\u05ea\u05e7\u05e0...", "\ud83c\udfac \u05ea\u05d9\u05e2\u05d5\u05d3 \u05d0\u05d9\u05e8\u05d0\u05e0\u05d9 \u05e9\u05dc \u05d4\u05e4\u05dc\u05ea \u05db\u05d8\u05d1\u05de \u05de\u05e1\u05d5\u05d2 MQ-9 \u05d1\u05e9\u05de\u05d9 \u05d0\u05dc\u05d0\u05d4\u05d5\u05d5\u05d0\u05d6 \u05d1\u05d0\u05e9 \u05de\u05e2\u05e8\u05db\u05d5\u05ea \u05d4\u05d4\u05d2\u05e0\u05d4 \u05d4\u05d0\u05d5\u05d5\u05d9\u05e8\u05d9\u05ea \u05e9\u05dc \u05de\u05e9...", "\ud83d\uddbc \u05d0\u05e0\u05e9\u05d9 \u05de\u05e0\u05d2\u05e0\u05d5\u05df \u05d4\u05d1\u05d9\u05d8\u05d7\u05d5\u05df \u05d4\u05de\u05e1\u05db\u05dc \u05e9\u05dc \u05d4\u05e8\u05e9\u05d5\u05ea \u05d4\u05e4\u05dc\u05e1\u05d8\u05d9\u05e0\u05d9\u05ea \u05d0\u05d9\u05ea\u05e8\u05d5 \u05d1\u05d0\u05d6\u05d5\u05e8 \u05e8\u05de\u05d0\u05dc\u05dc\u05d4 \u05e8\u05db\u05d1 \u05e9\u05dc \u05e9\u05d2\u05e8\u05d9\u05e8\u05d5\u05ea ...", "\ud83c\udfac \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d9\u05e9\u05e8\u05d0\u05dc \u05db\u05d4\u05df", "\ud83d\uddbc \u05ea\u05de\u05d5\u05e0\u05ea \u05dc\u05d5\u05d5\u05d9\u05d9\u05df \u05e9\u05dc \u05d4\u05e8\u05e1 \u05d1\u05d1\u05e1\u05d9\u05e1 \u05de\u05d8\u05d5\u05e1\u05d9 \u05e7\u05e8\u05d1 \u05d0\u05de\u05e8\u05d9\u05e7\u05d0\u05d9\u05d9\u05dd \u05d1\u05d9\u05e8\u05d3\u05df (\u05ea\u05e1\u05e0\u05d9\u05dd)", "\u05d0\u05d5\u05e8 \u05e8\u05d1\u05d9\u05d3", "\u05dc\u05e4\u05d9 \u05e0\u05d9\u05d5 \u05d9\u05d5\u05e8\u05e7 \u05d8\u05d9\u05d9\u05de\u05e1, \u05d9\u05e8\u05d3\u05df \u05d4\u05e4\u05db\u05d4 \u05dc\u05de\u05d5\u05e7\u05d3 \u05dc\u05d4\u05ea\u05e7\u05e4\u05d5\u05ea \u05d0\u05d9\u05e8\u05d0\u05e0\u05d9\u05d5\u05ea \u05d1\u05e1\u05d1\u05d1 \u05d6\u05d4 \u05d0\u05d7\u05e8\u05d9 \u05e9\u05d7\u05dc\u05e7 \u05de\u05de\u05d3\u05d9\u05e0\u05d5\u05ea \u05d4\u05de\u05e4...", "\ud83d\uddbc \u05d1\u05d9\u05df \u05d4\u05d6\u05de\u05e0\u05d9\u05dd \u05d1\u05d1\u05d9\u05ea \u05d1\u05e6\u05e4\u05ea \ud83c\udf3f", "\ud83d\uddbc \"\u05d4\u05ea\u05e7\u05dc\u05d4\" \u05e9\u05d4\u05e6\u05d9\u05dc\u05d4 \u05d0\u05ea \u05e2\u05d9\u05df \u05d4\u05e9\u05dc\u05d5\u05e9\u05d4 \u05d4\u05d9\u05d0 \u05e9\u05d4\u05d4\u05d5\u05e8\u05d0\u05d4 \u05d4\u05ea\u05de\u05d5\u05d4\u05d4 \u05d5\u05d9\u05d5\u05e6\u05d0\u05ea \u05d4\u05d3\u05d5\u05e4\u05df \u05e9\u05d4\u05d2\u05d9\u05e2\u05d4 \u05de\u05d4\u05d0\u05d5\u05d2\u05d3\u05d4 \u05d1 3:00...", "*\u05d0\u05dc\u05be\u05e2\u05e8\u05d1\u05d9\u05d4: \u05d5\u05d5\u05e9\u05d9\u05e0\u05d2\u05d8\u05d5\u05df \u05d3\u05d7\u05ea\u05d4 \u05d0\u05ea \u05d1\u05e7\u05e9\u05ea \u05d9\u05e9\u05e8\u05d0\u05dc \u05dc\u05d4\u05e6\u05d8\u05e8\u05e3 \u05dc\u05de\u05dc\u05d7\u05de\u05d4 \u05e0\u05d2\u05d3 \u05d0\u05d9\u05e8\u05d0\u05df*", "*\u05d4\u05e8\u05db\u05d1 \u05e9\u05e1\u05d9\u05d1\u05da \u05d0\u05ea \u05d4\u05d7\u05e9\u05d5\u05d3 \u05d1\u05d4\u05e6\u05ea\u05ea \u05e1\u05e0\u05d9\u05e3 \u05d2\u2019\u05e4\u05e0\u05d9\u05e7\u05d4 \u05d1\u05d7\u05d9\u05e4\u05d4*", "\u05d9\u05d5\u05dc\u05df \u05db\u05d4\u05df", "\u05d3\u05e1\u05e7 \u05d4\u05e2\u05d5\u05dc\u05dd \u05d4\u05e2\u05e8\u05d1\u05d9", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d4\u05d0\u05d3\u05de\u05d5\u05f4\u05e8 \u05de\u05e1\u05d0\u05d3\u05d9\u05d2\u05d5\u05e8\u05d4 \u05d1\u05d0\u05de\u05d9\u05e8\u05ea \u05ea\u05d4\u05d9\u05dc\u05d9\u05dd \u05d1\u05e6\u05d9\u05d5\u05df \u05d4\u05d0\u05e8\u05f4\u05d9 \u05d4\u05e7\u05d3\u05d5\u05e9 \u05de\u05e6\u05e4\u05ea", "\u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d1\u05e8\u05e7\u05e2 \u05d2\u05d6\u05d9\u05e8\u05ea \u05d4\u05d2\u05d9\u05d5\u05e1 \u05d5\u05e6\u05d5\u05d5\u05d9 \u05e2\u05d9\u05db\u05d5\u05d1 \u05d4\u05d9\u05e6\u05d9\u05d0\u05d4 \u05d4\u05de\u05d5\u05e0\u05e2\u05d9\u05dd \u05de\u05d0\u05dc\u05e4\u05d9 \u05d7\u05e1\u05d9\u05d3\u05d9 \u05d1\u05e8\u05e1\u05dc\u05d1 \u05dc\u05d4\u05d2\u05d9\u05e2 \u05d1\u05d9\u05de\u05d9 \u05e8...", "\u05e9\u05d2\u05e8\u05d9\u05e8\u05d5\u05ea \u05d0\u05e8\u05d4\"\u05d1 \u05d1\u05d9\u05e8\u05d3\u05df: \u05d4\u05e8\u05e9\u05d5\u05d9\u05d5\u05ea \u05e4\u05d9\u05e0\u05d5 \u05d0\u05ea \u05e0\u05de\u05dc \u05d4\u05ea\u05e2\u05d5\u05e4\u05d4 \u05d4\u05d1\u05d9\u05df-\u05dc\u05d0\u05d5\u05de\u05d9 \u05d5\u05d0\u05ea \u05d4\u05e0\u05de\u05dc \u05d4\u05d9\u05de\u05d9 \u05d1\u05e2\u05e7\u05d1\u05d4 \u05d1\u05e2\u05e7\u05d1...", "\ud83d\uddbc \u05e9\u05d9\u05dc\u05d4 \u05e4\u05e8\u05d9\u05d3\ud83c\uddee\ud83c\uddf1 \u05de\u05e6\u05d8\u05d8 \u05d0\u05ea \u05d0\u05dc\u05d9", "*\u05d0\u05d5\u05ea\u05e8 \u05d4\u05e8\u05db\u05d1 \u05e9\u05e0\u05d2\u05e0\u05d1 \u05de\u05d4\u05e7\u05d5\u05e0\u05e1\u05d5\u05dc\u05d9\u05d4 \u05d1\u05e9\u05db\u05d5\u05e0\u05ea \u05e9\u05de\u05e2\u05d5\u05df \u05d4\u05e6\u05d3\u05d9\u05e7*", "\ud83d\uddbc \"\u05d6\u05d5 \u05e8\u05e7 \u05d0\u05e9 \u05e7\u05d8\u05e0\u05d4 \u05dc\u05e7\u05e4\u05d4. \u05de\u05d4 \u05d4\u05d1\u05e2\u05d9\u05d4\u2753", "\ud83c\udfac \u05e9\u05d5\u05d8\u05e8\u05d9 \u05de\u05d7\u05d5\u05d6 \u05d9\u05e8\u05d5\u05e9\u05dc\u05d9\u05dd \u05e2\u05e6\u05e8\u05d5 \u05e9\u05e0\u05d9 \u05e7\u05d8\u05d9\u05e0\u05d9\u05dd \u05ea\u05d5\u05e9\u05d1\u05d9 \u05d4\u05e2\u05d9\u05e8 \u05d4\u05e2\u05ea\u05d9\u05e7\u05d4 \u05d1\u05d7\u05e9\u05d3 \u05dc\u05ea\u05e7\u05d9\u05e4\u05ea \u05e6\u05e2\u05d9\u05e8 \u05d7\u05e8\u05d3\u05d9 \u05e1\u05de\u05d5\u05da...", "\ud83d\uddbc \u05d4\u05d4\u05e1\u05dc\u05de\u05d4 \u05de\u05d5\u05dc \u05d0\u05d9\u05e8\u05df: \u05d9\u05e8\u05d3\u05df \u05e4\u05d9\u05e0\u05ea\u05d4 \u05d0\u05ea \u05e0\u05de\u05dc\u05d9 \u05d4\u05ea\u05e2\u05d5\u05e4\u05d4 \u05d5\u05d4\u05d9\u05dd \u05d1\u05e2\u05e7\u05d1\u05d4 - \u05f4\u05d1\u05e9\u05dc \u05d0\u05d9\u05d5\u05dd \u05e1\u05e4\u05e6\u05d9\u05e4\u05d9 \u05d5\u05de\u05d4\u05d9\u05de\u05df\u05f4", "\ud83c\udfac\ud83d\uddbc \u05d0\u05dc\u05d2'\u05d6\u05d9\u05e8\u05d4: \u05d9\u05e9\u05e8\u05d0\u05dc \u05d4\u05e9\u05ea\u05dc\u05d8\u05d4 \u05db\u05d1\u05e8 \u05e2\u05dc \u05d9\u05d5\u05ea\u05e8 \u05de - 70% \u05de\u05d4\u05e8\u05e6\u05d5\u05e2\u05d4 \u05d5\u05d4\u05e7\u05d5 \u05d4\u05e6\u05d4\u05d5\u05d1 \u05de\u05de\u05e9\u05d9\u05da \u05dc\u05d4\u05ea\u05e7\u05d3\u05dd \u05de\u05de\u05d6\u05e8\u05d7 ...", "\u05d5\u05e0\u05e9\u05de\u05e8\u05ea\u05dd: \u05d1\u05e1\u05d5\u05e3 \u05d4\u05e9\u05d1\u05d5\u05e2 \u05d4\u05d0\u05d7\u05e8\u05d5\u05df 5 \u05d1\u05e0\u05d9 \u05d0\u05d3\u05dd \u05d8\u05d1\u05e2\u05d5 \u05dc\u05de\u05d5\u05d5\u05ea. \u05de\u05ea\u05d7\u05d9\u05dc\u05ea \u05e2\u05d5\u05e0\u05ea \u05d4\u05e8\u05d7\u05e6\u05d4 \u05e0\u05e8\u05e9\u05de\u05d5 \u05d1\u05e8\u05d7\u05d1\u05d9 \u05d4\u05d0\u05e8\u05e5 ...", "*\u05de\u05e1\u05e4\u05e8 \u05de\u05d8\u05d5\u05e8\u05e3 \u05e9\u05dc \u05db\u05dc\u05d9 \u05d8\u05d9\u05d9\u05e1 \u05d0\u05de\u05e8\u05d9\u05e7\u05d0\u05d9\u05dd \u05d1\u05d0\u05e8\u05e5*", "\u05e9\u05d2\u05e8\u05d9\u05e8\u05d5\u05ea \u05d0\u05e8\u05d4\u05f4\u05d1 \u05d1\u05d9\u05e8\u05d3\u05df: \u05e2\u05e7\u05d1 \u05d0\u05d9\u05d5\u05dd \u05e1\u05e4\u05e6\u05d9\u05e4\u05d9 \u05d5\u05d0\u05de\u05d9\u05df, \u05e4\u05d9\u05e0\u05d5 \u05d4\u05e8\u05e9\u05d5\u05d9\u05d5\u05ea \u05d4\u05d9\u05e8\u05d3\u05e0\u05d9\u05d5\u05ea \u05d0\u05ea \u05e9\u05d3\u05d4 \u05d4\u05ea\u05e2\u05d5\u05e4\u05d4 \u05d4\u05d1...", "\ud83c\udfac \u05e0\u05d1\u05d7\u05e8\u05ea \u05de\u05e6\u05e8\u05d9\u05dd \u05d4\u05e4\u05e1\u05d9\u05d3\u05d4 - \u05db\u05d9 \u05d0\u05e0\u05e9\u05d9\u05dd \u05e0\u05e2\u05d3\u05e8\u05d5 \u05de\u05d4\u05ea\u05e4\u05d9\u05dc\u05d5\u05ea \u05d1\u05de\u05e1\u05d2\u05d3\u05d9\u05dd!", "*\u05d1\u05d0\u05d9\u05e8\u05d0\u05df \u05de\u05d3\u05d5\u05d5\u05d7\u05d9\u05dd*", "\ud83d\uddbc \u05e9\u05d2\u05e8\u05d9\u05e8\u05d5\u05ea \u05d0\u05e8\u05d4\"\u05d1 \u05d1\u05d9\u05e8\u05d3\u05df :", "\ud83d\uddbc \u05d0\u05d6\u05e8\u05d7\u05d9\u05ea \u05d0\u05de\u05e8\u05d9\u05e7\u05d0\u05d9\u05ea-\u05d0\u05d9\u05e8\u05d0\u05e0\u05d9\u05ea, \u05d3\u05e0\u05d4 \u05e7\u05d0\u05e8\u05d0\u05e8\u05d9, \u05e9\u05d1\u05d4 \u05dc\u05d0\u05e8\u05d4\"\u05d1 \u05dc\u05d0\u05d7\u05e8 \u05e9\u05e0\u05e2\u05e6\u05e8\u05d4 \u05d1\u05d0\u05d9\u05e8\u05d0\u05df \u05d1\u05de\u05e9\u05da 566 \u05d9\u05de\u05d9\u05dd \u05d1...", "\ud83d\uddbc *\u05d1\u05d9\u05df \u05d4\u05d6\u05de\u05e0\u05d9\u05dd \u05d1\u05d1\u05d9\u05ea \u05d1\u05e6\u05e4\u05ea* \ud83c\udf3f", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d4\u05d7\u05d9\u05d3\"\u05d0 \u05d0\u05d1\u05e8\u05d2'\u05dc \u05de\u05d5\u05db\u05e8 \u05d0\u05d1\u05df \u05de\u05d1\u05d9\u05ea \u05de\u05d3\u05e8\u05e9\u05d5 \u05e9\u05dc \u05d0\u05d1\u05d9\u05d5 \u05d4\u05e8\u05d1 \u05d9\u05d5\u05e8\u05dd \u05d6\u05e6\"\u05dc \u05d1-700 \u05e9\u05e7\u05dc", "\ud83d\uddbc \u05d3\u05d9\u05d5\u05d5\u05d7 \u05d1\u05d0\u05d9\u05e8\u05d0\u05df: \u05ea\u05de\u05d5\u05e0\u05d5\u05ea \u05dc\u05d5\u05d5\u05d9\u05d9\u05df \u05de\u05d5\u05db\u05d9\u05d7\u05d5\u05ea \u05e4\u05d2\u05d9\u05e2\u05d5\u05ea \u05de\u05d3\u05d5\u05d9\u05d9\u05e7\u05d5\u05ea \u05d5\u05d4\u05e8\u05e1 \u05e9\u05dc \u05d4\u05d0\u05e0\u05d2\u05e8 \u05de\u05d8\u05d5\u05e1\u05d9 \u05e7\u05e8\u05d1 \u05d1\u05d1\u05e1...", "'\u05d4\u05d9\u05d5\u05dd': \u05d4\u05de\u05e9\u05d8\u05e8\u05d4 \u05d4\u05e6\u05d1\u05d0\u05d9\u05ea \u05e4\u05ea\u05d7\u05d4 \u05d1\u05d7\u05e7\u05d9\u05e8\u05d4 \u05e0\u05e8\u05d7\u05d1\u05ea \u05db\u05e0\u05d2\u05d3 \u05db\u05de\u05d4 \u05d0\u05d6\u05e8\u05d7\u05d9\u05dd \u05e2\u05d5\u05d1\u05d3\u05d9 \u05e6\u05d4\"\u05dc \u05d1\u05d7\u05e9\u05d3 \u05e9\u05d3\u05d9\u05d5\u05d5\u05d7\u05d5 \u05e2\u05dc \u05d9...", "\u05d4\u05de\u05d7\u05d0\u05d4 \u05e0\u05d2\u05d3 \u05de\u05e2\u05e6\u05e8 \u05dc\u05d5\u05de\u05d3\u05d9 \u05ea\u05d5\u05e8\u05d4: \u05de\u05d7\u05e8 \u05d4\u05e2\u05e6\u05e8\u05ea \u05e9\u05dc \u05d7\u05e1\u05d9\u05d3\u05d5\u05ea \u05d2\u05d5\u05e8 \u05d1\u05e8\u05d0\u05e9\u05d5\u05ea \u05d4\u05d0\u05d3\u05de\u05d5\"\u05e8, \u05d0\u05dc \u05de\u05d5\u05dc \u05db\u05dc\u05d0 10. \u05d1\u05e9\u05e2\u05d4...", "\u05de\u05d4 \u05d4\u05dd \u05d9\u05d5\u05d3\u05e2\u05d9\u05dd? \u05e9\u05d2\u05e8\u05d9\u05e8\u05d5\u05ea \u05d0\u05e8\u05d4\u05f4\u05d1 \u05d1\u05d9\u05e8\u05d3\u05df: \u05e2\u05e7\u05d1 \u05d0\u05d9\u05d5\u05dd \u05e1\u05e4\u05e6\u05d9\u05e4\u05d9 \u05d5\u05d0\u05de\u05d9\u05df, \u05e4\u05d9\u05e0\u05d5 \u05d4\u05e8\u05e9\u05d5\u05d9\u05d5\u05ea \u05d4\u05d9\u05e8\u05d3\u05e0\u05d9\u05d5\u05ea \u05d0\u05ea ...", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05de\u05e9\u05d4 \u05d5\u05d9\u05e1\u05d1\u05e8\u05d2", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d9\u05e9\u05e8\u05d0\u05dc \u05db\u05d4\u05df", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d7\u05e8\u05d3\u05d9\u05dd10", "\u05d0\u05e1\u05e3 \u05e8\u05d5\u05d6\u05e0\u05e6\u05d5\u05d9\u05d9\u05d2", "\u05e9\u05e8 \u05d4\u05d7\u05d5\u05e5 \u05e9\u05dc \u05d0\u05d9\u05e8\u05d0\u05df \u05e2\u05dc \u05d7\u05d9\u05e1\u05d5\u05dc \u05e2\u05dc\u05d9 \u05d7'\u05d0\u05de\u05e0\u05d0\u05d9: \u05d4\u05e2\u05d5\u05d1\u05d3\u05d4 \u05e9\u05d4\u05d0\u05d5\u05d9\u05d1 \u05d9\u05d3\u05e2 \u05e2\u05dc \u05e7\u05d9\u05d5\u05de\u05df \u05e9\u05dc \u05d4\u05d9\u05e9\u05d9\u05d1\u05d5\u05ea - \u05ea\u05d5\u05e6\u05d0\u05d4 ...", "\u05d8\u05d5\u05d1\u05d9\u05d4 \u05d9\u05d2\u05dc\u05e0\u05d9\u05e7: \u05e2\u05e9\u05e8\u05d5\u05ea \u05d0\u05dc\u05e4\u05d9 \u05d0\u05e8\u05d9\u05ea\u05e8\u05d9\u05d0\u05d9\u05dd \u05d5\u05e1\u05d5\u05d3\u05e0\u05d9\u05dd \u05e2\u05d6\u05d1\u05d5 \u05d0\u05ea \u05d9\u05e9\u05e8\u05d0\u05dc \u05d1\u05e2\u05e9\u05d5\u05e8 \u05d4\u05d0\u05d7\u05e8\u05d5\u05df, \u05d1\u05e2\u05d9\u05e7\u05e8 \u05dc\u05de\u05d3\u05d9\u05e0...", "\ud83c\udfac \u05db\u05ea\u05d1 \u05d0\u05d9\u05e9\u05d5\u05dd \u05d4\u05d5\u05d2\u05e9 \u05e0\u05d2\u05d3 \u05ea\u05d5\u05e9\u05d1 \u05e2\u05d6\u05d4 \u05e9\u05e0\u05db\u05e0\u05e1 \u05dc\u05d9\u05e9\u05e8\u05d0\u05dc \u05dc\u05e4\u05e0\u05d9 \u05d4-7 \u05dc\u05d0\u05d5\u05e7\u05d8\u05d5\u05d1\u05e8 \u05d5\u05d0\u05d5\u05ea\u05e8 \u05d1\u05de\u05e7\u05e8\u05d4 \u05dc\u05e4\u05e0\u05d9 \u05db\u05e9\u05d1\u05d5...", "\ud83d\uddbc \u05e9\u05d9\u05dc\u05d4 \u05e4\u05e8\u05d9\u05d3\ud83c\uddee\ud83c\uddf1 \u05de\u05e6\u05d8\u05d8 \u05d0\u05ea \u05e9\u05d9\u05dc\u05d4 \u05e4\u05e8\u05d9\u05d3\ud83c\uddee\ud83c\uddf1", "*\u05e0\u05ea\u05d5\u05e0\u05d9 \u05d4\u05de\u05e1\u05ea\u05e0\u05e0\u05d9\u05dd \u05d1\u05d9\u05e9\u05e8\u05d0\u05dc \u05e0\u05d7\u05e9\u05e4\u05d9\u05dd*", "\u21a9\ufe0f\ud83c\udfac \u05f4\u05d8\u05e8\u05e0\u05d3 \u05d7\u05d3\u05e9\u05f4: \u05e6\u05e2\u05d9\u05e8\u05d5\u05ea \u05d4\u05e9\u05d7\u05d9\u05ea\u05d5 \u05de\u05d5\u05e6\u05e8\u05d9\u05dd \u05d1\u05e7\u05e0\u05d9\u05d5\u05df \u05d1\u05e9\u05d1\u05d9\u05dc \u05e1\u05e8\u05d8\u05d5\u05df \u05dc\u05d8\u05d9\u05e7\u05d8\u05d5\u05e7 \u05f4\u05d1\u05e9\u05d1\u05d9\u05dc \u05e6\u05e4\u05d9\u05d5\u05ea\u05f4: \u05d4\u05d8...", "\ud83c\udfac *\u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05e1\u05e7\u05d5\u05e4\u05d9\u05dd*", "\u05d1\u05d9\u05e8\u05d3\u05df \u05de\u05db\u05d7\u05d9\u05e9\u05d9\u05dd: \u05d0\u05d9\u05df \u05d0\u05de\u05ea \u05d1\u05d4\u05d5\u05d3\u05e2\u05ea \u05d4\u05d0\u05de\u05e8\u05d9\u05e7\u05e0\u05d9\u05dd \u05e2\u05dc \u05e4\u05d9\u05e0\u05d5\u05d9 \u05e0\u05de\u05dc\u05d9 \u05d4\u05ea\u05e2\u05d5\u05e4\u05d4 \u05d5\u05d4\u05d9\u05dd \u05d1\u05e2\u05e7\u05d1\u05d4 (\u05d0\u05dc\u05d2\u05f3\u05d6\u05d9\u05e8\u05d4)", "\ud83d\uddbc \u05d9\u05e9\u05e8\u05d0\u05dc \u05db\u05d4\u05df \u05de\u05e6\u05d8\u05d8 \u05d0\u05ea \ud83c\udf39libi rose \u05e4\u05e8\u05d1\u05e8\ud83c\udf39", "*\u05d3\u05e8\u05de\u05d4 \u05d1\u05d9\u05e9\u05d9\u05d1\u05ea \u05d0\u05e9 \u05d4\u05ea\u05dc\u05de\u05d5\u05d3 \u05d1\u05e1\u05d5\u05e3 \u05d4\u05d6\u05de\u05df*", "\u05d0\u05e8\u05d4\"\u05d1 - \u05de\u05d3\u05d9\u05e0\u05d5\u05ea \u05d4\u05de\u05e4\u05e8\u05e5 | \u05d1\u05db\u05d9\u05e8 \u05d0\u05de\u05e8\u05d9\u05e7\u05e0\u05d9 \u05de\u05d5\u05e1\u05e8 \u05dc\u05e2\u05e8\u05d5\u05e5 \u05d0\u05dc-\u05d7\u05d3\u05ea' \u05d4\u05e1\u05e2\u05d5\u05d3\u05d9 \u05db\u05d9 \u05d0\u05e8\u05d4\"\u05d1 \u05de\u05ea\u05d5\u05d0\u05de\u05ea \u05e2\u05dd \u05e9\u05d5\u05ea\u05e4...", "\ud83c\udfac \ud83d\ude1e \u05dc\u05de\u05d4 \u05d0\u05e0\u05d9 \u05e2\u05e6\u05d5\u05d1? \u05d4\u05d0\u05e8\u05f4\u05d9 \u05d4\u05e7\u05d3\u05d5\u05e9 \u05de\u05d2\u05dc\u05d4 \u05d0\u05ea \u05d4\u05e1\u05d9\u05d1\u05d4", "\ud83c\udfac \u05d4\u05e2\u05e8\u05d9\u05e0\u05d2: \u05d7\u05e8\u05d3\u05d9\u05dd \u05ea\u05e7\u05d5\u05e2\u05d9\u05dd \u05d1\u05d0\u05de\u05e6\u05e2 \u05db\u05d1\u05d9\u05e9 6 \u05d1\u05dc\u05d9 \u05de\u05d9\u05dd \u05dc\u05d0\u05d7\u05e8 \u05e9\u05d4\u05d0\u05d5\u05d8\u05d5\u05d1\u05d5\u05e1 \u05e9\u05d1\u05e7 \u05d7\u05d9\u05d9\u05dd. \u05de\u05d9 \u05e9\u05d9\u05db\u05d5\u05dc \u05dc\u05e2\u05e6\u05d5\u05e8...", "\u05d1\u05e2\u05e7\u05d1\u05d5\u05ea \u05ea\u05e7\u05d9\u05e4\u05ea \u05e2\u05d5\u05d1\u05d3\u05d9 \u05e8\u05e9\u05d5\u05ea \u05d4\u05de\u05d9\u05e1\u05d9\u05dd: \u05d4\u05e1\u05ea\u05d3\u05e8\u05d5\u05ea \u05d4\u05de\u05d3\u05d9\u05e0\u05d4 \u05de\u05e9\u05d1\u05d9\u05ea\u05d4 \u05d0\u05ea \u05e4\u05e2\u05d9\u05dc\u05d5\u05ea \u05e2\u05d5\u05d1\u05d3\u05d9 \u05e8\u05e9\u05d5\u05ea \u05d4\u05de\u05d9\u05e1\u05d9\u05dd ...", "\u21a9\ufe0f \u05e9\u05d2\u05e8\u05d9\u05e8\u05d5\u05ea \u05d0\u05e8\u05d4\"\u05d1 \u05d1\u05d9\u05e8\u05d3\u05df: \u05d4\u05e8\u05e9\u05d5\u05d9\u05d5\u05ea \u05d4\u05d9\u05e8\u05d3\u05e0\u05d9\u05d5\u05ea \u05e4\u05d9\u05e0\u05d5 \u05d0\u05ea \u05e0\u05de\u05dc \u05d4\u05ea\u05e2\u05d5\u05e4\u05d4 \u05d4\u05d1\u05d9\u05e0\u05dc\u05d0\u05d5\u05de\u05d9 \u05d5\u05d0\u05ea \u05d4\u05e0\u05de\u05dc \u05d4\u05d9\u05de...", "\u05e9\u05e8 \u05d4\u05d7\u05d5\u05e5 \u05e9\u05dc \u05d0\u05d9\u05e8\u05d0\u05df \u05e2\u05d1\u05d0\u05e1 \u05e2\u05e8\u05d0\u05e7\u05e6'\u05d9 \u05e2\u05dc \u05d4\u05ea\u05e7\u05d9\u05e4\u05d4 \u05dc\u05d7\u05d9\u05e1\u05d5\u05dc \u05de\u05e0\u05d4\u05d9\u05d2 \u05d0\u05d9\u05e8\u05d0\u05df \u05e2\u05dc\u05d9 \u05d7'\u05d0\u05de\u05e0\u05d0\u05d9 \u05d1\u05e4\u05ea\u05d9\u05d7\u05ea \u05d4\u05de\u05dc\u05d7\u05de...", "\u05e0\u05ea\u05d5\u05e0\u05d9 \u05d4\u05de\u05e1\u05ea\u05e0\u05e0\u05d9\u05dd \u05d1\u05d9\u05e9\u05e8\u05d0\u05dc \u05e0\u05d7\u05e9\u05e4\u05d9\u05dd | \u05d8\u05d5\u05d1\u05d9\u05d4 \u05d9\u05d2\u05dc\u05e0\u05d9\u05e7 \u05d1\u05e4\u05e8\u05e1\u05d5\u05dd \u05e8\u05d0\u05e9\u05d5\u05df: \u05e2\u05e9\u05e8\u05d5\u05ea \u05d0\u05dc\u05e4\u05d9 \u05d0\u05e8\u05d9\u05ea\u05e8\u05d9\u05d0\u05d9\u05dd \u05d5\u05e1\u05d5...", "\ud83d\uddbc \u05d0\u05d7\u05d3 \u05de\u05e1\u05d9\u05e4\u05d5\u05e8\u05d9 \u05d4\u05d4\u05d9\u05e9\u05e8\u05d3\u05d5\u05ea \u05d4\u05de\u05d3\u05d4\u05d9\u05de\u05d9\u05dd \u05e9\u05d4\u05d9\u05d5 \u05d4\u05d9\u05d4 \u05e1\u05d9\u05e4\u05d5\u05e8\u05d5 \u05e9\u05dc \u05d5\u05d5\u05d9\u05dc\u05d9\u05d0\u05dd \u05dc\u05d0\u05e4\u05d1\u05e8, \u05e6\u05e2\u05d9\u05e8 \u05d0\u05de\u05e8\u05d9\u05e7\u05d0\u05d9 \u05e2\u05dd...", "`[\u05d4\u05de\u05e9\u05da \u05de\u05d4\u05d5\u05d3\u05e2\u05d4 \u05e7\u05d5\u05d3\u05de\u05ea \ud83d\udc46]`", "\ud83c\udfac \u05de\u05e8\u05df \u05e4\u05d5\u05e1\u05e7 \u05d4\u05d3\u05d5\u05e8 \u05d1\u05e7\u05d5\u05dc \u05d6\u05e2\u05e7\u05d4: \"\u05d4\u05e7\u05d1\"\u05d4 \u05e6\u05d5\u05e2\u05e7 \u05d4\u05ea\u05e2\u05d5\u05e8\u05e8\u05d5 \u05dc\u05d4\u05e6\u05dc\u05ea \u05e2\u05d5\u05dc\u05dd \u05d4\u05ea\u05d5\u05e8\u05d4!!\"", "\u21a9\ufe0f \u05e8\u05d5\u05d9\u05d8\u05e8\u05e1: \u05dc\u05e4\u05d9 \u05de\u05e0\u05db\"\u05dc \u05d7\u05d1\u05e8\u05ea \u05d4\u05e0\u05de\u05dc\u05d9\u05dd \u05e9\u05dc \u05e2\u05e7\u05d1\u05d4. \u05d0\u05d9\u05df \u05d0\u05de\u05ea \u05d1\u05e4\u05e8\u05e1\u05d5\u05dd \u05e2\u05dc \u05e4\u05d9\u05e0\u05d5\u05d9 \u05d5\u05d4\u05e0\u05de\u05dc \u05d1\u05d9\u05e8\u05d3\u05df \u05e4\u05d5\u05e2\u05dc \u05db...", "\ud83d\uddbc \u05dc\u05e7\u05e8\u05d0\u05ea \u05d7\u05ea\u05d5\u05e0\u05d4 \u05e2\u05dc \u05d4\u05d8\u05e2\u05d9\u05d4? \u05d0\u05d1\u05e0\u05e8 \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5, \u05d1\u05e0\u05d5 \u05e9\u05dc \u05e8\u05d0\u05e9 \u05d4\u05de\u05de\u05e9\u05dc\u05d4, \u05e0\u05de\u05e6\u05d0 \u05d1\u05d6\u05d5\u05d2\u05d9\u05d5\u05ea \u05d7\u05d3\u05e9\u05d4 \u05e2\u05dd \u05d3\u05e0\u05d4 \u05e6\u05d1...", "\u05e0\u05e6\u05d9\u05d1\u05d5\u05ea \u05e9\u05d9\u05e8\u05d5\u05ea \u05d4\u05de\u05d3\u05d9\u05e0\u05d4 \u05d1\u05d4\u05e0\u05d7\u05d9\u05d4 \u05e8\u05e9\u05de\u05d9\u05ea \u05db\u05e2\u05ea \u05dc\u05e2\u05d5\u05d1\u05d3\u05d9 \u05d4\u05de\u05d3\u05d9\u05e0\u05d4: \u05d4\u05d9\u05d5\u05dd \u05d4\u05d5\u05d0 \u05d4\u05d9\u05d5\u05dd \u05d4\u05d0\u05d7\u05e8\u05d5\u05df \u05e9\u05d1\u05d5 \u05e0\u05d9\u05ea\u05df ...", "\u05d4\u05d0\u05e8\u05d2\u05d5\u05df \u05d4\u05d0\u05d9\u05e8\u05d0\u05e0\u05d9 \u05dc\u05d0\u05e0\u05e8\u05d2\u05d9\u05d4 \u05d0\u05d8\u05d5\u05de\u05d9\u05ea \u05d8\u05d5\u05e2\u05df \u05db\u05d9 \u05e6\u05d1\u05d0 \u05d0\u05e8\u05d4\"\u05d1 \u05ea\u05e7\u05e3 \u05d4\u05dc\u05d9\u05dc\u05d4 \u05ea\u05d7\u05e0\u05ea \u05db\u05d5\u05d7 \u05d2\u05e8\u05e2\u05d9\u05e0\u05d9\u05ea \u05e9\u05e0\u05de\u05e6\u05d0\u05ea ...", "\u05de\u05e1\u05e4\u05e8 \u05d4\u05de\u05e1\u05ea\u05e0\u05e0\u05d9\u05dd \u05d1\u05d9\u05e9\u05e8\u05d0\u05dc \u05e6\u05e0\u05d7 \u05d1-50% \u05d1\u05e2\u05e9\u05d5\u05e8 \u05d4\u05d0\u05d7\u05e8\u05d5\u05df \u05de\u05db-50,000 \u05d1\u05ea\u05d7\u05d9\u05dc\u05ea 2016 \u05dc\u05db-25,000 \u05db\u05d9\u05d5\u05dd. \u05e2\u05e9\u05e8\u05d5\u05ea \u05d0\u05dc\u05e4\u05d9 ..."]}