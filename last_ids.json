u05d9\u05dd \u05d1\u05d8\u05d5\u05d7\u05d9\u05dd \u05d0\u05d5 \u05d3\u05d9 \u05d1\u05d8\u05d5\u05d7\u05d9\u05dd \u05dc\u05de\u05d9 \u05d9\u05e6\u05d1\u05d9\u05e2\u05d5. 66% \u05de\u05d4\u05d9\u05d4\u05d5\u05d3\u05d9\u05dd \u05de\u05d2\u05d3\u05d9\u05e8...", "\u05d5\u05d5\u05dc \u05e1\u05d8\u05e8\u05d9\u05d8 \u05d2'\u05d5\u05e8\u05e0\u05dc: \u05d1\"\u05de\u05d1\u05e6\u05e2 \u05d4\u05d4\u05e9\u05e4\u05e2\u05d4\" \u05e9\u05e0\u05d9\u05d4\u05dc\u05d4 \u05d9\u05e9\u05e8\u05d0\u05dc \u05e2\u05dc \u05d0\u05d6\u05e8\u05d7\u05d9 \u05d0\u05e8\u05d4\"\u05d1 \u05e0\u05e9\u05dc\u05d7\u05d5 \u05de\u05d9\u05dc\u05d9\u05d5\u05e0\u05d9 \u05d4\u05d5\u05d3\u05e2\u05d5\u05ea \u05dc\u05d0...", "\u05d2\u05d4\u05d4 \u05dc\u05d3\u05e8\u05d5\u05dd \u05e4\u05e7\u05d5\u05e7 \u05de\u05d0\u05d5\u05d3, \u05d1\u05d2\u05dc\u05dc \u05ea\u05d0\u05d5\u05e0\u05d4 \u05d1\u05d0\u05dc\u05d5\u05e3 \u05e9\u05d3\u05d4.", "\ud83d\uddbc \u05d5\u05d9\u05dc\u05d5\u05ea \u05d4\u05d0\u05d9\u05e8\u05d5\u05d7 \u05d7\u05d3\u05e9\u05d4 \u05d5\u05d9\u05d5\u05e7\u05e8\u05ea\u05d9\u05d5\u05ea \u05d1\u05e1\u05e4\u05e1\u05d5\u05e4\u05d4 \u2013 \u05d4\u05de\u05e7\u05d5\u05dd \u05d4\u05de\u05d5\u05e9\u05dc\u05dd \u05dc\u05e6\u05d9\u05d1\u05d5\u05e8 \u05d4\u05d3\u05ea\u05d9 \u05d5\u05d4\u05d7\u05e8\u05d3\u05d9", "\u21a9\ufe0f \u05e9\u05e8 \u05d4\u05ea\u05e7\u05e9\u05d5\u05e8\u05ea \u05e7\u05e8\u05e2\u05d9: \"\u05dc\u05d1\u05d2\"\u05e5 \u05d0\u05d9\u05df \u05e1\u05de\u05db\u05d5\u05ea \u05dc\u05d4\u05e7\u05e4\u05d9\u05d0 \u05d0\u05d5 \u05dc\u05e4\u05e1\u05d5\u05dc \u05d7\u05d5\u05e7\u05d9\u05dd. \u05dc\u05e6\u05d5 \u05d4\u05e0\u05d9\u05ea\u05df \u05d1\u05d7\u05d5\u05e1\u05e8 \u05e1\u05de\u05db\u05d5\u05ea \u05d0\u05d9...", "\u05e7\u05d5\u05dc\u05d5\u05ea \u05de\u05dc\u05d7\u05de\u05d4 - \u05dc\u05e7\u05e8\u05d0\u05ea \u05e1\u05d1\u05d1 \u05e0\u05d5\u05e1\u05e3: \u05d7\u05dc\u05e7 \u05de\u05de\u05d8\u05d5\u05e1\u05d9 \u05d4\u05e7\u05e8\u05d1 \u05d4\u05d0\u05de\u05e8\u05d9\u05e7\u05e0\u05d9\u05d9\u05dd \u05e9\u05e0\u05e9\u05dc\u05d7\u05d5 \u05dc\u05d0\u05d6\u05d5\u05e8 \u05d4\u05de\u05d6\u05e8\u05d7 \u05d4\u05ea\u05d9\u05db\u05d5\u05df ...", "\ud83d\uddbc \u05e0\u05db\u05d3 \u05dc\u05e9\u05e8 \u05d4\u05d0\u05d5\u05e6\u05e8: \u05d1\u05df \u05e9\u05e0\u05d9 \u05e0\u05d5\u05dc\u05d3 \u05d4\u05dc\u05d9\u05dc\u05d4 \u05dc\u05d1\u05e0\u05d9\u05d4 \u05d5\u05ea\u05de\u05e8 \u05e1\u05de\u05d5\u05d8\u05e8\u05d9\u05e5'. \u05d1\u05e0\u05d5 \u05e9\u05dc \u05d4\u05e9\u05e8 \u05de\u05e9\u05ea\u05e7\u05dd \u05de\u05e4\u05e6\u05d9\u05e2\u05d4 \u05e7\u05e9\u05d4 ...", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d9\u05d0\u05d9\u05e8 \u05dc\u05d5\u05d9", "\ud83d\uddbc \u05d1\u05e8\u05d6\u05d9\u05dc \u05d4\u05d5\u05d3\u05d7\u05d4 \u05de\u05de\u05d5\u05e0\u05d3\u05d9\u05d0\u05dc 2026 \u05d1\u05e9\u05de\u05d9\u05e0\u05d9\u05ea \u05d4\u05d2\u05de\u05e8, \u05de\u05e8\u05d5\u05e1\u05e7\u05ea \u05ea\u05d7\u05ea \u05d4\u05ea\u05e7\u05d5\u05d5\u05ea \u05e9\u05d4\u05ea\u05e0\u05e4\u05e6\u05d5 \u05e9\u05dc \u05de\u05d3\u05d9\u05e0\u05d4 \u05e9\u05dc\u05de\u05d4. \u05d4...", "\ud83d\uddbc \u05d1-13 \u05d1\u05d9\u05e0\u05d5\u05d0\u05e8 2012, \u05d0\u05d5\u05e0\u05d9\u05d9\u05ea \u05d4\u05ea\u05e2\u05e0\u05d5\u05d2\u05d5\u05ea \u05d4\u05d0\u05d9\u05d8\u05dc\u05e7\u05d9\u05ea \u05e7\u05d5\u05e1\u05d8\u05d4 \u05e7\u05d5\u05e0\u05e7\u05d5\u05e8\u05d3\u05d9\u05d4 \u05d4\u05ea\u05e7\u05e8\u05d1\u05d4 \u05de\u05d3\u05d9 \u05dc\u05d7\u05d5\u05e4\u05d9 \u05d4\u05d0\u05d9 \u05d2'\u05d9...", "`[\u05d4\u05de\u05e9\u05da \u05de\u05d4\u05d5\u05d3\u05e2\u05d4 \u05e7\u05d5\u05d3\u05de\u05ea \ud83d\udc46]`", "\u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05e4\u05e8\u05e1\u05d5\u05dd \u05e8\u05d0\u05e9\u05d5\u05df: \u05d4\u05d0\u05d3\u05de\u05d5\"\u05e8 \u05de\u05d2\u05d5\u05e8 \u05de\u05ea\u05db\u05e0\u05df \u05dc\u05d1\u05d5\u05d0 \u05de\u05d7\u05e8 \u05dc\u05e7\u05e8\u05d0\u05ea \u05d7\u05e6\u05d5\u05ea \u05dc\u05d9\u05dc \u05dc\u05db\u05dc\u05d0 10 \u05e2\u05dd \u05e2\u05e9\u05e8\u05d5\u05ea \u05d0\u05dc\u05e4\u05d9...", "\u21a9\ufe0f \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d4\u05e0\u05d5\u05e9\u05d0 \u05d2\u05dd \u05e2\u05dc\u05d4 \u05d1\u05e4\u05d2\u05d9\u05e9\u05d4 \u05d0\u05de\u05e9 \u05e2\u05dd \u05e9\u05de\u05e2\u05d5\u05df \u05e9\u05d9\u05e9\u05d0 \u05e9\u05d4\u05ea\u05d1\u05e7\u05e9 \u05dc\u05d4\u05e2\u05d1\u05d9\u05e8 \u05de\u05e1\u05e8 \u05d1\u05e8\u05d5\u05d7 \u05d6\u05d5 \u05dc\u05de\u05e4\u05e7\u05d3\u05d9 \u05d4...", "\ud83c\udfac \u05e0\u05e9\u05d9\u05d0 \u05dc\u05d1\u05e0\u05d5\u05df \u05d2'\u05d5\u05d6\u05e3 \u05e2\u05d5\u05df \u05d5\u05e8\u05e2\u05d9\u05d9\u05ea\u05d5 \u05e0\u05d7\u05ea\u05d5 \u05d1\u05d0\u05e8\u05d4\"\u05d1 \u05dc\u05e7\u05e8\u05d0\u05ea \u05de\u05e4\u05d2\u05e9 \u05e6\u05e4\u05d5\u05d9 \u05e2\u05dd \u05d4\u05e0\u05e9\u05d9\u05d0 \u05d8\u05e8\u05d0\u05de\u05e4 \u05d5\u05e2\u05dd \u05d1\u05db\u05d9\u05e8...", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d0\u05d9\u05e9\u05d9\u05d5\u05ea \u05d1\u05db\u05d9\u05e8\u05d4 \u05d1\u05d1\u05d9\u05e7\u05d5\u05e8 \u05d1\u05de\u05e8\u05dc\u05d5\"\u05d2 \u05d6\u05e7\"\u05d0 \u05d4\u05d0\u05e8\u05e6\u05d9", "\ud83d\uddbc \u05e2\u05d5\u05de\u05e1\u05d9 \u05ea\u05e0\u05d5\u05e2\u05d4 \u05db\u05d1\u05d3\u05d9\u05dd \u05de\u05d5\u05e8\u05d2\u05e9\u05d9\u05dd \u05db\u05e2\u05ea \u05d1\u05e8\u05d7\u05d5\u05d1 \u05d6'\u05d1\u05d5\u05d8\u05d9\u05e0\u05e1\u05e7\u05d9 \u05d5\u05d4\u05d0\u05d6\u05d5\u05e8, \u05d5\u05d1\u05db\u05d1\u05d9\u05e9 4 \u05dc\u05db\u05d9\u05d5\u05d5\u05df \u05d3\u05e8\u05d5\u05dd, \u05d1\u05e2\u05e7...", "*\u05e8\u05e2\u05d1\u05d9\u05e9\u05e2 \u05e1\u05e7\u05d5\u05e4\u05d9\u05dd*", "\ud83c\udfac *\u05dc\u05d0 \u05ea\u05e2\u05d5\u05e3 \u05dc\u05d1\u05d3, \u05e1\u05d5\u05d3 \u05d4\u05d4\u05e0\u05d4\u05d2\u05d4 \u05d1\u05dc\u05d4\u05e7* \ud83e\udd85", "\ud83d\uddbc \u05d0\u05d5\u05e8 \u05e8\u05d1\u05d9\u05d3", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d9\u05e2\u05e7\u05d1 \u05d4\u05e8\u05e9\u05e7\u05d5\u05d1\u05d9\u05e5 | Yaakov hershkowitz", "\ud83c\udfac \u05d4\u05e4\u05e2\u05dc\u05ea \u05de\u05e2\u05e8\u05db\u05ea \u05d4\u05d4\u05d2\u05e0\u05d4 \u05d4\u05d0\u05d5\u05d5\u05d9\u05e8\u05d9\u05ea C-RAM \u05d4\u05dc\u05d9\u05dc\u05d4 \u05d1\u05e7\u05d5\u05e0\u05e1\u05d5\u05dc\u05d9\u05d4 \u05d4\u05d0\u05de\u05e8\u05d9\u05e7\u05e0\u05d9\u05ea \u05d1\u05d0\u05e8\u05d1\u05d9\u05dc \u05d1\u05e6\u05e4\u05d5\u05df \u05e2\u05d9\u05e8\u05d0\u05e7", "*\u05de\u05e0\u05e1\u05d9\u05dd \u05dc\u05d4\u05e9\u05e4\u05d9\u05e2 \u05e2\u05dc \u05d4\u05d3\u05e2\u05ea \u05e7\u05d4\u05dc \u05d4\u05d0\u05de\u05e8\u05d9\u05e7\u05d0\u05d9*", "*\u05e8\u05d0\u05e9 \u05e2\u05d9\u05e8\u05d9\u05d9\u05ea \u05e0\u05d9\u05d5 \u05d9\u05d5\u05e8\u05e7 \u05de\u05d7\u05e4\u05e9 \u05e1\u05d5\u05dc\u05dd \u05dc\u05e8\u05d3\u05ea \u05de\u05f4\u05d4\u05d1\u05d8\u05d7\u05ea \u05d4\u05de\u05e2\u05e6\u05e8\u05f4 \u05e0\u05d2\u05d3 \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05d1\u05d0\u05d5\u05f4\u05dd:*", "\u05de\u05d1\u05d6\u05e7\u05df 12", "\ud83d\uddbc \u05d4\u05e4\u05e8\u05e9\u05df \u05d4\u05e6\u05d1\u05d0\u05d9 \u05e9\u05dc \u05d4\u05d0\u05e8\u05e5 \u05e2\u05de\u05d5\u05e1 \u05d4\u05e8\u05d0\u05dc: \u05d9\u05e9 \u05e1\u05d5\u05d1\u05e8\u05d9\u05dd \u05db\u05d9 \u05d0\u05e8\u05d4\u05f4\u05d1 \u05de\u05ea\u05db\u05e0\u05e0\u05ea \u05e4\u05e2\u05d5\u05dc\u05d4 \u05e7\u05e8\u05e7\u05e2\u05d9\u05ea \u05d1\u05d0\u05d9\u05e8\u05d0\u05df", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05de\u05e9\u05d4 \u05d5\u05d9\u05e1\u05d1\u05e8\u05d2", "\ud83d\uddbc *\u05d7\u05d9\u05d6\u05d5\u05e7 \u05d9\u05d5\u05de\u05d9 - \u05d4' \u05d0\u05d1*", "\ud83d\uddbc \u05d4\u05d5\u05d5\u05dc \u05e1\u05d8\u05e8\u05d9\u05d8 \u05d2'\u05d5\u05e8\u05e0\u05dc: \u05d9\u05e9\u05e8\u05d0\u05dc \u05d4\u05e9\u05e7\u05d9\u05e2\u05d4 50 \u05de\u05d9\u05dc\u05d9\u05d5\u05df \u05d3\u05d5\u05dc\u05e8 \u05d1\u05e4\u05e8\u05d5\u05d9\u05e7\u05d8 \u05dc\u05d4\u05e9\u05e4\u05e2\u05d4 \u05e2\u05dc \u05d3\u05e2\u05ea \u05d4\u05e7\u05d4\u05dc \u05d1\u05d0\u05e8\u05d4\"\u05d1.", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05e8\u05e5 \u05d1\u05e8\u05e9\u05ea \u05e1\u05e8\u05d8\u05d5\u05df \u05e4\u05d9\u05d9\u05e7 \u05e9\u05e0\u05d5\u05e6\u05e8 \u05e2\u05dc \u05d9\u05d3\u05d9 AI \u05d5\u05db\u05d3\u05d5\u05de\u05d4. \u05db\u05d0\u05d9\u05dc\u05d5 \u05d4\u05ea\u05e4\u05d5\u05e6\u05e5 \u05d4\u05d2\u05e0\u05e8\u05d8\u05d5\u05e8 \u05e9\u05dc \u05d4\u05e8\u05d1 \u05d1\u05e8\u05d5...", "\ud83d\uddbc \u05e9\u05e8 \u05d4\u05ea\u05e7\u05e9\u05d5\u05e8\u05ea \u05e9\u05dc\u05de\u05d4 \u05e7\u05e8\u05e2\u05d9 \u05e0\u05d2\u05d3 \u05d1\u05d2\"\u05e5, \u05dc\u05d0\u05d7\u05e8 \u05e9\u05d4\u05d5\u05e6\u05d9\u05d0 \u05e6\u05d5 \u05d0\u05e8\u05e2\u05d9 \u05e0\u05d2\u05d3 \u05d7\u05d5\u05e7 \u05d4\u05ea\u05e7\u05e9\u05d5\u05e8\u05ea, \u05d4\u05de\u05e2\u05db\u05d1 \u05d0\u05ea \u05db\u05e0\u05d9\u05e1...", "*\u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05e1\u05e7\u05d5\u05e4\u05d9\u05dd*", "\u05dc\u05e7\u05d9\u05d9\u05dd \u05d1\u05e0\u05d5 \u05d7\u05db\u05de\u05d9 \u05d9\u05e9\u05e8\u05d0\u05dc : \u05d4\u05e6\u05d9\u05d1\u05d5\u05e8 \u05e0\u05e7\u05e8\u05d0 \u05dc\u05d4\u05ea\u05e4\u05dc\u05dc \u05d5\u05dc\u05d4\u05e2\u05d8\u05d9\u05e8 \u05d1\u05ea\u05e4\u05d9\u05dc\u05d4 \u05dc\u05e8\u05e4\u05d5\u05d0\u05ea\u05d5 \u05d4\u05e9\u05dc\u05d9\u05de\u05d4 \u05e9\u05dc \u05d4\u05d2\u05d0\u05d5\u05df \u05d4...", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d9\u05e9\u05e8\u05d0\u05dc \u05db\u05d4\u05df", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05e9\u05d9\u05dc\u05d4 \u05e4\u05e8\u05d9\u05d3\ud83c\uddee\ud83c\uddf1", "\u05d0\u05d2\u05d5\u05d3\u05ea \u05d4\u05e2\u05d9\u05ea\u05d5\u05e0\u05d0\u05d9\u05dd \u05d1\u05de\u05e6\u05e8\u05d9\u05dd \u05d4\u05d7\u05dc\u05d9\u05d8\u05d4 \u05dc\u05e4\u05ea\u05d5\u05d7 \u05d1\u05d7\u05e7\u05d9\u05e8\u05d4 \u05d5\u05dc\u05d0\u05e1\u05d5\u05e8 \u05e2\u05dc \u05de\u05d2\u05d9\u05e9 \u05d7\u05d3\u05e9\u05d5\u05ea \u05dc\u05d4\u05d5\u05e4\u05d9\u05e2 \u05d1\u05db\u05dc\u05d9 \u05d4\u05ea\u05e7\u05e9\u05d5...", "\u05d7\u05d9\u05dc \u05d4\u05d0\u05d5\u05d5\u05d9\u05e8 \u05e9\u05dc \u05d0\u05d5\u05e7\u05e8\u05d0\u05d9\u05e0\u05d4 \u05d4\u05e4\u05d9\u05dc \u05d4\u05dc\u05d9\u05dc\u05d4 18 \u05de\u05ea\u05d5\u05da 41 \u05d8\u05d9\u05dc\u05d9\u05dd \u05e9\u05e9\u05d9\u05d2\u05e8\u05d4 \u05e8\u05d5\u05e1\u05d9\u05d4 \u2022 \u05e9\u05e8 \u05d4\u05d7\u05d5\u05e5 \u05d4\u05d0\u05d5\u05e7\u05e8\u05d0\u05d9\u05e0\u05d9: ...", "\u05d9\u05ea\u05db\u05df \u05d5\u05d0\u05dc\u05e4\u05d9 \u05d7\u05e1\u05d9\u05d3\u05d9 \u05d2\u05d5\u05e8 \u05d9\u05e6\u05d0\u05d5 \u05e9\u05d5\u05d1 \u05dc\u05d4\u05e4\u05d2\u05d9\u05df \u05de\u05d5\u05dc \u05db\u05dc\u05d0 10 \u05d1\u05e2\u05e7\u05d1\u05d5\u05ea \u05de\u05e2\u05e6\u05e8 \u05d1\u05d7\u05d5\u05e8 \u05de\u05d9\u05e9\u05d9\u05d1\u05ea \u05f3\u05e9\u05e4\u05ea \u05d0\u05de\u05ea\u05f3. \u05d4...", "\ud83d\uddbc \u05ea\u05d7\u05e8\u05d5\u05ea \u05d4\u05f3\u05de\u05d5\u05e0\u05d3\u05d9\u05e6\u05d4\u05f4\u05dc\u05f3 \u05de\u05d2\u05d9\u05e2\u05d4 \u05dc\u05e1\u05d9\u05d5\u05de\u05d4! \u05d5\u05d9\u05e9 \u05dc\u05db\u05dd \u05d4\u05d6\u05d3\u05de\u05e0\u05d5\u05ea \u05dc\u05d4\u05e9\u05e4\u05d9\u05e2\ud83e\udd29", "\ud83c\udfac \u05e8\u05d5\u05d7 \u05d4\u05e7\u05d5\u05d3\u05e9 \u05d5\u05e7\u05d3\u05d5\u05e9\u05d4 \u05e9\u05e2\u05d8\u05d5\u05e4\u05d4 \u05d1\u05d0\u05e0\u05d5\u05e9\u05d9\u05d5\u05ea: \u05de\u05d9 \u05d4\u05d9\u05d4 \u05d4\u05d0\u05e8\"\u05d9 \u05d4\u05e7\u05d3\u05d5\u05e9?", "\ud83d\uddbc \u05d3\u05e8\u05de\u05d4 \u05d1\u05e2\u05d9\u05e8\u05d9\u05d9\u05ea \u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7: \u05d1\u05de\u05d4\u05dc\u05da \u05d4\u05dc\u05d9\u05dc\u05d4 \u05d0\u05d9\u05e8\u05e2\u05d4 \u05e4\u05e8\u05d9\u05e6\u05d4 \u05dc\u05d1\u05e0\u05d9\u05d9\u05df \u05d4\u05e2\u05d9\u05e8\u05d9\u05d9\u05d4. \u05e2\u05dc \u05e4\u05d9 \u05d4\u05de\u05d9\u05d3\u05e2 \u05d4\u05e8\u05d0\u05e9\u05d5\u05e0...", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d4\u05d9\u05d5\u05e2\u05e5 \u05d4\u05d0\u05e1\u05d8\u05e8\u05d8\u05d2\u05d9 \u05d0\u05d1\u05d9\u05e0\u05d5\u05e2\u05dd \u05e7\u05d5\u05d8\u05e9\u05e8 \u05d1\u05ea\u05d5\u05db\u05e0\u05d9\u05ea \u05db\u05d9\u05e4\u05d5\u05ea \u05e9\u05d7\u05d5\u05e8\u05d5\u05ea \u05d1\u05e2\u05d9\u05de\u05d5\u05ea \u05e2\u05dd \u05ea\u05d5\u05de\u05e8 \u05d0\u05d1\u05d9\u05d8\u05dc ...", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d3\u05e8\u05d5\u05dd \u05e6'\u05d9\u05dc\u05d4. \u05e6\u05d1\u05d9\u05e2\u05ea \u05d3\u05d2\u05d9\u05dd \u05dc\u05e6\u05d1\u05e2 \u05d4\u05e1\u05dc\u05de\u05d5\u05df \u05d4\u05de\u05d1\u05d5\u05e7\u05e9", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d4\u05d2\u05e0\u05e8\u05d8\u05d5\u05e8 \u05dc\u05d0 \u05d4\u05ea\u05e4\u05d5\u05e6\u05e5. \u05d4\u05d9\u05e9\u05d9\u05d1\u05d4 \u05d4\u05d5\u05e6\u05d9\u05d0\u05d4 \u05e1\u05e8\u05d8\u05d5\u05df \u05e9\u05de\u05db\u05d7\u05d9\u05e9 \u05d0\u05ea \u05e1\u05e8\u05d8\u05d5\u05df \u05d4AI", "\u05d1\u05db\u05d9\u05e8\u05d9\u05dd \u05d1\u05de\u05e4\u05dc\u05d2\u05d5\u05ea \u05d4\u05d7\u05e8\u05d3\u05d9\u05d5\u05ea \u05e0\u05d2\u05d3 \u05e1\u05de\u05d5\u05d8\u05e8\u05d9\u05e5': \"\u05db\u05e9\u05d1\u05d2\"\u05e6 \u05de\u05e7\u05e4\u05d9\u05d0 \u05d0\u05ea \u05d7\u05d5\u05e7 \u05d4\u05ea\u05e7\u05e9\u05d5\u05e8\u05ea \u05d4\u05d5\u05d0 \u05d6\u05d5\u05e2\u05dd \u05d5\u05de\u05e9\u05ea\u05d5\u05dc\u05dc, ...", "\u05d1\u05d7\u05e1\u05d9\u05d3\u05d5\u05ea \u05d2\u05d5\u05e8 \u05e0\u05e2\u05e8\u05db\u05d9\u05dd \u05dc\u05e7\u05d9\u05d9\u05dd \u05e2\u05e6\u05e8\u05ea \u05de\u05d7\u05d0\u05d4 \u05e0\u05d5\u05e1\u05e4\u05ea \u05de\u05d5\u05dc \u05db\u05dc\u05d0 10 \u05d1\u05d2\u05dc\u05dc \u05de\u05e2\u05e6\u05e8\u05d5 \u05e9\u05dc \u05d1\u05d7\u05d5\u05e8 \u05de\u05d4\u05d7\u05e1\u05d9\u05d3\u05d5\u05ea. \u05d0\u05ea\u05de...", "\ud83d\uddbc \u05d1\u05d9\u05df \u05d4\u05d6\u05de\u05e0\u05d9\u05dd - \u05d1\u05d9\u05df \u05d4\u05d2\u05dc\u05d9\u05dd", "\u05d0\u05d5\u05e8 \u05e8\u05d1\u05d9\u05d3", "\ud83c\udfac \u05e1\u05d9\u05e8\u05d8\u05d5\u05df \u05e9\u05e8\u05e5 \u05d1\u05e8\u05e9\u05ea \u05e9\u05d4\u05ea\u05e4\u05d5\u05e6\u05e5 \u05d4\u05dc\u05d5\u05d7 \u05d7\u05e9\u05de\u05dc \u05d0\u05e6\u05dc \u05d4\u05e8\u05d1 \u05d1\u05e8\u05d5\u05d5\u05e8\u05de\u05df \u05d4\u05d9\u05e0\u05d5 \u05d1\u05d0\u05de\u05e6\u05e2\u05d5\u05ea \u05d1\u05d9\u05e0\u05d4 \u05de\u05dc\u05d0\u05db\u05d5\u05ea\u05d9\u05ea", "\ud83d\uddbc \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d1\u05d6\u05d1\u05d5\u05d6 \u05e6\u05d5\u05d5\u05d9 8 \u05d1\u05e6\u05d1\u05d0?", "\ud83d\uddbc \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d4\u05ea\u05e2\u05dc\u05d5\u05de\u05d4 \u05d1\u05e4\u05ea\u05d7 \u05ea\u05e7\u05d5\u05d5\u05d4 \u05dc\u05e4\u05e0\u05d9 \u05e4\u05ea\u05e8\u05d5\u05df. \u05d4\u05e7\u05d5\u05e8\u05e2 \u05d4\u05e1\u05d3\u05e8\u05ea\u05d9 \u05e9\u05dc \u05de\u05d5\u05d3\u05e2\u05d5\u05ea \u05d4\u05e2\u05d9\u05e8\u05d9\u05d9\u05d4 \u05d5\u05dc\u05d1 \u05d4\u05e9\u05d8\u05e2\u05d8...", "\u05d8\u05e8\u05d2\u05d3\u05d9\u05d4: \u05e8' \u05d0\u05dc\u05d9\u05d4\u05d5 \u05d9\u05e9\u05e8\u05d0\u05dc \u05d0\u05d1\u05d0 \u05e9\u05d0\u05d5\u05dc (59) \u05d0\u05d1 \u05dc-9 \u05d9\u05dc\u05d3\u05d9\u05dd \u05de\u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7, \u05e0\u05e4\u05d8\u05e8 \u05de\u05d3\u05d5\u05dd \u05dc\u05d1 \u05d1\u05de\u05d4\u05dc\u05da \u05d8\u05d9\u05d5\u05dc \u05de\u05e9\u05e4\u05d7...", "\ud83d\uddbc \u05e9\u05d9\u05dc\u05d4 \u05e4\u05e8\u05d9\u05d3\ud83c\uddee\ud83c\uddf1 \u05de\u05d2\u05d9\u05d1 \u05dc-\u05e9\u05d9\u05dc\u05d4 \u05e4\u05e8\u05d9\u05d3\ud83c\uddee\ud83c\uddf1", "\ud83d\uddbc \"\u05d2\u05d6\u05e2\u05df! \u05ea\u05df \u05dc\u05e0\u05d5 \u05dc\u05e2\u05d1\u05d5\u05d3!\": \u05d4\u05e4\u05dc\u05e1\u05d8\u05d9\u05e0\u05d9\u05dd \u05d1\u05d9\u05d5\"\u05e9 \u05d6\u05d5\u05e2\u05de\u05d9\u05dd \u05e2\u05dc \u05d4\u05d7\u05dc\u05d8\u05ea \u05e9\u05e8 \u05d4\u05db\u05dc\u05db\u05dc\u05d4 \u05e0\u05d9\u05e8 \u05d1\u05e8\u05e7\u05ea \u05dc\u05d4\u05d1\u05d9\u05d0 \u05de\u05db...", "\ud83d\uddbc \u05d1\u05d0\u05d9\u05e8\u05d0\u05df \u05de\u05d3\u05d5\u05d5\u05d7\u05d9\u05dd \u05e9\u05d4\u05e4\u05d9\u05dc\u05d5 \u05de\u05dc\"\u05d8 \u05d0\u05de\u05e8\u05d9\u05e7\u05e0\u05d9 \u05de\u05e1\u05d5\u05d2 MQ-9 \u05d1\u05e9\u05de\u05d9 \u05de\u05d7\u05d5\u05d6 \u05d0\u05d4\u05d5\u05d5\u05d0\u05d6", "\ud83d\uddbc", "\ud83c\udfac \ud83c\udfa4 \u05e8\u05d5\u05e6\u05d9\u05dd \u05dc\u05e2\u05e9\u05d5\u05ea \u05e9\u05d1\u05ea \u05e2\u05dd \u05d0\u05d1\u05e8\u05d4\u05dd \u05e4\u05e8\u05d9\u05d3 \u05d5\u05d9\u05d5\u05d0\u05dc\u05d9 \u05d3\u05d9\u05e7\u05de\u05df?", "\u05d2\u05d5\u05dc\u05e9\u05d9\u05dd \u05e8\u05d1\u05d9\u05dd \u05d1\u05e8\u05d7\u05d1\u05d9 \u05d4\u05e2\u05d5\u05dc\u05dd \u05de\u05d3\u05d5\u05d5\u05d7\u05d9\u05dd \u05d1\u05e9\u05e2\u05d4 \u05d4\u05d0\u05d7\u05e8\u05d5\u05e0\u05d4 \u05e2\u05dc \u05ea\u05e7\u05dc\u05d5\u05ea \u05d1\u05d2\u05d9\u05e9\u05d4 \u05dc\u05e8\u05e9\u05ea \u05d4\u05d7\u05d1\u05e8\u05ea\u05d9\u05ea \u05e4\u05d9\u05d9\u05e1\u05d1\u05d5\u05e7. ...", "\ud83c\udfac \u05de\u05d4 \u05e8\u05d0\u05d9\u05e0\u05d5 \u05e4\u05d4?", "\u05d4\u05e2\u05e8\u05d9\u05e0\u05d2 \u05d1\u05e4\u05e8\u05e9\u05e0\u05d5\u05ea: \u05d1\u05e6\u05dc \u05d4\u05d3\u05d9\u05d5\u05d5\u05d7 \u05e9\u05dc\u05e0\u05d5 \u05d0\u05de\u05e9 \u05e2\u05dc \u05de\u05d7\u05d0\u05ea \u05d7\u05e1\u05d9\u05d3\u05d5\u05ea \u05d2\u05d5\u05e8 \u05d5\u05e4\u05d2\u05d9\u05e9\u05ea \u05d4\u05d0\u05d3\u05de\u05d5\"\u05e8 \u05e2\u05dd \u05e9\u05dc\u05d9\u05d7 \u05d1\u05d9\"\u05d3 \u05e9...", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d7\u05e8\u05d3\u05d9\u05dd10", "\ud83d\uddbc \u05e8\u05d0\u05e9 \u05d3\u05e1\u05e7 12", "\u05d4\u05d0\u05d3\u05de\u05d5\u201d\u05e8 \u05de\u05d2\u05d5\u05e8 \u05e0\u05e4\u05d2\u05e9 \u05d0\u05de\u05e9 \u05e2\u05dd \u05d0\u05d9\u05e9 \u05d4\u05e2\u05d3\u05d4 \u05d4\u05d7\u05e8\u05d3\u05d9\u05ea \u05e8' \u05e9\u05de\u05e2\u05d5\u05df \u05e9\u05d9\u05e9\u05d0 \u05e9\u05e4\u05d5\u05e2\u05dc \u05dc\u05d8\u05d5\u05d1\u05ea \u05d0\u05e1\u05d9\u05e8\u05d9 \u05e2\u05d5\u05dc\u05dd \u05d4\u05ea\u05d5\u05e8\u05d4...", "\ud83d\uddbc \u05d7\u05e9\u05d9\u05e4\u05d4 \u05e8\u05d0\u05e9\u05d5\u05e0\u05d4 \u05d5\u05d3\u05e8\u05de\u05d8\u05d9\u05ea \u05d1\u05ea\u05e2\u05e8\u05d5\u05db\u05ea \u05d4\u05d9\u05db\u05dc\u05d5\u05ea - \u05db\u05d9\u05e1\u05d5\u05d9 \u05d4\u05d7\u05dc\u05d5\u05ea \u05e9\u05dc \u05d0\u05d3\u05de\u05d5\"\u05e8\u05d9 \u05d1\u05d9\u05ea \u05d2\u05d5\u05e8: \u05de\u05e4\u05d9\u05ea \u05d4\u05d7\u05dc\u05d5\u05ea ...", "\u05d4\u05e2\u05e8\u05d9\u05e0\u05d2 \u05de\u05d3\u05d5\u05d5\u05d7 \u05e2\u05dc \u05e1\u05e2\u05e8\u05d4 \u05d1\u05d0\u05dc\u05e2\u05d3: \u05de\u05e0\u05d4\u05dc \u05de\u05d5\u05e1\u05d3\u05d5\u05ea \u05d0\u05e8\u05d7\u05d5\u05ea \u05ea\u05d5\u05e8\u05d4 \u05d4\u05d6\u05d4\u05d9\u05e8 \u05db\u05d9 \u05d0\u05dd \u05e2\u05d9\u05e8\u05d9\u05d9\u05ea \u05d0\u05dc\u05e2\u05d3 \u05dc\u05d0 \u05ea\u05de\u05e9\u05d5\u05da...", "\u21a9\ufe0f\ud83c\udfac \u05d4\u05d2\u05e0\u05e8\u05d8\u05d5\u05e8 \u05e2\u05d1\u05d3 \u05de\u05e6\u05d5\u05d9\u05df. \u05d6\u05d4 \u05d4\u05e1\u05e8\u05d8\u05d5\u05df \u05d4\u05de\u05e7\u05d5\u05e8\u05d9 \u05d1\u05dc\u05d9 \u05e2\u05e8\u05d9\u05db\u05d4 \u05e9\u05dc \u05d2\u05d9\u05de\u05e0\u05d9.", "\ud83c\udfac \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d9\u05e7\u05d9 \u05d0\u05d3\u05de\u05e7\u05e8", "\u05e2\u05d5\u05d3 \u05e2\u05dc \u05d4\u05e4\u05e8\u05d9\u05e6\u05d4 \u05d1\u05e2\u05d9\u05e8\u05d9\u05d9\u05ea \u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7: \u05dc\u05e4\u05e0\u05d9 \u05e9\u05d1\u05d5\u05e2 \u05d4\u05d9\u05d9\u05ea\u05d4 \u05e4\u05e8\u05d9\u05e6\u05d4 \u05e0\u05d5\u05e1\u05e4\u05ea \u05d1\u05d7\u05d3\u05e8\u05d5 \u05e9\u05dc \u05d9\u05d5\u05e2\u05e5 \u05d4\u05de\u05e0\u05db\"\u05dc \u05de\u05e0\u05d3...", "\ud83d\uddbc *\u05d0\u05d6\u05d4\u05e8\u05ea \u05de\u05e4\u05e7\u05d3 \u05de\u05d8\u05d4 \u05d7\u05f3\u05d0\u05ea\u05dd \u05d0\u05dc\u05be\u05d0\u05e0\u05d1\u05d9\u05d0\u05d0 \u05dc\u05d0\u05e8\u05e6\u05d5\u05ea \u05d4\u05d1\u05e8\u05d9\u05ea:*", "*\u05e8\u05d0\u05e9 \u05de\u05db\u05d5\u05df \u05e8\u05d9\u05e4\u05de\u05df, \u05d7\u05d2\u05d9 \u05e8\u05d6\u05e0\u05d9\u05e7 \u05d1\u05e8\u05d3\u05d9\u05d5 \u05d3\u05e8\u05d5\u05dd*:", "*\u05d4\u05d1\u05d7\u05d9\u05e8\u05d5\u05ea \u05dc\u05de\u05e0\u05d4\u05d9\u05d2 \u05d7\u05de\u05d0\u05e1:*", "\u21a9\ufe0f\ud83c\udfac \u05e8\u05e6\u05d5\u05e2\u05ea \u05e2\u05d6\u05d4: \u05d4\u05de\u05d0\u05dd \u05e0\u05e1\u05de\u05d0\u05df, \u05d0\u05d7\u05d9\u05d5 \u05e9\u05dc \u05d0\u05d3\u05d4\u05dd \u05e0\u05e1\u05de\u05d0\u05df\u261d\ufe0f, \u05de\u05d7\u05d1\u05dc \u05d7\u05de\u05d0\u05e1 \u05d4\u05d1\u05db\u05d9\u05e8 \u05e9\u05d7\u05d5\u05e1\u05dc \u05d0\u05ea\u05de\u05d5\u05dc \u05d1\u05ea\u05e7\u05d9\u05e4...", "\u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05de\u05e9\u05ea\u05de\u05e9\u05d9\u05dd \u05d1\u05e8\u05d7\u05d1\u05d9 \u05d4\u05e2\u05d5\u05dc\u05dd \u05de\u05d3\u05d5\u05d5\u05d7\u05d9\u05dd \u05e2\u05dc \u05ea\u05e7\u05dc\u05d4 \u05d1\u05e4\u05d9\u05d9\u05e1\u05d1\u05d5\u05e7 \u05d5\u05d1\u05d0\u05d9\u05e0\u05e1\u05d8\u05d2\u05e8\u05dd", "\ud83d\uddbc \u05e0\u05e9\u05d9\u05d0 \u05dc\u05d1\u05e0\u05d5\u05df \u05d2'\u05d5\u05d6\u05e3 \u05e2\u05d5\u05df \u05e0\u05d7\u05ea \u05d4\u05d1\u05d5\u05e7\u05e8 \u05e2\u05dd \u05d0\u05e9\u05ea\u05d5 \u05d1\u05d0\u05e8\u05d4\"\u05d1, \u05dc\u05e7\u05e8\u05d0\u05ea \u05d4\u05e4\u05d2\u05d9\u05e9\u05d4 \u05e2\u05dd \u05d8\u05e8\u05d0\u05de\u05e4 \u05de\u05d7\u05e8.", "\ud83d\uddbc \u05d0\u05e8\u05d4\"\u05d1 \u05de\u05e4\u05e0\u05d4 \u05de\u05d8\u05d5\u05e1\u05d9 \u05ea\u05d3\u05dc\u05d5\u05e7 \u05de\u05d1\u05e1\u05d9\u05e1 \u05d0\u05dc\u05e2\u05d5\u05d3\u05d9\u05d3 \u05d1\u05e7\u05d8\u05e8 \u05dc\u05d1\u05e1\u05d9\u05e1 \u05e2\u05d5\u05d1\u05d3\u05d4 \u05d1\u05d9\u05e9\u05e8\u05d0\u05dc - \u05d6\u05d0\u05ea \u05db\u05d3\u05d9 \u05dc\u05d4\u05e7\u05d8\u05d9\u05df \u05e1\u05d9...", "\u05e9\u05e8\u05d5\u05df \u05e7\u05e0\u05d5\u05d1\u05dc\u05d9\u05da", "\ud83c\udfac \u05d5\u05d6\u05d4 \u05d4\u05e1\u05e8\u05d8\u05d5\u05df \u05d4\u05d0\u05d5\u05e8\u05d2\u05d9\u05e0\u05dc \u05e9\u05dc \u05d4\u05d2\u05e0\u05e8\u05d8\u05d5\u05e8 \u05e9\u05e2\u05d1\u05d3 \u05e4\u05d9\u05e7\u05e1.", "\ud83d\uddbc \u05e1\u05e2\u05e8\u05d4 \u05d1\u05de\u05e6\u05e8\u05d9\u05dd \u05d1\u05e2\u05e7\u05d1\u05d5\u05ea \u05e8\u05d9\u05d0\u05d9\u05d5\u05df \u05e9\u05d4\u05e2\u05e0\u05d9\u05e7 \u05d4\u05e2\u05d9\u05ea\u05d5\u05e0\u05d0\u05d9 \u05d4\u05d9\u05e9\u05e8\u05d0\u05dc\u05d9 \u05d2\u05d3\u05e2\u05d5\u05df \u05dc\u05d5\u05d9 \u05dc\u05e2\u05e8\u05d5\u05e5 \u05d4\u05d8\u05dc\u05d5\u05d5\u05d9\u05d6\u05d9\u05d4 \u05d4\u05de...", "\u05de\u05e7\u05d5\u05e8 \u05d1\u05d9\u05d8\u05d7\u05d5\u05e0\u05d9 \u05d9\u05e9\u05e8\u05d0\u05dc\u05d9 \u05de\u05e1\u05e8 \u05dc\u05e2\u05e8\u05d5\u05e5 \u05d0\u05dc\u05d7\u05d3\u05ea\u05f3 \u05d4\u05e1\u05e2\u05d5\u05d3\u05d9, \u05db\u05d9 \u05de\u05d5\u05d2'\u05ea\u05d1\u05d0 \u05d7\u05f3\u05d0\u05de\u05e0\u05d0\u05d9 \u05dc\u05d0 \u05e0\u05de\u05e6\u05d0 \u05d1\u05d0\u05d9\u05e8\u05d0\u05df, \u05d5\u05d0\u05ea...", "\u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05e0\u05d9\u05e6\u05d7\u05d5\u05df \u05dc\u05de\u05d5\u05e2\u05e6\u05d4 \u05d4\u05de\u05e7\u05d5\u05de\u05d9\u05ea \u05e7\u05e8\u05d9\u05ea \u05d9\u05e2\u05e8\u05d9\u05dd, \u05dc\u05d0\u05d7\u05e8 \u05e9\u05d1\u05d9\u05ea \u05d4\u05de\u05e9\u05e4\u05d8 \u05d4\u05d5\u05e8\u05d4 \u05d4\u05d1\u05d5\u05e7\u05e8 \u05e2\u05dc \u05de\u05d7\u05d9\u05e7\u05ea \u05ea\u05d1\u05d9\u05e2...", "\ud83c\udfac \u05ea\u05e7\u05d9\u05e4\u05d4 \u05d0\u05d5\u05e7\u05e8\u05d0\u05d9\u05e0\u05d9\u05ea \u05d1\u05de\u05d5\u05e1\u05e7\u05d1\u05d4 \u05db\u05e4\u05d9 \u05e9\u05ea\u05d5\u05e2\u05d3\u05d4 \u05d0\u05ea\u05de\u05d5\u05dc \u05de\u05d7\u05dc\u05d5\u05df \u05de\u05d8\u05d5\u05e1.", "\ud83d\uddbc \u05d4\u05e1\u05d9\u05e8\u05d7\u05d5\u05df \u05d7\u05d5\u05d2\u05d2: \u05d1\u05d2\u05dc\u05dc \u05d1\u05d9\u05d5\u05d1 \u05e9\u05e0\u05e4\u05ea\u05d7 \u05d1\u05e8\u05d7\u05d5\u05d1 \u05e8\u05d1\u05d9 \u05e2\u05e7\u05d9\u05d1\u05d0 \u05de\u05d5\u05dc \u05e8\u05d7\u05d5\u05d1 \u05d0\u05d7\u05d9\u05e2\u05d6\u05e8, \u05d4\u05d1\u05d9\u05d5\u05d1 \u05d6\u05d5\u05e8\u05dd \u05e2\u05d3 \u05dc\u05e8\u05d7...", "*\u05ea\u05e7\u05dc\u05d4 \u05e2\u05d5\u05dc\u05de\u05d9\u05ea \u05d1\u05e4\u05d9\u05d9\u05e1\u05d1\u05d5\u05e7 \u05d5\u05d0\u05d9\u05e0\u05e1\u05d8\u05d2\u05e8\u05dd \u05d4\u05e9\u05d9\u05d9\u05db\u05d5\u05ea \u05dc\u05de\u05d8\u05d0.*", "*\u05d4\u05d1\u05d9\u05ea \u05de\u05e9\u05e4\u05d8 \u05de\u05e9\u05d9\u05d1 \u05d8\u05d5\u05d1\u05d4 \u05ea\u05d7\u05ea \u05d8\u05d5\u05d1\u05d4 \u05d0\u05d7\u05e8\u05d9 \u05e9\u05d1\u05db\u05d9\u05e8 \u05d1\u05de\u05d5\u05e2\u05e6\u05d4 \u05d0\u05d9\u05e9\u05e8 \u05d8\u05d5\u05d1\u05d5\u05ea \u05d4\u05e0\u05d0\u05d4 \u05dc\u05e0\u05e9\u05d9\u05d0 \u05d1\u05d9\u05ea \u05d4\u05de\u05e9\u05e4\u05d8 \u05d4\u05e2\u05dc...", "\ud83d\uddbc \u05d2\u05dc\u05e2\u05d3 \u05db\u05d4\u05df: \u05d0\u05e8\u05d4\"\u05d1 \u05de\u05e4\u05e0\u05d4 \u05de\u05d8\u05d5\u05e1\u05d9 \u05ea\u05d3\u05dc\u05d5\u05e7 \u05de\u05d1\u05e1\u05d9\u05e1 \u05d0\u05dc\u05e2\u05d5\u05d3\u05d9\u05d3 \u05d1\u05e7\u05d8\u05e8 \u05dc\u05d1\u05e1\u05d9\u05e1 \u05e2\u05d5\u05d1\u05d3\u05d4 \u05d1\u05d9\u05e9\u05e8\u05d0\u05dc - \u05d6\u05d0\u05ea \u05db\u05d3\u05d9 ...", "'\u05e2\u05e8\u05d5\u05e5 7': \u05d1\u05e7\u05d3\u05d5\u05dd \u05d9\u05d9\u05e4\u05ea\u05d7 \u05d4\u05d9\u05d5\u05dd \u05de\u05e8\u05db\u05d6 \u05e9\u05d9\u05e8\u05d5\u05ea \u05d9\u05d9\u05e2\u05d5\u05d3\u05d9 \u05dc\u05ea\u05d5\u05e9\u05d1\u05d9 \u05d7\u05d5\u05d5\u05ea \u05d2\u05dc\u05e2\u05d3 \u05e9\u05e0\u05e4\u05d2\u05e2\u05d5 \u05de\u05d4\u05e9\u05e8\u05d9\u05e4\u05d4, \u05d4\u05ea\u05d5\u05e9\u05d1\u05d9...", "\u05d1\u05d0\u05d9\u05e8\u05d0\u05df \u05de\u05d3\u05d5\u05d5\u05d7\u05d9\u05dd \u05e9\u05e6\u05d1\u05d0 \u05d0\u05e8\u05d4\"\u05d1 \u05ea\u05e7\u05e3 \u05d1\u05d9\u05de\u05de\u05d4 \u05d4\u05d0\u05d7\u05e8\u05d5\u05e0\u05d4 \u05d1\u05e2\u05d9\u05e8 \u05d7'\u05d5\u05de\u05d9\u05df \u05d1\u05de\u05e8\u05db\u05d6 \u05d0\u05d9\u05e8\u05d0\u05df, \u05dc\u05d0 \u05e8\u05d7\u05d5\u05e7 \u05de\u05d4\u05e2\u05d9\u05e8 ...", "\ud83c\udfac *\u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05e1\u05e7\u05d5\u05e4\u05d9\u05dd*", "\u05d0\u05dc\u05de\u05d5\u05e0\u05d9\u05dd \u05e4\u05e8\u05e6\u05d5 \u05d4\u05dc\u05d9\u05dc\u05d4 \u05dc\u05d1\u05e0\u05d9\u05d9\u05df \u05e2\u05d9\u05e8\u05d9\u05d9\u05ea \u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7 \u05d5\u05e0\u05db\u05e0\u05e1\u05d5 \u05dc\u05de\u05e1\u05e4\u05e8 \u05de\u05e9\u05e8\u05d3\u05d9\u05dd \u05d1\u05e7\u05d5\u05de\u05d4 \u05e9\u05e0\u05d9\u05d9\u05d4 \u05d5\u05e9\u05dc\u05d9\u05e9\u05d9\u05ea. ...", "\u05d1\u05d1\u05d7\u05e8\u05d9\u05d9\u05df \u05de\u05d3\u05d5\u05d5\u05d7 \u05e2\u05dc \u05d0\u05d6\u05e2\u05e7\u05d5\u05ea \u05d1\u05e2\u05e7\u05d1\u05d5\u05ea \u05ea\u05e7\u05d9\u05e4\u05d5\u05ea \u05de\u05d0\u05d9\u05e8\u05d0\u05df. \u05dc\u05e4\u05e0\u05d9 \u05e9\u05e2\u05d4 \u05e7\u05dc\u05d4 \u05d2\u05dd \u05ea\u05e7\u05d9\u05e4\u05d5\u05ea \u05d0\u05d9\u05e8\u05d0\u05e0\u05d9\u05d5\u05ea \u05d1\u05db\u05d5\u05d5...", "\u05d1\u05d0\u05d9\u05e8\u05d0\u05df \u05d8\u05d5\u05e2\u05e0\u05d9\u05dd: \u05d4\u05e4\u05dc\u05e0\u05d5 \u05de\u05dc\"\u05d8 \u05d0\u05de\u05e8\u05d9\u05e7\u05e0\u05d9 \u05de\u05e1\u05d5\u05d2 MQ-9 \u05d1\u05e9\u05de\u05d9 \u05de\u05d7\u05d5\u05d6 \u05d0\u05d4\u05d5\u05d5\u05d0\u05d6", "\ud83c\udfac \u05e9\u05e8\u05d5\u05df \u05e7\u05e0\u05d5\u05d1\u05dc\u05d9\u05da", "\u05d3\u05e1\u05e7 \u05d4\u05d7\u05d5\u05e5"]}