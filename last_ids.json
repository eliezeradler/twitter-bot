ps://t.me/N12chat/218212"], "global_seen_titles": ["\ud83d\uddbc \u05e8\u05d5\u05e1\u05d9\u05d4 \u05d8\u05d5\u05e2\u05e0\u05ea: \u05d0\u05d5\u05e7\u05e8\u05d0\u05d9\u05e0\u05d4 \u05e9\u05d9\u05d2\u05e8\u05d4 400 \u05db\u05d8\u05d1\"\u05de\u05d9\u05dd \u05d4\u05dc\u05d9\u05dc\u05d4 \u05dc\u05e2\u05d1\u05e8 \u05de\u05d5\u05e1\u05e7\u05d1\u05d4 (\u05e2\u05de\u05d9\u05d7\u05d9 \u05e9\u05d8\u05d9\u05d9\u05df).", "\u21a9\ufe0f \u05e9\u05e0\u05d9 \u05d4\u05e4\u05dc\u05e1\u05d8\u05d9\u05e0\u05d9\u05dd \u05e9\u05e0\u05e2\u05e6\u05e8\u05d5 \u05d4\u05dd \u05d0\u05dc\u05d4 \u05e9\u05e0\u05e1\u05e2\u05d5 \u05d1\u05e8\u05db\u05d1 \u05d4\u05e4\u05dc\u05e1\u05d8\u05d9\u05e0\u05d9 \u05d1\u05d9\u05d5\u05dd \u05e9\u05d1\u05ea \u05d1\u05db\u05d1\u05d9\u05e9 55, \u05d5\u05db\u05db\u05dc \u05d4\u05e0\u05e8\u05d0\u05d4 \u05de\u05d4\u05e8...", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d7\u05d3\u05e9\u05d5\u05ea \u05d1\u05d7\u05d3\u05e8\u05d9 \u05d7\u05e8\u05d3\u05d9\u05dd", "\ud83d\uddbc \u05d4\u05d0\u05d9\u05e8\u05d5\u05e2 \u05d4\u05d4\u05d9\u05e1\u05d8\u05d5\u05e8\u05d9 : \u05d4\u05d8\u05d1\u05d7 \u05d1\u05d7\u05d9\u05d5\u05ea \u05d4\u05d1\u05e8 \u05d1\u05d6\u05d9\u05d9\u05e0\u05e1\u05d5\u05d5\u05d9\u05dc", "\u05d1\u05d5\u05e7\u05e8 \u05d8\u05d5\u05d1\u2764\ufe0f", "\u05d4\u05ea\u05d7\u05d6\u05d9\u05ea \u05dc\u05d4\u05d9\u05d5\u05dd \u05d9\u05d5\u05dd \u05e9\u05e0\u05d9: \u05d4\u05d9\u05d5\u05dd \u05d7\u05dd \u05de\u05e2\u05d8 \u05de\u05d4\u05e8\u05d2\u05d9\u05dc \u05d1\u05d4\u05e8\u05d9\u05dd \u05d5\u05d1\u05e4\u05e0\u05d9\u05dd \u05d4\u05d0\u05e8\u05e5, \u05d4\u05d1\u05d9\u05dc \u05d1\u05de\u05d9\u05e9\u05d5\u05e8 \u200f\u05d4\u05d7\u05d5\u05e3, \u05d4\u05d8\u05de\u05e4...", "\u05d7\"\u05db \u05d0\u05e8\u05d6 \u05de\u05dc\u05d5\u05dc \u05de\u05e9\"\u05e1, \u05d4\u05ea\u05d9\u05d9\u05d7\u05e1 \u05d1\u05e8\u05d0\u05d9\u05d5\u05df \u05d4\u05d1\u05d5\u05e7\u05e8 \u05dc\u05d9\u05e9\u05e8\u05d0\u05dc \u05db\u05d4\u05df \u05d1\u05ea\u05d5\u05db\u05e0\u05d9\u05ea \u05f3\u05e9\u05de\u05d5\u05e0\u05d4 \u05d0\u05e4\u05e1 \u05d0\u05e4\u05e1\u05f3 \u05d1\u05e8\u05d3\u05d9\u05d5 \u05f3\u05e7\u05d5...", "\ud83d\uddbc *\u05ea\u05d7\u05e7\u05d9\u05e8 '\u05db\u05d9\u05db\u05e8 \u05d4\u05e9\u05d1\u05ea' \u05d7\u05d5\u05e9\u05e3: \u05d1\u05d6\u05de\u05df \u05e9\u05d9\u05e9\u05d9\u05d1\u05d5\u05ea \u05e0\u05e8\u05d3\u05e4\u05d5\u05ea - \u05d7\u05e9\u05d5\u05d3\u05d9\u05dd \u05d1\u05ea\u05de\u05d9\u05db\u05d4 \u05d1\u05d8\u05e8\u05d5\u05e8 \u05de\u05e7\u05d1\u05dc\u05d9\u05dd \u05e4\u05d8\u05d5\u05e8*", "\ud83c\udfac \u05e6\u05d9\u05dc\u05d5\u05dd \u05d4\u05e8\u05d7\u05e4\u05df \u05d7\u05e9\u05e3: \u05db\u05da \u05e0\u05e8\u05d0\u05d4 \u05d8\u05e8\u05d5\u05e8 \u05d4\u05d4\u05e6\u05ea\u05d5\u05ea \u05d1\u05e9\u05d9\u05d3\u05d5\u05e8 \u05d7\u05d9", "\ud83d\uddbc \u05e1\u05d5\u05db\u05e0\u05d5\u05ea \u05d4\u05d9\u05d3\u05d9\u05e2\u05d5\u05ea \u05d4\u05d0\u05d9\u05e8\u05d0\u05e0\u05d9\u05ea \u05e4\u05d0\u05e8\u05e1: \u05d7\u05dc\u05e7\u05d9 \u05db\u05d8\u05d1\"\u05de \u05d0\u05de\u05e8\u05d9\u05e7\u05d0\u05d9 \u05de\u05e1\u05d5\u05d2 MQ-9 (\u05db - 30 \u05de\u05d9\u05dc\u05d9\u05d5\u05df \u05d3\u05d5\u05dc\u05e8) \u05e9\u05d4\u05d5\u05e4\u05dc...", "\u05e9\u05e8\u05d5\u05df \u05e7\u05e0\u05d5\u05d1\u05dc\u05d9\u05da", "\ud83d\uddbc \u05d0\u05d7\u05e8\u05d9 \u05d4\u05d5\u05d3\u05e2\u05d5\u05ea \u05d4\u05de\u05e9\u05d8\u05e8\u05d4: \u05d9\u05d5\u05e1\u05d9 \u05d3\u05d2\u05df \u05e8\u05d0\u05e9 \u05de\u05d5\u05e2\u05e6\u05ea \u05e9\u05d5\u05de\u05e8\u05d5\u05df \u05d3\u05d5\u05e8\u05e9: \"\u05dc\u05e7\u05d1\u05d5\u05e2 \u05d0\u05ea \u05d4\u05de\u05d5\u05d1\u05df \u05de\u05d0\u05dc\u05d9\u05d5 - \u05de\u05d3\u05d5\u05d1\u05e8 ...", "\ud83c\udfac \u05e9\u05d7\u05e7\u05e0\u05d9 \u05d0\u05e8\u05d2\u05e0\u05d8\u05d9\u05e0\u05d4 \u05d0\u05d9\u05d1\u05d3\u05d5 \u05d0\u05ea \u05d6\u05d4 \u05d0\u05ea\u05de\u05d5\u05dc \u05d1\u05e1\u05d5\u05e3 \u05d4\u05de\u05e9\u05d7\u05e7: \u05dc\u05d9\u05d0\u05e0\u05d3\u05e8\u05d5 \u05e4\u05e8\u05d3\u05e1 \u05d3\u05e4\u05e7 \u05de\u05db\u05d5\u05ea \u05dc\u05e9\u05d7\u05e7\u05e0\u05d9 \u05e0\u05d1\u05d7\u05e8\u05ea ...", "\ud83d\uddbc \u05de\u05d1\u05d6\u05e7\u05df 12", "\ud83d\uddbc \u05e2\u05de\u05d9\u05ea \u05e1\u05d2\u05dc: \u05d4\u05de\u05e9\u05d8\u05e8\u05d4 \u05dc\u05d5\u05e7\u05d7\u05ea \u05e6\u05e2\u05d3 \u05d0\u05d7\u05d5\u05e8\u05d4 \u05d5\u05e2\u05d5\u05e8\u05db\u05ea \u05d0\u05ea \u05d4\u05d5\u05d3\u05e2\u05ea\u05d4 \u05de\u05e0\u05e2\u05e6\u05e8\u05d5 \u05d1\u05d7\u05e9\u05d3 \u05dc\u05de\u05e2\u05d5\u05e8\u05d1\u05d5\u05ea \u05d1\u05d4\u05e6\u05ea\u05ea \u05d4\u05e9...", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d9\u05e2\u05e0\u05e7\u05d9 \u05e4\u05e8\u05d1\u05e8 | Yanki Farber", "\ud83d\uddbc \u05d5\u05d0\u05d5\u05dc\u05d9 \u05dc\u05db\u05dc \u05e8\u05db\u05d1 \u05e6\u05e8\u05d9\u05da \u05dc\u05d4\u05d9\u05d5\u05ea \u05d0\u05d5\u05e8 \u05ea\u05d5\u05d3\u05d4, \u05ea\u05d5\u05d3\u05d4 \u05dc\u05e0\u05d4\u05d2/\u05ea \u05de\u05d0\u05d7\u05d5\u05e8\u05d4 \u05e9\u05d1\u05d7\u05e8\u05d5 \u05dc\u05ea\u05ea \u05dc\u05d4\u05e9\u05ea\u05dc\u05d1..", "\u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05ea\u05d5\u05e4\u05e2\u05d4 \u05de\u05e2\u05e0\u05d9\u05d9\u05e0\u05ea: \u05e2\u05d5\u05d1\u05e8\u05d9\u05dd \u05de\u05d1\u05d9\u05ea \u05d4\u05e0\u05e9\u05d9\u05d0 \u05dc\u05d3\u05d1\u05e8\u05e8 \u05de\u05e4\u05dc\u05d2\u05d5\u05ea \u05d7\u05d3\u05e9\u05d5\u05ea", "\ud83d\uddbc \u05d8\u05e8\u05d5\u05e8 \u05d4\u05d4\u05e6\u05ea\u05d4 \u05d1\u05d7\u05d5\u05d5\u05ea \u05d2\u05dc\u05e2\u05d3 \u05d1\u05e9\u05d5\u05de\u05e8\u05d5\u05df \u05d1\u05e9\u05d1\u05ea \u05d4\u05d0\u05d7\u05e8\u05d5\u05e0\u05d4: \u05d1\u05de\u05e1\u05d2\u05e8\u05ea \u05e4\u05e2\u05d9\u05dc\u05d5\u05ea \u05de\u05e9\u05d5\u05ea\u05e4\u05ea \u05e9\u05dc \u05d4\u05d9\u05d7\u05d9\u05d3\u05d4 \u05d4\u05de\u05e8\u05db...", "\ud83d\uddbc \u05d1\u05d1\u05d5\u05e7\u05e8 \u05d4\u05e4\u05e8\u05d9\u05d9\u05de\u05e8\u05d9\u05d6 \u05d1\u05d3\u05de\u05d5\u05e7\u05e8\u05d8\u05d9\u05dd \u05d0\u05dc\u05d5\u05e3 \u05d1\u05de\u05d9\u05dc\u05f3 \u05e0\u05de\u05e8\u05d5\u05d3 \u05e9\u05e4\u05e8 \u05d1\u05de\u05d5\u05d3\u05e2\u05d4 \u05d1\u05e2\u05d9\u05ea\u05d5\u05df \u05d4\u05d0\u05e8\u05e5: \u05f4\u05dc\u05d0 \u05de\u05e4\u05d7\u05d3 \u05dc\u05d7\u05dc...", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05e9\u05d9\u05dc\u05d4 \u05e4\u05e8\u05d9\u05d3\ud83c\uddee\ud83c\uddf1", "\ud83c\udfac \u05db\u05db\u05d4 \u05d4\u05d9\u05d4 \u05e0\u05e8\u05d0\u05d4 \u05d4\u05e9\u05d5\u05e2\u05e8 \u05e9\u05dc \u05e1\u05e4\u05e8\u05d3 \u05d0\u05ea\u05de\u05d5\u05dc . \u05e1\u05e8\u05d8\u05d5\u05df \u05d1\u05d9\u05e0\u05d4 \u05de\u05dc\u05d0\u05db\u05d5\u05ea\u05d9\u05ea \u05d1\u05d4\u05d5\u05de\u05d5\u05e8 \u05d1\u05d2\u05dc\u05dc \u05e9\u05d4\u05db\u05d3\u05d5\u05e8 \u05d1\u05e7\u05d5\u05e9\u05d9 ...", "*\u200f\u05d4\u05d0\u05dd \u05d4\u05de\u05e6\u05d1 \u05d4\u05d1\u05d9\u05d8\u05d7\u05d5\u05e0\u05d9 \u05d9\u05d1\u05d8\u05dc \u05d0\u05ea \u05d4\u05e4\u05e8\u05d9\u05d9\u05de\u05e8\u05d9\u05d6 \u05d1\u05dc\u05d9\u05db\u05d5\u05d3?*", "*\u05de\u05d5\u05d4\u05dc \u05d9\u05e8\u05f4\u05e9 \u05d5\u05e8\u05d1 \u05de\u05e4\u05d5\u05e8\u05e1\u05dd*", "\ud83d\uddbc \u05e9\u05dc\u05d5\u05dd, \u05e9\u05de\u05d9 \u05e0\u05e4\u05ea\u05dc\u05d9 \u05d9\u05e4\u05d4. \u05ea\u05d5\u05e9\u05d1 \u05d7\u05d5\u05d5\u05ea \u05d2\u05dc\u05e2\u05d3", "\ud83d\uddbc \u05ea\u05d5\u05e9\u05d1\u05d9\u05dd \u05d1\u05de\u05d5\u05d3\u05d9\u05e2\u05d9\u05df \u05e2\u05d9\u05dc\u05d9\u05ea \u05d2\u05d9\u05dc\u05d5 \u05e9\u05d7\u05dc\u05e7 \u05de\u05d4\u05de\u05d5\u05e6\u05e8\u05d9\u05dd \u05d1\u05e1\u05d5\u05e4\u05e8\u05de\u05e8\u05e7\u05d8 \u05de\u05db\u05d9\u05dc\u05d9\u05dd \u05d0\u05d1\u05e7\u05ea \u05d7\u05dc\u05d1 \u05e0\u05d5\u05db\u05e8\u05d9 \u05d5\u05d1\u05d4\u05e9\u05d2...", "\ud83d\uddbc \u05d9\u05e2\u05dc \u05d0\u05d5\u05d3\u05dd", "\u05e9\u05d5\u05d7\u05d7\u05ea\u05d9 \u05e2\u05dd \u05d9\u05e0\u05d5\u05df \u05de\u05d2\u05dc \u05d5\u05e0\u05d3\u05d1 \u05e4\u05e8\u05d9 \u05e2\u05dc \u05d4\u05e4\u05e8\u05d9\u05d9\u05de\u05e8\u05d9\u05d6 \u05d1\u05dc\u05d9\u05db\u05d5\u05d3 \u05d5\u05d1\u05d3\u05de\u05d5\u05e7\u05e8\u05d8\u05d9\u05dd, \u05e2\u05dc \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05d5\u05d0\u05d9\u05d6\u05e0\u05e7\u05d5\u05d8 \u05d5\u05e2\u05dc...", "\u05e2\u05e0\u05d1\u05e8 \u05d8\u05d5\u05d9\u05d6\u05e8", "\u05d3\u05d9\u05d5\u05d5\u05d7\u05d9\u05dd: \u05e9\u05e0\u05d9 \u05d4\u05e2\u05e6\u05d5\u05e8\u05d9\u05dd \u05d1\u05d7\u05e9\u05d3 \u05dc\u05de\u05e2\u05d5\u05e8\u05d1\u05d5\u05ea \u05d1\u05e9\u05e8\u05d9\u05e4\u05d4 \u05d4\u05dd \u05e9\u05d5\u05d8\u05e8\u05d9\u05dd \u05e4\u05dc\u05e1\u05d8\u05d9\u05e0\u05d9\u05dd", "\ud83d\uddbc \u05e9\u05e8\u05d5\u05df \u05e7\u05e0\u05d5\u05d1\u05dc\u05d9\u05da", "\ud83c\udfac \u05dc\u05d5\u05d9\u05e0\u05e1\u05d5\u05df \u05e7\u05dd \u05e2\u05dc \u05e8\u05d2\u05dc \u05e9\u05de\u05d0\u05dc", "\ud83c\udfac \u05d4\u05e2\u05e8\u05d9\u05e0\u05d2: \u05e1\u05e8\u05d8\u05d5\u05df \u05d4\u05e1\u05ea\u05d4 \u05d1\u05e8\u05e9\u05ea \u05e0\u05d2\u05d3 \u05d1\u05d7\u05d5\u05e8\u05d9 \u05d9\u05e9\u05d9\u05d1\u05d4 \u05e9\u05de\u05d5\u05e6\u05d2\u05d9\u05dd \u05db\u05d1\u05d8\u05dc\u05e0\u05d9\u05dd.", "*\u05d4\u05e9\u05d5\u05d8\u05e8\u05d9\u05dd \u05d4\u05e4\u05dc0\u05d8\u05d9\u05e0\u05d9\u05dd \u05dc\u05d0 \u05d2\u05e8\u05d5\u05e2\u05d9\u05dd \u05de\u05d4\u05e0\u05d5\u05d7\u05d1\u05d5\u05ea \u05e9\u05dc \u05d7\u05de\u05d0\u05e1*", "*\u05d4\u05d0\u05dd \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05d9\u05d6\u05e8\u05d5\u05e7 \u05d0\u05ea \u05d4\u05d9\u05de\u05d9\u05df \u05d5\u05d4\u05d7\u05e8\u05d3\u05d9\u05dd \u05d5\u05d9\u05e2\u05e9\u05d4 \u05de\u05de\u05e9\u05dc\u05ea \u05d0\u05d7\u05d3\u05d5\u05ea ?*", "\u05e1\u05e4\u05d9\u05e8 \u05dc\u05d9\u05e4\u05e7\u05d9\u05df", "\ud83d\uddbc \u05d0\u05d5\u05e8 \u05e8\u05d1\u05d9\u05d3", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05de\u05e9\u05d4 \u05d5\u05d9\u05e1\u05d1\u05e8\u05d2", "\ud83d\uddbc \u05ea\u05de\u05e9\u05d9\u05db\u05d5 \u05dc\u05d4\u05d9\u05d5\u05ea \u05d8\u05d5\u05d1\u05d9\u05dd", "\ud83d\uddbc *\u05f4\u05d1\u05d0\u05d1 \u05d0\u05dc \u05d5\u05d5\u05d0\u05d3 \u05dc\u05e0\u05e6\u05d7 \u05d6\u05db\u05d5\u05e8 \u05e0\u05d0 \u05d0\u05ea \u05e9\u05de\u05d5\u05ea\u05d9\u05e0\u05d5\u05f4\ud83c\udfbc\u2026*", "\u05d7\u05de\u05d9\u05e9\u05d4 \u05d7\u05d1\u05e8\u05d9 \u05d4\u05de\u05d5\u05e2\u05e6\u05d4 \u05dc\u05d4\u05e9\u05db\u05dc\u05d4 \u05d2\u05d1\u05d5\u05d4\u05d4 \u05d4\u05ea\u05e4\u05d8\u05e8\u05d5 \u05d4\u05d1\u05d5\u05e7\u05e8 \u05d1\u05de\u05d7\u05d0\u05d4 \u05e2\u05dc \u05d4\u05e2\u05d1\u05e8\u05ea \u05d7\u05d5\u05e7 \u05d4\u05d4\u05e4\u05e8\u05d3\u05d4 \u05d4\u05de\u05d2\u05d3\u05e8\u05d9\u05ea \u05d1\u05d0\u05e7...", "\u05d9\u05e2\u05dc \u05d0\u05d5\u05d3\u05dd", "\u05de\u05e9\u05e8\u05d3 \u05d4\u05d7\u05d5\u05e5 \u05d4\u05d0\u05d9\u05e8\u05d0\u05e0\u05d9: \u05d4\u05de\u05ea\u05d5\u05d5\u05db\u05d5\u05ea \u05d4\u05d2\u05d9\u05e9\u05d5 \u05dc\u05e0\u05d5 \u05d4\u05e6\u05e2\u05d5\u05ea \u05dc\u05d4\u05e1\u05d3\u05e8\u05ea \u05d4\u05de\u05e6\u05d1 \u05de\u05d5\u05dc \u05d0\u05e8\u05d4\u05f4\u05d1", "\ud83d\uddbc \ud83c\udfae \u05d4\u05beFBI \u05e2\u05e6\u05e8 \u05e6\u05e2\u05d9\u05e8 \u05d1\u05df 21 \u05de\u05e4\u05dc\u05d5\u05e8\u05d9\u05d3\u05d4, \u05d1\u05d7\u05e9\u05d3 \u05dc\u05d4\u05e4\u05e6\u05ea \u05de\u05e9\u05d7\u05e7\u05d9\u05dd \u05e0\u05d2\u05d5\u05e2\u05d9\u05dd \u05d1\u05e0\u05d5\u05d6\u05e7\u05d4 \u05d3\u05e8\u05da Steam.", "\u05d3\u05d5\u05d1\u05e8 \u05de\u05e9\u05e8\u05d3 \u05d4\u05d7\u05d5\u05e5 \u05d4\u05d0\u05d9\u05e8\u05d0\u05e0\u05d9: \u05d1\u05d9\u05de\u05d9\u05dd \u05d4\u05d0\u05d7\u05e8\u05d5\u05e0\u05d9\u05dd \u05d4\u05de\u05d3\u05d9\u05e0\u05d5\u05ea \u05d4\u05de\u05ea\u05d5\u05d5\u05db\u05d5\u05ea \u05d4\u05e2\u05d1\u05d9\u05e8\u05d5 \u05dc\u05d8\u05d4\u05e8\u05df \u05d4\u05e6\u05e2\u05d5\u05ea \u05d5\u05d4\u05df \u05e0\u05de...", "'\u05de\u05e2\u05e8\u05d9\u05d1': \u05e9\u05d0\u05d5\u05dc \u05de\u05e8\u05d9\u05d3\u05d5\u05e8 \u05d7\u05e9\u05e3 \u05d1\u05d7\u05d5\u05d2 \u05d1\u05d9\u05ea \u05d1\u05d9\u05e8\u05d5\u05e9\u05dc\u05d9\u05dd \u05db\u05d9 \u05d0\u05e0\u05e9\u05d9 '\u05d9\u05e9\u05e8' \u05de\u05e0\u05d4\u05dc\u05d9\u05dd \u05e9\u05d9\u05d7\u05d5\u05ea \u05e2\u05dd \u05d2\u05d5\u05e8\u05de\u05d9\u05dd \u05d1\u05dc\u05d9\u05db...", "\ud83d\uddbc https://wa.me/972555627652", "\u21a9\ufe0f\ud83c\udfac \u05d1\u05e2\u05e7\u05d1\u05d5\u05ea \u05d4\u05ea\u05e7\u05d9\u05e4\u05d5\u05ea \u05d4\u05d0\u05d9\u05e8\u05d0\u05e0\u05d9\u05d5\u05ea \u05e2\u05dc \u05ea\u05d7\u05e0\u05d5\u05ea \u05d4\u05db\u05d5\u05d7 \u05d1\u05db\u05d5\u05d5\u05d9\u05ea, \u05d4\u05db\u05d5\u05d5\u05d9\u05ea\u05d9\u05dd \u05e2\u05d1\u05e8\u05d5 \u05dc\u05d4\u05e9\u05ea\u05de\u05e9 \u05d1\u05d2\u05e0\u05e8\u05d8\u05d5\u05e8\u05d9...", "\ud83c\udfac *\u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05e1\u05e7\u05d5\u05e4\u05d9\u05dd*", "\u05d0\u05e0\u05d8\u05e9\u05de\u05d9\u05d5\u05ea \u05d1\u05d9\u05e9\u05e8\u05d0\u05dc! \u05d9\u05d5\u05d0\u05dc\u05d9 \u05d1\u05e8\u05d9\u05dd: 5 \u05d7\u05d1\u05e8\u05d9 \u05d4\u05de\u05d5\u05e2\u05e6\u05d4 \u05dc\u05d4\u05e9\u05db\u05dc\u05d4 \u05d2\u05d1\u05d5\u05d4\u05d4 \u05d4\u05d5\u05d3\u05d9\u05e2\u05d5 \u05dc\u05e0\u05e9\u05d9\u05d0 \u05d4\u05e8\u05e6\u05d5\u05d2 \u05d5\u05dc\u05e9\u05e8 \u05d4\u05d7\u05d9...", "\ud83c\udfac \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d9\u05e9\u05d9 \u05db\u05d4\u05df", "\ud83c\udfac \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d9\u05e7\u05d9 \u05d0\u05d3\u05de\u05e7\u05e8", "*\u05d4\u05e4\u05d2\u05d9\u05e9\u05d4 \u05d4\u05e6\u05e4\u05d5\u05d9\u05d4 \u05de\u05d7\u05e8 \u05d1\u05d1\u05d9\u05ea \u05d4\u05dc\u05d1\u05df \u05d1\u05d9\u05df \u05e0\u05e9\u05d9\u05d0 \u05dc\u05d1\u05e0\u05d5\u05df, \u05d2'\u05d5\u05d6\u05e3 \u05e2\u05d0\u05d5\u05df \u05d5\u05e0\u05e9\u05d9\u05d0 \u05d0\u05e8\u05e6\u05d5\u05ea \u05d4\u05d1\u05e8\u05d9\u05ea \u05d3\u05d5\u05e0\u05dc\u05d3 \u05d8\u05e8\u05d0...", "\ud83c\udfac \u05d4\u05ea\u05de\u05e0\u05d5\u05df \u05d4\u05d8\u05d5\u05e8\u05e7\u05d9 \ud83c\uddf9\ud83c\uddf7", "\ud83d\uddbc \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05de\u05d4\u05d5\u05de\u05d4 \u05e2\u05dd \u05de\u05e9\u05d8\u05e8\u05d4 \u05d1\u05e9\u05d8\u05d9\u05d1\u05dc\u05da \u05d6\u05db\u05e8\u05d5\u05df \u05de\u05e9\u05d4", "\u05e2\u05d9\u05d3\u05db\u05d5\u05df \u05d7\u05e9\u05d5\u05d1:", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d0\u05d1\u05d9 \u05de\u05d5\u05e1\u05e7\u05d5\u05d1 Avi moskoff", "\u21a9\ufe0f \u05d4\u05e1\u05d9\u05d1\u05d4 \u05dc\u05ea\u05d9\u05e7\u05d5\u05df \u05d4\u05d9\u05d0 \u05e9\u05de\u05d1\u05d7\u05d9\u05e0\u05d4 \u05de\u05e9\u05e4\u05d8\u05d9\u05ea \u05d2\u05dd \u05d0\u05dd \u05de\u05e9\u05d4\u05d5 \u05dc\u05d0 \u05e0\u05e2\u05e9\u05d4 \u05d1\u05de\u05db\u05d5\u05d5\u05df \u05d4\u05d5\u05d0 \u05de\u05d5\u05d2\u05d3\u05e8 \u05d4\u05e6\u05ea\u05d4, \u05d0\u05d1\u05dc \u05d4\u05e7...", "\ud83d\uddbc \u2022 \u05d4\u05e0\u05d4\u05d2 \u05d1\u05dc\u05dd: \u05db\u05d5\u05d7\u05d5\u05ea \u05d4\u05e6\u05dc\u05d4 \u05d4\u05d5\u05d6\u05e2\u05e7\u05d5 \u05d1\u05e9\u05e2\u05d4 10:15 \u05dc\u05e8\u05d7\u05d5\u05d1 \u05d0\u05d1\u05e8\u05d1\u05e0\u05d0\u05dc \u05d1\u05e7\u05e8\u05d9\u05ea \u05d4\u05e8\u05e6\u05d5\u05d2, \u05d1\u05e2\u05e7\u05d1\u05d5\u05ea \u05d3\u05d9\u05d5\u05d5\u05d7 \u05e2\u05dc...", "\u05d4\u05e7\u05e8\u05d9\u05e1\u05d4 \u05d4\u05e6\u05e4\u05d5\u05d9\u05d4 \u05e9\u05dc \u05d4\u05d1\u05d9\u05d8\u05d5\u05d7 \u05d4\u05dc\u05d0\u05d5\u05de\u05d9, \u05de\u05d0\u05dc\u05e6\u05ea \u05d0\u05ea \u05d4\u05de\u05de\u05e9\u05dc\u05d4 \u05dc\u05de\u05e6\u05d5\u05d0 \u05de\u05e7\u05d5\u05e8\u05d5\u05ea \u05de\u05d9\u05de\u05d5\u05df \u05dc\u05d2\u05d9\u05e8\u05e2\u05d5\u05df, \u05e9\u05db\u05df \u05e7\u05e8...", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d7\u05e8\u05d3\u05d9\u05dd10", "\ud83c\udfac \u05e9\u05d7\u05e7\u05df \u05de\u05d0\u05e8\u05d2\u05e0\u05d8\u05d9\u05e0\u05d4 \u05de\u05e1\u05e8\u05d1 \u05dc\u05dc\u05d7\u05d5\u05e5 \u05d9\u05d3 \u05dc\u05d8\u05e8\u05d0\u05de\u05e4", "*\u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05e1\u05e7\u05d5\u05e4\u05d9\u05dd*", "\ud83c\udfac \u05e1\u05d5\u05e7\u05e8 '\u05d4\u05de\u05d3\u05d3' \u05d5\u05e4\u05e8\u05e9\u05df \u05d7\u05d3\u05e9\u05d5\u05ea 13 \u05de\u05e0\u05ea\u05d7: \u05dc\u05de\u05d4 \u05dc\u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05d7\u05e9\u05d5\u05d1 \u05dc\u05e9\u05db\u05e0\u05e2 \u05e9\u05d0\u05d9\u05d6\u05e0\u05e7\u05d5\u05d8 \u05d4\u05d5\u05d0 \u05e9\u05de\u05d0\u05dc.", "\ud83c\udfac \u05d1\u05db\u05d9\u05e8 \u05d4\u05d7\u05de\u05d0\u05e1, \u05d1\u05d0\u05e1\u05dd \u05e0\u05e2\u05d9\u05dd, \u05de\u05d1\u05e8\u05da \u05d0\u05ea \u05e1\u05e4\u05e8\u05d3:", "\ud83c\udfac \u05d8\u05e8\u05d0\u05de\u05e4 \u05de\u05e9\u05e7\u05d9\u05e3 \u05de\u05dc\u05de\u05e2\u05dc\u05d4 \u05e2\u05dc \u05d2\u05de\u05e8 \u05d4\u05de\u05d5\u05e0\u05d3\u05d9\u05d0\u05dc", "\ud83d\uddbc \u05d1\u05e1\u05f4\u05d3, \u05e4\u05d7\u05d7\u05d5\u05ea \u05d5\u05e6\u05d1\u05e2, \u05ea\u05d9\u05e7\u05d5\u05df \u05ea\u05d0\u05d5\u05e0\u05d5\u05ea, \u05d5\u05de\u05db\u05d5\u05e0\u05d0\u05d5\u05ea \u05e8\u05db\u05d1", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05de\u05e0\u05d9 \u05d2\u05d9\u05e8\u05d0 \u05e9\u05d5\u05e8\u05e5", "\ud83d\uddbc \u05d0\u05d1\u05d9 \u05de\u05d5\u05e1\u05e7\u05d5\u05d1 Avi moskoff \u05de\u05e6\u05d8\u05d8 \u05d0\u05ea \u05d0\u05d1\u05d9\u05d2\u05d3\u05d5\u05e8 \u05dc\u05d9\u05d1\u05e8\u05de\u05df", "\u05de\u05d1\u05d6\u05e7\u05df 12", "\ud83d\uddbc \u05d1\u05d1\u05d5\u05e7\u05e8 \u05d4\u05e4\u05e8\u05d9\u05d9\u05de\u05e8\u05d9\u05d6 \u05dc\u05de\u05e4\u05dc\u05d2\u05ea \u05d4\u05e4\u05d0\u05e9\u05d9\u05e1\u05d8\u05d9\u05dd (\u05d4\u05d3\u05de\u05d5\u05e7\u05e8\u05d8\u05d9\u05dd), \u05e0\u05de\u05e8\u05d5\u05d3 \u05e9\u05e4\u05e8 \u05d1\u05de\u05d5\u05d3\u05e2\u05d4 \u05d1\u05e2\u05d9\u05ea\u05d5\u05df \u05d4\u05d0\u05e8\u05e5: \"\u05dc\u05d0 ...", "\ud83d\uddbc \u05d1\u05d1\u05e8\u05d9\u05d8\u05e0\u05d9\u05d4 \u05de\u05de\u05ea\u05d9\u05e0\u05d9\u05dd \u05d1\u05d3\u05e8\u05d9\u05db\u05d5\u05ea \u05dc\u05d9\u05e6\u05d9\u05d0\u05ea\u05d5 \u05d4\u05d0\u05d7\u05e8\u05d5\u05e0\u05d4 \u05e9\u05dc \u05e7\u05d9\u05e8 \u05e1\u05d8\u05d0\u05e8\u05de\u05e8 \u05de\u05d4\u05d1\u05d9\u05ea \u05d1\u05d3\u05d0\u05d5\u05e0\u05d9\u05e0\u05d2 10 \u05d0\u05dc \u05d0\u05e8\u05de...", "\u05d3\u05d9\u05d5\u05d5\u05d7 \u05d3\u05e8\u05de\u05d8\u05d9: 2 \u05de\u05e7\u05d5\u05e8\u05d5\u05ea \u05e9\u05d5\u05e0\u05d9\u05dd \u05d1\u05d1\u05d9\u05ea \u05d4\u05dc\u05d1\u05df - \u05d0\u05e8\u05d4\"\u05d1 \u05e2\u05dc \u05e1\u05e3 \u05d7\u05d6\u05e8\u05d4 \u05dc\u05de\u05dc\u05d7\u05de\u05d4 \u05db\u05d5\u05dc\u05dc\u05ea \u05e2\u05dd \u05d0\u05d9\u05e8\u05d0\u05df (\u05d5\u05d5\u05e9\u05d9\u05e0...", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d9\u05e9\u05e8\u05d0\u05dc \u05db\u05d4\u05df", "\ud83d\uddbc *13 \u05d7\u05d5\u05d3\u05e9\u05d9 \u05de\u05d0\u05e1\u05e8 \u05dc\u05d1\u05df \u05d6\u05d5\u05d2\u05d4 \u05e9\u05dc \u05d9\u05d5\u05e2\u05e6\u05ea \u05d4\u05e9\u05e8\u05d4 \u05de\u05d0\u05d9 \u05d2\u05d5\u05dc\u05df*", "\u05de\u05e1\u05ea\u05de\u05df: \u05d4\u05d1\u05d7\u05d9\u05e8\u05d5\u05ea \u05d1\u05de\u05e8\u05db\u05d6 \u05d4\u05dc\u05d9\u05db\u05d5\u05d3 \u05dc\u05d0\u05d9\u05e9\u05d5\u05e8 \u05d4\u05d7\u05dc\u05d8\u05d5\u05ea \u05d5\u05e2\u05d3\u05ea \u05d4\u05d7\u05d5\u05e7\u05d4 \u05d1\u05e2\u05e0\u05d9\u05d9\u05df \u05d4\u05e4\u05e8\u05d9\u05d9\u05de\u05e8\u05d9\u05d6 \u05d9\u05ea\u05e7\u05d9\u05d9\u05de\u05d5 \u05de\u05d7\u05e8...", "\ud83d\uddbc \u05d0\u05d3\u05e8 \u05d2\u05d9\u05e6\u05d9\u05e1", "\u05d3\u05d9\u05d5\u05d5\u05d7: \u05e9\u05e0\u05d9 \u05d4\u05e2\u05e6\u05d5\u05e8\u05d9\u05dd \u05d1\u05d7\u05e9\u05d3 \u05dc\u05de\u05e2\u05d5\u05e8\u05d1\u05d5\u05ea \u05d1\u05d2\u05e8\u05d9\u05de\u05ea \u05d4\u05e9\u05e8\u05d9\u05e4\u05d4 \u05d1\u05d7\u05d5\u05d5\u05ea \u05d2\u05dc\u05e2\u05d3 \u05d4\u05dd \u05e9\u05d5\u05d8\u05e8\u05d9\u05dd \u05e4\u05dc\u05e1\u05d8\u05d9\u05e0\u05d9\u05dd. \u05d4\u05dd \u05d4...", "50,000 \u05de\u05e6\u05d1\u05d9\u05e2\u05d9\u05dd \u05e2\u05d3 \u05e2\u05ea\u05d4 \u05d1\u05d3\u05de\u05d5\u05e7\u05e8\u05d8\u05d9\u05dd, 43 \u05d0\u05d7\u05d5\u05d6 \u05d4\u05e6\u05d1\u05e2\u05d4 \u05ea\u05d5\u05da \u05e9\u05e2\u05ea\u05d9\u05d9\u05dd \u05d5\u05d7\u05e6\u05d9", "\u05e2\u05de\u05d9\u05ea \u05e1\u05d2\u05dc", "\ud83d\uddbc *\u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05e1\u05e7\u05d5\u05e4\u05d9\u05dd*", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05de\u05e9\u05d0\u05d9\u05ea \u05e4\u05d5\u05d2\u05e2\u05ea \u05d1\u05d2\u05e9\u05e8 \u05e9\u05dc \u05de\u05d2\u05d3\u05dc\u05d9 \u05e9\u05e7\u05dc \u05d1\u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7", "\ud83c\udfac \u05dc\u05d9\u05dc\u05d4 \u05ea\u05e9\u05d9\u05e2\u05d9 \u05d1\u05e8\u05e6\u05d9\u05e4\u05d5\u05ea: \u05e6\u05d1\u05d0 \u05d0\u05e8\u05d4\"\u05d1 \u05ea\u05e7\u05e3 \u05d4\u05dc\u05d9\u05dc\u05d4 \u05dc\u05d0\u05d5\u05e8\u05da \u05e9\u05e2\u05d5\u05ea \u05d1\u05d0\u05d9\u05e8\u05d0\u05df, \u05d1\u05e2\u05d9\u05e7\u05e8 \u05de\u05d8\u05e8\u05d5\u05ea \u05d1\u05de\u05e8\u05d7\u05d1 \u05de\u05e6\u05e8 ...", "\u05d4\u05e4\u05e8\u05d9\u05d9\u05de\u05e8\u05d9\u05d6 \u05dc\u05de\u05e4\u05dc\u05d2\u05ea \u05d4\u05d3\u05de\u05d5\u05e7\u05e8\u05d8\u05d9\u05dd: \u05e9\u05e2\u05ea\u05d9\u05d9\u05dd \u05d5\u05d7\u05e6\u05d9 \u05de\u05e4\u05ea\u05d9\u05d7\u05ea \u05d4\"\u05e7\u05dc\u05e4\u05d9\u05d5\u05ea\" \u05d4\u05d3\u05d9\u05d2\u05d9\u05d8\u05dc\u05d9\u05d5\u05ea. 50,000, \u05d4\u05de\u05d4\u05d5\u05d5\u05d9\u05dd ...", "\u05d2\u05d3\u05d9 \u05d0\u05d9\u05d6\u05e0\u05e7\u05d5\u05d8 \u05dc\u05d0\u05ea\u05d0\u05dc\u05d9 \u05d5\u05d0\u05d5\u05e7\u05d5: \u05f4\u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05d3\u05e8\u05e9 \u05dc\u05e7\u05e6\u05e8 \u05d0\u05ea \u05d4\u05e9\u05d9\u05e8\u05d5\u05ea \u05d4\u05e1\u05d3\u05d9\u05e8 \u05d1\u05e9\u05e0\u05d4, \u05d0\u05e0\u05d9 \u05e0\u05dc\u05d7\u05de\u05ea\u05d9 \u05e0\u05d2\u05d3 \u05d6\u05d4 ...", "*\"\u05d4\u05e4\u05e8\u05d9\u05d9\u05de\u05e8\u05d9\u05d6 \u05d1\u05de\u05e4\u05dc\u05d2\u05ea \u05d4\u05d3\u05de\u05d5\u05e7\u05e8\u05d8\u05d9\u05dd\"*", "\u05d0\u05d5\u05e8 \u05e8\u05d1\u05d9\u05d3", "\ud83d\uddbc \u05d4\u05d9\u05d5\u05e2\u05de\u05f4\u05e9\u05d9\u05ea \u05dc\u05d1\u05d2\u05f4\u05e5: \u05d1\u05df \u05d2\u05d1\u05d9\u05e8 \u05e4\u05e2\u05dc \u05dc\u05e9\u05de\u05d5\u05e8 \u05e2\u05dc \u05e9\u05dc\u05d5\u05dd \u05d4\u05de\u05e4\u05d2\u05d9\u05e0\u05d9\u05dd \u05d4\u05d7\u05e8\u05d3\u05d9\u05dd - \u05d4\u05d3\u05d1\u05e8 \u05d4\u05e2\u05d1\u05d9\u05e8 \u201c\u05de\u05e1\u05e8 \u05d1\u05e2\u05d9...", "\u21a9\ufe0f\ud83d\uddbc \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05e0\u05d2\u05d3 \u05d3\u05d1\u05e8\u05d9 \u05de\u05e0\u05d4\u05d9\u05d2 \u05d3\u05d2\u05dc \u05d4\u05ea\u05d5\u05e8\u05d4 \u05d4\u05e8\u05d1 \u05d3\u05d1 \u05dc\u05e0\u05d3\u05d5 \u05d0\u05d1\u05dc \u05d1\u05dc\u05d9 \u05dc\u05d4\u05d6\u05db\u05d9\u05e8 \u05d0\u05ea \u05e9\u05de\u05d5 \u05d1\u05de\u05e4\u05d5\u05e8\u05e9.", "\ud83d\uddbc \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05de\u05d2\u05e0\u05d4 \u05d0\u05ea \u05d3\u05d1\u05e8\u05d9 \u05d4\u05e8\u05d1 \u05dc\u05e0\u05d3\u05d5: \u05f4\u05de\u05d6\u05e2\u05d6\u05e2\u05d9\u05dd, \u05dc\u05d5\u05d7\u05de\u05d9\u05e0\u05d5 \u05e8\u05d0\u05d5\u05d9\u05d9\u05dd \u05dc\u05d4\u05e2\u05e8\u05db\u05d4 \u05e2\u05de\u05d5\u05e7\u05d4 \u05d2\u05dd \u05de\u05e2\u05d5\u05dc\u05dd \u05d4\u05ea\u05d5...", "\u05d0\u05dc\u05d9 \u05d4\u05d9\u05e8\u05e9\u05de\u05df", "\ud83d\uddbc \u05e9\u05d9\u05dc\u05d4 \u05e4\u05e8\u05d9\u05d3\ud83c\uddee\ud83c\uddf1 \u05de\u05e6\u05d8\u05d8 \u05d0\u05ea \u05d9\u05e9\u05e8\u05d0\u05dc \u05db\u05d4\u05df", "\ud83d\uddbc \u05e9\u05d9\u05dc\u05d4 \u05e4\u05e8\u05d9\u05d3\ud83c\uddee\ud83c\uddf1 \u05de\u05d2\u05d9\u05d1 \u05dc-\u05e9\u05d9\u05dc\u05d4 \u05e4\u05e8\u05d9\u05d3\ud83c\uddee\ud83c\uddf1", "\ud83d\uddbc \u05e6\u05d1\u05d0 \u05d0\u05e8\u05d4\"\u05d1 \u05d4\u05e9\u05d9\u05d1 \u05dc\u05d0\u05d6\u05d5\u05e8 \u05d0\u05ea \u05db\u05dc\u05d9 \u05d4\u05d0\u05d9\u05e1\u05d5\u05e3 MQ-4C Triton \u05e8\u05d7\u05e4\u05df \u05e6\u05d1\u05d0\u05d9 \u05d9\u05e7\u05e8 \u05e2\u05e8\u05da (\u05db-200 \u05de\u05d9\u05dc\u05d9\u05d5\u05df \u05d3\u05d5\u05dc\u05e8) \u05e9\u05e0\u05e2...", "\"\u05d4\u05d5\u05d9 \u05d6\u05d4\u05d9\u05e8 \u05d1\u05d2\u05d7\u05dc\u05ea\u05df\": \u05e8\u05d0\u05e9 \u05d4\u05de\u05de\u05e9\u05dc\u05d4 \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05de\u05e2\u05d6 \u05d4\u05d1\u05d5\u05e7\u05e8 \u05dc\u05ea\u05e7\u05d5\u05e3 \u05d0\u05ea \u05d3\u05d1\u05e8\u05d9 \u05de\u05e8\u05df \u05de\u05e0\u05d4\u05d9\u05d2 \u05d4\u05d3\u05d5\u05e8 \u05d4\u05d2\u05e8\"\u05d3 \u05dc\u05e0...", "\ud83c\udfac \u05e2\u05e4\u05e8\u05d0 \u05dc\u05e4\u05d5\u05de\u05d9\u05d4: \u05e8\u05d0\u05e9 \u05d4\u05de\u05de\u05e9\u05dc\u05d4 \u05d1\u05e0\u05d9\u05de\u05d9\u05df \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05d9\u05d5\u05e6\u05d0 \u05e0\u05d2\u05d3 \u05de\u05e8\u05df \u05d4\u05e8\u05d1 \u05dc\u05e0\u05d3\u05d5: \u05d0\u05e0\u05d9 \u05d3\u05d5\u05d7\u05d4 \u05d1\u05ea\u05d5\u05e7\u05e3 \u05d0\u05ea \u05d4\u05d3...", "\ud83d\uddbc \u05d0\u05d1\u05d9\u05e9\u05d9 \u05d2\u05e8\u05d9\u05e0\u05e6\u05d9\u05d9\u05d2: \u05dc\u05d0 \u05d9\u05d5\u05d3\u05e2 \u05de\u05d4 \u05e9\u05dc\u05d5\u05dd \u05de\u05e0\u05d4\u05dc\u05ea \u05d4\u05d4\u05d2\u05d9\u05e8\u05d4 \u05de\u05e8\u05e6\u05d5\u05df, \u05d0\u05d1\u05dc \u05d4\u05d1\u05d5\u05e7\u05e8 \u05d1\u05d1\u05d2\u05f4\u05e5 \u05e2\u05dc\u05d4 \u05e9\u05d0\u05e4\u05d9\u05dc\u05d5 \u05e2...", "\u05dc\u05d0\u05d5\u05e8 \u05d4\u05d4\u05ea\u05e4\u05ea\u05d7\u05d5\u05ea \u05de\u05d5\u05dc \u05d0\u05d9\u05e8\u05d0\u05df: \u05e8\u05d4\"\u05de \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05d9\u05e7\u05d9\u05d9\u05dd \u05d4\u05e2\u05e8\u05d1 \u05d3\u05d9\u05d5\u05df \u05d1\u05d9\u05d8\u05d7\u05d5\u05e0\u05d9", "\ud83c\udfac \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d0\u05d1\u05d9 \u05de\u05d5\u05e1\u05e7\u05d5\u05d1 Avi moskoff", "\u05e2\u05dc \u05e8\u05e7\u05e2 \u05d4\u05d4\u05e1\u05dc\u05de\u05d4, \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05d9\u05e2\u05e8\u05d5\u05da \u05d4\u05e2\u05e8\u05d1 \u05d3\u05d9\u05d5\u05df \u05d1\u05d9\u05d8\u05d7\u05d5\u05e0\u05d9 \u05de\u05e6\u05d5\u05de\u05e6\u05dd"]}