chat/218212", "https://t.me/N12chat/218215", "https://t.me/N12chat/218217", "https://t.me/N12chat/218219", "https://t.me/N12chat/218220", "https://t.me/N12chat/218221", "https://t.me/N12chat/218222", "https://t.me/N12chat/218223", "https://t.me/N12chat/218224"], "global_seen_titles": ["\ud83d\uddbc \u05d0\u05d1\u05d9\u05e9\u05d9 \u05d2\u05e8\u05d9\u05e0\u05e6\u05d9\u05d9\u05d2: \u05dc\u05d0 \u05d9\u05d5\u05d3\u05e2 \u05de\u05d4 \u05e9\u05dc\u05d5\u05dd \u05de\u05e0\u05d4\u05dc\u05ea \u05d4\u05d4\u05d2\u05d9\u05e8\u05d4 \u05de\u05e8\u05e6\u05d5\u05df, \u05d0\u05d1\u05dc \u05d4\u05d1\u05d5\u05e7\u05e8 \u05d1\u05d1\u05d2\u05f4\u05e5 \u05e2\u05dc\u05d4 \u05e9\u05d0\u05e4\u05d9\u05dc\u05d5 \u05e2...", "\u05dc\u05d0\u05d5\u05e8 \u05d4\u05d4\u05ea\u05e4\u05ea\u05d7\u05d5\u05ea \u05de\u05d5\u05dc \u05d0\u05d9\u05e8\u05d0\u05df: \u05e8\u05d4\"\u05de \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05d9\u05e7\u05d9\u05d9\u05dd \u05d4\u05e2\u05e8\u05d1 \u05d3\u05d9\u05d5\u05df \u05d1\u05d9\u05d8\u05d7\u05d5\u05e0\u05d9", "\ud83c\udfac \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d0\u05d1\u05d9 \u05de\u05d5\u05e1\u05e7\u05d5\u05d1 Avi moskoff", "\u05e2\u05dc \u05e8\u05e7\u05e2 \u05d4\u05d4\u05e1\u05dc\u05de\u05d4, \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05d9\u05e2\u05e8\u05d5\u05da \u05d4\u05e2\u05e8\u05d1 \u05d3\u05d9\u05d5\u05df \u05d1\u05d9\u05d8\u05d7\u05d5\u05e0\u05d9 \u05de\u05e6\u05d5\u05de\u05e6\u05dd", "\ud83d\uddbc \u05d4\u05e2\u05d9\u05ea\u05d5\u05e0\u05d0\u05d9 \u05d9\u05d7\u05d9\u05d0\u05dc \u05d2\u05dc\u05d0\u05d9 \u05de\u05d2\u05d7\u05da: \u05db\u05dc \u05e4\u05d9\u05e9\u05e8 \u05e2\u05d5\u05e9\u05d4 \u05d4\u05e8\u05e6\u05d0\u05d4", "2 \u05d9\u05e9\u05e8\u05d0\u05dc\u05d9\u05dd \u05d1\u05e9\u05e0\u05d5\u05ea \u05d4-20 \u05dc\u05d7\u05d9\u05d9\u05d4\u05dd \u05e0\u05e2\u05e6\u05e8\u05d5 \u05d1\u05d7\u05e9\u05d3 \u05e9\u05e2\u05e6\u05e8\u05d5 \u05d5\u05e9\u05d3\u05d3\u05d5 \u05e4\u05dc\u05e1\u05d8\u05d9\u05e0\u05d9 \u05d1\u05e2\u05ea \u05e9\u05e0\u05d4\u05d2 \u05d1\u05e8\u05db\u05d1\u05d5", "\u05e2\u05dc \u05e8\u05e7\u05e2 \u05d4\u05d4\u05e1\u05dc\u05de\u05d4, \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05d9\u05e2\u05e8\u05d5\u05da \u05d4\u05e2\u05e8\u05d1 \u05d3\u05d9\u05d5\u05df \u05d1\u05d9\u05d8\u05d7\u05d5\u05e0\u05d9 \u05de\u05e6\u05d5\u05de\u05e6\u05dd.", "\ud83d\uddbc \u05d0\u05d1\u05d9 \u05de\u05d5\u05e1\u05e7\u05d5\u05d1 Avi moskoff \u05de\u05e6\u05d8\u05d8 \u05d0\u05ea \u05d0\u05d1\u05d9 \u05de\u05d5\u05e1\u05e7\u05d5\u05d1 Avi moskoff", "*\u05e8\u05d0\u05e9 \u05d4\u05de\u05de\u05e9\u05dc\u05d4 \u05d1\u05e0\u05d9\u05de\u05d9\u05df \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05d1\u05d4\u05ea\u05d9\u05d9\u05d7\u05e1\u05d5\u05ea \u05dc\u05d3\u05d1\u05e8\u05d9 \u05d4\u05e8\u05d1 \u05dc\u05e0\u05d3\u05d5:*", "\ud83d\uddbc \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d1\u05e2\u05e7\u05d1\u05d5\u05ea \u05d3\u05d1\u05e8\u05d9 \u05d4\u05d2\u05e8\"\u05d3 \u05dc\u05e0\u05d3\u05d5, \u05d0\u05d5\u05d3\u05d5\u05ea \u05d7\u05d9\u05d9\u05dc\u05d9 \u05e6\u05d4\"\u05dc \u05de\u05d4\u05e6\u05d9\u05d5\u05e0\u05d5\u05ea \u05d4\u05d3\u05ea\u05d9\u05ea, \u05d4\u05d2\u05d9\u05d1 \u05e8\u05d0\u05e9 \u05d4\u05de\u05de\u05e9\u05dc\u05d4 ...", "\u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05e9\u05e0\u05d9 \u05e2\u05e6\u05d5\u05e8\u05d9 \u05e1\u05d5\u05dc\u05d1\u05e8\u05d2 \u05d4\u05d0\u05d7\u05e8\u05d5\u05e0\u05d9\u05dd \u05e9\u05d5\u05d7\u05e8\u05e8\u05d5 \u05d4\u05d9\u05d5\u05dd \u05d1\u05d4\u05dc\u05d9\u05da \u05e9\u05d7\u05e8\u05d5\u05e8 \u05de\u05d5\u05e7\u05d3\u05dd.", "\ud83c\udfac \u05de\u05e8\u05df \u05d2\u05d0\u05d5\u05df \u05d9\u05e9\u05e8\u05d0\u05dc \u05d4\u05d2\u05e8\"\u05d3 \u05dc\u05e0\u05d3\u05d5 \u05e9\u05dc\u05d9\u05d8\"\u05d0, \u05d9\u05e6\u05d0 \u05d1\u05de\u05ea\u05e7\u05e4\u05d4 \u05d7\u05e8\u05d9\u05e4\u05d4 \u05e0\u05d2\u05d3 \u05d0\u05e0\u05e9\u05d9 \u05d4\u05e6\u05d9\u05d5\u05e0\u05d5\u05ea \u05d4\u05d3\u05ea\u05d9\u05ea \u05d1\u05e9\u05d1\u05d5\u05e2 \u05e9...", "\ud83d\uddbc \u05de\u05e8\u05d3\u05db\u05d9 \u05d4\u05dc\u05e4\u05e8\u05d9\u05df \u05de\u05e6\u05d8\u05d8 \u05d0\u05ea Benjamin Netanyahu - \u05d1\u05e0\u05d9\u05de\u05d9\u05df \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5", "\u21a9\ufe0f \u05d0\u05d1\u05d9 \u05de\u05d5\u05e1\u05e7\u05d5\u05d1: \u05d4\u05e8\u05d1 \u05dc\u05e0\u05d3\u05d5 \u05db\u05d9\u05e0\u05d4 \u05d0\u05ea \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05f4\u05e9\u05e7\u05e8\u05df\u05f4 - \u05db\u05e2\u05ea \u05e8\u05d4\u05f4\u05de \u05de\u05e9\u05d9\u05d1 \u05d0\u05e9 \u05e0\u05d2\u05d3 \u05d4\u05de\u05e0\u05d4\u05d9\u05d2 \u05d4\u05e8\u05d5\u05d7\u05e0\u05d9", "\u05d0\u05e1\u05e3 \u05e8\u05d5\u05d6\u05e0\u05e6\u05d5\u05d9\u05d9\u05d2", "\ud83d\uddbc \u05ea\u05d5\u05e9\u05d1\u05d9\u05dd \u05d1\u05e8\u05de\u05ea \u05d0\u05d1\u05e8\u05d4\u05dd: \"\u05d4\u05e8\u05d7\u05d5\u05d1 \u05e0\u05d7\u05e1\u05dd \u05d1\u05de\u05e9\u05da \u05d6\u05de\u05df \u05e8\u05d1 \u05dc\u05dc\u05d0 \u05d4\u05e6\u05d3\u05e7\u05d4\"", "\u21a9\ufe0f \u05d4\u05d5\u05d3\u05e2\u05d4 \u05de\u05d8\u05e2\u05dd \u05d4\u05e2\u05d9\u05e8\u05d9\u05d9\u05d4: \u05d7\u05dc\u05d5\u05e7\u05ea \u05db\u05e8\u05d8\u05d9\u05e1\u05d9 \u05ea\u05d5\u05e9\u05d5\u05d5\u05d9\u05dd \u05d4\u05de\u05d0\u05e4\u05e9\u05e8 \u05d4\u05e9\u05ea\u05ea\u05e4\u05d5\u05ea \u05d5\u05db\u05e0\u05d9\u05e1\u05d4 \u05dc\u05d0\u05d9\u05e8\u05d5\u05e2\u05d9 \u05d4\u05e7\u05d9\u05e5 \u05d4\u05d2...", "\ud83d\uddbc \u05d9\u05e8\u05d3\u05df: \u05d4\u05e4\u05d2\u05d9\u05e2\u05d4 \u05d4\u05d0\u05d9\u05e8\u05d0\u05e0\u05d9\u05ea \u05d1\u05d1\u05e1\u05d9\u05e1 \u05d7\u05d9\u05dc \u05d4\u05d0\u05d5\u05d5\u05d9\u05e8 \u05de\u05d5\u05d5\u05d0\u05e4\u05e7 \u05e1\u05dc\u05d8\u05d9", "\u05e8\u05d0\u05e9 \u05d4\u05de\u05de\u05e9\u05dc\u05d4 \u05d9\u05db\u05e0\u05e1 \u05d3\u05d9\u05d5\u05df \u05d1\u05d9\u05d8\u05d7\u05d5\u05e0\u05d9 \u05d4\u05e2\u05e8\u05d1.", "\u05d1\u05de\u05e4\u05dc\u05d2\u05ea \u05d4\u05d3\u05de\u05d5\u05e7\u05e8\u05d8\u05d9\u05dd \u05e9\u05dc \u05d9\u05d0\u05d9\u05e8 \u05d2\u05d5\u05dc\u05df \u05dc\u05d0 \u05d0\u05d9\u05e9\u05e8\u05d5 \u05dc\u05e6\u05d5\u05d5\u05ea \u05d7\u05d3\u05e9\u05d5\u05ea 14 \u05dc\u05d4\u05d2\u05d9\u05e2 \u05dc\u05e1\u05e7\u05e8 \u05d0\u05ea \u05d0\u05d9\u05e8\u05d5\u05e2 \u05d4\u05e9\u05e7\u05ea \u05e8\u05e9\u05d9\u05de...", "\u05e2\u05dc \u05e8\u05e7\u05e2 \u05d4\u05de\u05ea\u05d9\u05d7\u05d5\u05ea \u05d4\u05d2\u05d5\u05d1\u05e8\u05ea \u05de\u05d5\u05dc \u05d0\u05d9\u05e8\u05d0\u05df \u05d5\u05d4\u05d4\u05e1\u05dc\u05de\u05d4 \u05d1\u05d0\u05d6\u05d5\u05e8, \u05e8\u05d0\u05e9 \u05d4\u05de\u05de\u05e9\u05dc\u05d4 \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05d9\u05e7\u05d9\u05d9\u05dd \u05d4\u05e2\u05e8\u05d1 \u05d3\u05d9\u05d5\u05df \u05d1...", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d3\u05d1\u05e8\u05d9 \u05d4\u05d2\u05e8\"\u05d3 \u05dc\u05e0\u05d3\u05d5 \u05e2\u05dc \u05d7\u05d9\u05d9\u05dc\u05d9 \u05d4\u05e6\u05d9\u05d5\u05e0\u05d5\u05ea \u05d4\u05d3\u05ea\u05d9\u05ea \u05e9\u05e2\u05d5\u05e8\u05e8\u05d5 \u05e1\u05e2\u05e8\u05d4", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05e2\u05de\u05d9\u05d0\u05dc \u05d9\u05e8\u05d7\u05d9", "\ud83d\uddbc *\u26bd\ufe0f \u05d0\u05d9\u05de\u05e4\u05e8\u05d9\u05d9\u05ea \u05d4\u05de\u05d9\u05dc\u05d9\u05d0\u05e8\u05d3\u05d9\u05dd \u05e9\u05dc \u05dc\u05d9\u05d0\u05d5 \u05de\u05e1\u05d9: \u05db\u05da \u05e0\u05e8\u05d0\u05d4 \u05d0\u05d5\u05e8\u05d7 \u05d4\u05d7\u05d9\u05d9\u05dd \u05e9\u05dc \u05d0\u05d7\u05d3 \u05d4\u05db\u05d3\u05d5\u05e8\u05d2\u05dc\u05e0\u05d9\u05dd \u05d4\u05e2\u05e9\u05d9\u05e8\u05d9...", "`[\u05d4\u05de\u05e9\u05da \u05de\u05d4\u05d5\u05d3\u05e2\u05d4 \u05e7\u05d5\u05d3\u05de\u05ea \ud83d\udc46]`", "\ud83d\uddbc \ud83d\ude05\ud83d\ude05\ud83d\ude05\ud83d\ude05", "\u05d7\u05dc\u05d5\u05e7\u05ea \u05db\u05e8\u05d8\u05d9\u05e1\u05d9 \u05ea\u05d5\u05e9\u05d5\u05d5\u05d9\u05dd \u05d4\u05de\u05d0\u05e4\u05e9\u05e8 \u05d4\u05e9\u05ea\u05ea\u05e4\u05d5\u05ea \u05d5\u05db\u05e0\u05d9\u05e1\u05d4 \u05dc\u05d0\u05d9\u05e8\u05d5\u05e2\u05d9 \u05d4\u05e7\u05d9\u05e5 \u05d4\u05d2\u05d3\u05d5\u05dc\u05d9\u05dd \u05d5\u05d4\u05de\u05d5\u05e9\u05e7\u05e2\u05d9\u05dd \u05e9\u05dc \u05d4\u05e2\u05d9...", "\u05e2\u05dd \u05d7\u05d9\u05d3\u05d5\u05e9 \u05d4\u05dc\u05d7\u05d9\u05de\u05d4 \u05d1\u05d0\u05d9\u05e8\u05d0\u05df: \u05de\u05d7\u05d9\u05e8 \u05d4\u05d1\u05e0\u05d6\u05d9\u05df \u05d4\u05de\u05de\u05d5\u05e6\u05e2 \u05d1\u05d0\u05e8\u05d4\"\u05d1 \u05e2\u05dc\u05d4 \u05e9\u05d5\u05d1 \u05dc\u05d9\u05d5\u05ea\u05e8 \u05de\u05d0\u05e8\u05d1\u05e2\u05d4 \u05d3\u05d5\u05dc\u05e8\u05d9\u05dd \u05dc\u05d2\u05dc\u05d5...", "\ud83c\udfac \u05e1\u05d5\u05e2\u05e8 \u05d1\u05e4\u05d9\u05d3 \u05e1\u05e4\u05d5\u05e8\u05d8: \u05e9\u05d7\u05e7\u05df \u05d0\u05e8\u05d2\u05e0\u05d8\u05d9\u05e0\u05d4 \u05d7\u05d5\u05dc\u05e3 \u05d0\u05de\u05e9 \u05e2\u05dc \u05e4\u05e0\u05d9\u05d5 \u05e9\u05dc \u05d4\u05e0\u05e9\u05d9\u05d0 \u05d8\u05e8\u05d0\u05de\u05e4 \u05d5\u05dc\u05d0 \u05dc\u05d7\u05e5 \u05dc\u05d5 \u05d0\u05ea \u05d4\u05d9\u05d3.", "\ud83c\udfac \u05d4\u05de\u05d5\u05e0\u05d3\u05d9\u05d0\u05dc: \u05de\u05d0\u05e8\u05e7 \u05e7\u05d5\u05e7\u05d5\u05e8\u05d9\u05d9\u05d4 \u05e9\u05d7\u05e7\u05df \u05e0\u05d1\u05d7\u05e8\u05ea \u05e1\u05e4\u05e8\u05d3 \u05dc\u05d5\u05e7\u05d7 \u05d0\u05ea \u05d2\u05d1\u05d9\u05e2 \u05d4\u05e2\u05d5\u05dc\u05dd \u05d4\u05d1\u05d9\u05ea\u05d4 \u05d1\u05e9\u05e7\u05d9\u05ea \u05d0\u05e9\u05e4\u05d4 \u05d2\u05d3\u05d5...", "\ud83d\uddbc \u05e8\u05d7\u05d5\u05d1 \u05d0\u05dc\u05d2'\u05dc\u05d0\u05d0' \u05d1\u05de\u05e2\u05e8\u05d1 \u05d4\u05e2\u05d9\u05e8 \u05e2\u05d6\u05d4 - \u05d9\u05d5\u05e0\u05d3\u05d0\u05d9 \u05d0\u05e7\u05e1\u05e0\u05d8 \u05d4\u05d5\u05ea\u05e7\u05e4\u05d4 \u05dc\u05e4\u05e0\u05d9 \u05d6\u05de\u05df \u05e7\u05e6\u05e8 \u05d1\u05e9\u05e0\u05d9 \u05d8\u05d9\u05dc\u05d9 \u05db\u05d8\u05d1\"\u05de", "\u05d0\u05d1\u05d9\u05d1\u05d9\u05ea \u05de\u05d9\u05e1\u05e0\u05d9\u05e7\u05d5\u05d1", "\ud83d\uddbc \u05d1\u05d1\u05d9\u05df \u05d4\u05d6\u05de\u05e0\u05d9\u05dd \u05d4\u05d6\u05d4 \u05d9\u05d5\u05e6\u05d0\u05d9\u05dd \u05dc\u05de\u05e1\u05e2 \u05d9\u05e9\u05e8\u05d0\u05dc\u05d9 \u05d1\u05d2\u05d1\u05e2\u05ea \u05d4\u05ea\u05d7\u05de\u05d5\u05e9\u05ea!", "\ud83d\uddbc \u05de\u05d8\u05d5\u05e1 \u05e8\u05d4\"\u05de \u05db\u05e0\u05e3 \u05e6\u05d9\u05d5\u05df \u05d4\u05de\u05e8\u05d9\u05d0, \u05e2\u05d5\u05e9\u05d4 \u05db\u05e8\u05d2\u05e2 \u05e1\u05d9\u05d1\u05d5\u05d1\u05d9\u05dd \u05de\u05e2\u05dc \u05e7\u05d5 \u05d4\u05d7\u05d5\u05e3 \u05de\u05d5\u05dc \u05ea\u05dc \u05d0\u05d1\u05d9\u05d1.", "\ud83d\uddbc \u05d1\u05d1\u05d9\u05ea \u05d4\u05e8\u05d1 \u05dc\u05e0\u05d3\u05d5 \u05de\u05d1\u05d4\u05d9\u05e8\u05d9\u05dd: \u05d4\u05e8\u05d1 \u05dc\u05d0 \u05d4\u05ea\u05db\u05d5\u05d5\u05df \u05dc\u05dc\u05d5\u05d7\u05de\u05d9 \u05d4\u05e6\u05d9\u05d5\u05e0\u05d5\u05ea \u05d4\u05d3\u05ea\u05d9\u05ea", "\ud83d\uddbc \u05d4\u05e2\u05e8\u05d9\u05e0\u05d2: \u05db\u05e0\u05e3 \u05e6\u05d9\u05d5\u05df \u05d4\u05de\u05e8\u05d9\u05d0 \u05db\u05e2\u05ea \u05d5\u05e2\u05d5\u05e9\u05d4 \u05e1\u05d9\u05d1\u05d5\u05d1\u05d9\u05dd \u05de\u05e2\u05dc \u05d7\u05d5\u05e4\u05d9 \u05d4\u05d9\u05dd", "\u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05dc\u05de\u05d4 \u05d4\u05d5\u05d0 \u05dc\u05d0 \u05d0\u05de\u05e8 \u05d0\u05ea \u05d6\u05d4 4 \u05e9\u05e0\u05d9\u05dd?", "\u05d2\u05d5\u05e8\u05de\u05d9\u05dd \u05d1\u05de\u05e2\u05e8\u05db\u05ea \u05d4\u05d1\u05d9\u05d8\u05d7\u05d5\u05df \u05d8\u05d5\u05e2\u05e0\u05d9\u05dd - \u05f4\u05d1\u05d4\u05e0\u05d4\u05d2\u05ea \u05d0\u05d9\u05e8\u05d0\u05df \u05d9\u05e9 \u05e1\u05d3\u05e7, \u05d5\u05d4\u05d5\u05d0 \u05d4\u05d2\u05d5\u05e8\u05dd \u05d4\u05d9\u05d7\u05d9\u05d3\u05d9 \u05e9\u05d3\u05d5\u05d7\u05d4 \u05ea\u05e7\u05d9\u05e4\u05d4 ...", "\ud83d\uddbc \u05d9\u05e2\u05e0\u05e7\u05d9 \u05e4\u05e8\u05d1\u05e8 | Yanki Farber \u05de\u05e6\u05d8\u05d8 \u05d0\u05ea \u05d9\u05d7\u05d9\u05d0\u05dc \u05d2\u05dc\u05d0\u05d9", "\ud83d\uddbc \u05d1\u05e0\u05ea\u05d9\u05d9\u05dd \u05e7\u05d1\u05d5\u05e6\u05ea \u05d7\u05d3\u05e9\u05d5\u05ea \u05e1\u05d2\u05d5\u05e8\u05d4. \u05d1\u05db\u05d9\u05e8\u05d4 \u05d1\u05e6\u05d4\"\u05dc \u05d5\u05e4\u05d9\u05e7\u05d5\u05d3 \u05d4\u05e2\u05d5\u05e8\u05e3.", "\ud83d\uddbc \u05de\u05e9\u05d8\u05e8\u05ea \u05d9\u05e9\u05e8\u05d0\u05dc \u05ea\u05e4\u05e1\u05d4 \u05d0\u05ea \u05e1\u05e4\u05d9\u05d9\u05d3\u05e8\u05de\u05df \ud83d\ude02", "\ud83c\udfac \u05ea\u05d9\u05e2\u05d5\u05d3 \u05de\u05e2\u05d6\u05d4 \u05e9\u05dc \u05d4\u05e8\u05d2\u05e2\u05d9\u05dd \u05d4\u05e8\u05d0\u05e9\u05d5\u05e0\u05d9\u05dd \u05dc\u05d0\u05d7\u05e8 \u05ea\u05e7\u05d9\u05e4\u05d4 \u05d9\u05e9\u05e8\u05d0\u05dc\u05d9\u05ea \u05e9\u05dc \u05e8\u05db\u05d1 \u05d1\u05de\u05e2\u05e8\u05d1 \u05d4\u05e2\u05d9\u05e8 \u05e2\u05d6\u05d4", "\ud83d\uddbc \u05db\u05db\u05d4 \u05d6\u05d4 \u05e9\u05d0\u05ea\u05d4 \u05e8\u05d5\u05e9\u05dd \u05d4\u05db\u05dc \u05d1\u05e6\u05d0\u05d8", "\ud83d\uddbc \u05d0\u05dc \u05ea\u05e9\u05db\u05d7\u05d5 \u05d0\u05ea \u05e2\u05e6\u05de\u05d9\u05db\u05dd.", "\ud83d\uddbc \u05d1\u05e2\u05d5\u05dc\u05dd \u05d4\u05d7\u05d9 \u05d9\u05e9 \u05de\u05d2\u05d5\u05d5\u05df \u05e9\u05dc \u05d3\u05d5\u05d2\u05de\u05d0\u05d5\u05ea \u05e9\u05dc \u05d4\u05d5\u05e8\u05d9\u05dd \u05e9\u05d9\u05e2\u05e9\u05d5 \u05d4\u05db\u05dc \u05d1\u05e9\u05d1\u05d9\u05dc \u05d4\u05e6\u05d0\u05e6\u05d0\u05d9\u05dd \u05e9\u05dc\u05d4\u05dd.", "\u05d2\u05e4\u05e0\u05d9 \u05d1'\u05de\u05e2\u05e8\u05d9\u05d1': \"\u05d4\u05de\u05de\u05e9\u05dc\u05d4 \u05e0\u05db\u05e9\u05dc\u05d4 \u05dc\u05d7\u05dc\u05d5\u05d8\u05d9\u05df \u05d1\u05de\u05d0\u05d1\u05e7 \u05d1\u05d9\u05d5\u05e7\u05e8 \u05d4\u05de\u05d7\u05d9\u05d4, \u05d5\u05d6\u05d4 \u05dc\u05d0 \u05d3\u05d1\u05e8 \u05d7\u05d3\u05e9 \u05d0\u05dc\u05d0 \u05e0\u05de\u05e9\u05da \u05d4\u05e8\u05d1\u05d4 ...", "\ud83d\uddbc \u05de\u05d8\u05d5\u05e1 \u05db\u05e0\u05e3 \u05e6\u05d9\u05d5\u05df \u05d4\u05de\u05e8\u05d9\u05d0 \u05d1\u05e9\u05e2\u05d4 \u05d4\u05d0\u05d7\u05e8\u05d5\u05e0\u05d4 \u05d5\u05e2\u05d5\u05e8\u05e8 \u05d2\u05dc \u05e1\u05e4\u05e7\u05d5\u05dc\u05e6\u05d9\u05d5\u05ea. \u05db\u05db\u05dc \u05d4\u05e0\u05e8\u05d0\u05d4 \u05de\u05d3\u05d5\u05d1\u05e8 \u05d1\u05ea\u05e8\u05d2\u05d9\u05dc.", "\u05d3\u05e1\u05e7 \u05d4\u05d7\u05d5\u05e5", "\u05e9\u05e8 \u05d4\u05d7\u05d5\u05e5 \u05d4\u05d0\u05de\u05e8\u05d9\u05e7\u05d0\u05d9 \u05de\u05e8\u05e7\u05d5 \u05e8\u05d5\u05d1\u05d9\u05d5 \u05d4\u05d1\u05d5\u05e7\u05e8: \u05e2\u05d3\u05d9\u05d9\u05df \u05e4\u05ea\u05d5\u05d7\u05d9\u05dd \u05dc\u05d0\u05e4\u05e9\u05e8\u05d5\u05ea \u05e9\u05dc \u05e4\u05ea\u05e8\u05d5\u05df \u05d3\u05d9\u05e4\u05dc\u05d5\u05de\u05d8\u05d9 \u05d1\u05d0\u05d9\u05e8\u05d0\u05df.", "\u05e4\u05d9\u05e7\u05d5\u05d3 \u05d4\u05de\u05e8\u05db\u05d6 \u05e9\u05dc \u05d0\u05e8\u05d4\"\u05d1: \u05dc\u05de\u05e2\u05dc\u05d4 \u05de-400 \u05d0\u05e0\u05e9\u05d9 \u05e6\u05d1\u05d0 \u05d0\u05de\u05e8\u05d9\u05e7\u05e0\u05d9\u05dd \u05e0\u05e4\u05e6\u05e2\u05d5 \u05d1\u05de\u05e1\u05d2\u05e8\u05ea \u05d4\u05e2\u05d9\u05de\u05d5\u05ea \u05e2\u05dd \u05d0\u05d9\u05e8\u05d0\u05df", "\ud83d\uddbc \u05d9\u05e2\u05e0\u05e7\u05d9 \u05e4\u05e8\u05d1\u05e8 | Yanki Farber \u05de\u05e6\u05d8\u05d8 \u05d0\u05ea \u05d3\u05e0\u05d9\u05d0\u05dc \u05d2\u05e8\u05d5\u05d1\u05d9\u05d9\u05e1 Daniel Grovais", "\u05d5\u05d5\u05d0\u05dc\u05d4:", "\u05e2\u05d5\u05d3 \u05de\u05d9\u05d5\"\u05e8 \u05d3\u05d2\u05dc \u05d4\u05ea\u05d5\u05e8\u05d4 \u05d7\"\u05db \u05d2\u05e4\u05e0\u05d9 \u05d1'\u05de\u05e2\u05e8\u05d9\u05d1': \"\u05d1\u05d3\u05d9\u05e2\u05d1\u05d3 \u05e2\u05e9\u05d9\u05e0\u05d5 \u05d8\u05e2\u05d5\u05ea \u05db\u05e9\u05e0\u05db\u05e0\u05e1\u05e0\u05d5 \u05dc\u05e7\u05d5\u05d0\u05dc\u05d9\u05e6\u05d9\u05d4 \u05d4\u05d6\u05d0\u05ea. \u05d4\u05dc...", "\ud83c\udfac *\u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05e1\u05e7\u05d5\u05e4\u05d9\u05dd*", "\ud83d\uddbc \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05e0\u05d9\u05e0\u05d5 \u05e9\u05dc \u05d4\u05d0\u05d3\u05de\u05d5\"\u05e8 \u05de\u05d5\u05d9\u05d6'\u05e0\u05d9\u05e5 \u05d7\u05d6\u05e8 \u05d1\u05d9\u05d5\u05dd \u05e8\u05d0\u05e9\u05d5\u05df \u05dc\u05ea\u05dc\u05de\u05d5\u05d3 \u05ea\u05d5\u05e8\u05d4 \u05d1\u05d0\u05e9\u05d3\u05d5\u05d3, \u05d5\u05d4\u05d2\u05d9\u05e9 \u05dc\u05de\u05dc\u05de\u05d3 '...", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d7\u05dc\u05d5\u05e7\u05ea \u05e4\u05d9\u05e6\u05d5\u05ea \u05d1\u05e6\u05e4\u05ea", "\ud83d\uddbc \u05d7\"\u05db\u05d9 \u05d3\u05d2\u05dc \u05d4\u05ea\u05d5\u05e8\u05d4 \u05d1\u05de\u05db\u05ea\u05d1 \u05d7\u05e8\u05d9\u05e3 \u05dc\u05e8\u05d0\u05e9 \u05e8\u05e9\u05d5\u05ea \u05d4\u05de\u05e1\u05d9\u05dd: \"\u05d4\u05d0\u05e9\u05de\u05d4 \u05e7\u05d5\u05dc\u05e7\u05d8\u05d9\u05d1\u05d9\u05ea \u05e9\u05dc \u05e6\u05d9\u05d1\u05d5\u05e8 \u05e2\u05e0\u05e7\".", "\ud83c\udfac \u05d0\u05ea\u05e8 \u05ea\u05e4\u05d9\u05dc\u05ea \u05e8\u05d1\u05d9\u05dd \u05e1\u05d5\u05e3 \u05e1\u05d5\u05e3 \u05d1\u05d0\u05d5\u05d5\u05d9\u05e8 - \u05db\u05dc \u05d9\u05d4\u05d5\u05d3\u05d9! \u05db\u05dc \u05d1\u05e7\u05e9\u05d4!\u05ea\u05e4\u05d9\u05dc\u05d4 \u05d0\u05d7\u05ea \u05d2\u05d3\u05d5\u05dc\u05d4!>> https://prayerofthemany.co...", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05de\u05d4\u05de\u05d7\u05d0\u05d4 \u05d1\u05e9\u05d1\u05ea \u05d4\u05d0\u05d7\u05e8\u05d5\u05e0\u05d4 \u05d1\u05e6\u05e4\u05ea", "\u05e8\u05d5\u05d1 \u05d4\u05db\u05e1\u05e3 \u05d1\u05ea\u05f4\u05d0 \u05dc\u05e2\u05de\u05d5\u05ea\u05d5\u05ea \u05d7\u05d1\u05f4\u05d3 | \u05d8\u05d5\u05d1\u05d9\u05d4 \u05d9\u05d2\u05dc\u05e0\u05d9\u05e7 \u05d7\u05d5\u05e9\u05e3 \u05db\u05d9 \u05de\u05e9\u05e8\u05d3 \u05d4\u05d4\u05ea\u05d9\u05d9\u05e9\u05d1\u05d5\u05ea \u05d4\u05e2\u05d1\u05d9\u05e8 \u05de\u05d9\u05dc\u05d9\u05d5\u05e0\u05d9\u05dd \u05de\u05ea...", "\u21a9\ufe0f\ud83c\udfac 14 \u05e4\u05e6\u05d5\u05e2\u05d9\u05dd \u05de\u05ea\u05d5\u05db\u05dd \u05db\u05de\u05d4 \u05d1\u05de\u05e6\u05d1 \u05e7\u05e9\u05d4 \u05d1\u05ea\u05e7\u05d9\u05e4\u05ea \u05d4\u05d9\u05d5\u05e0\u05d3\u05d0\u05d9 \u261d\ufe0f\u05d1\u05e8\u05d7\u05d5\u05d1 \u05d0\u05dc\u05d2'\u05dc\u05d0\u05d0' \u05d1\u05de\u05e2\u05e8\u05d1 \u05d4\u05e2\u05d9\u05e8 \u05e2\u05d6\u05d4.", "\u05d1\u05df \u05d2\u05d5\u05dc\u05d3\u05e4\u05e8\u05d9\u05d9\u05e0\u05d3", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d0\u05d1\u05d9 \u05de\u05d5\u05e1\u05e7\u05d5\u05d1 Avi moskoff", "\ud83c\udfac \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d4\u05e6\u05e6\u05d4 \u05e8\u05d0\u05e9\u05d5\u05e0\u05d4: \u05db\u05da \u05e0\u05e8\u05d0\u05d5\u05ea \u05d4\u05d4\u05db\u05e0\u05d5\u05ea \u05dc\u05d7\u05d5\u05e4\u05e9\u05d4 \u05d4\u05de\u05d5\u05d6\u05d9\u05e7\u05dc\u05d9\u05ea \u05d4\u05de\u05d3\u05d5\u05d1\u05e8\u05ea \u05e9\u05dc \u05d7\u05d1\u05e8\u05ea \u05d0\u05d1\u05d9-\u05de\u05d5\u05e8 \u05d1\u05e4...", "\ud83d\uddbc \u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05e1\u05e7\u05d5\u05e4\u05d9\u05dd", "\ud83d\uddbc *\ud83e\udde0\u2728 \u05dc\u05d4\u05d9\u05d5\u05ea \u05e9\u05e0\u05d5\u05d0 \u05e2\u05dc \u05d9\u05d3\u05d9 \u05d0\u05d9\u05d3\u05d9\u05d5\u05d8\u05d9\u05dd \u05d4\u05d5\u05d0 \u05d4\u05de\u05d7\u05d9\u05e8 \u05e9\u05d0\u05ea\u05d4 \u05de\u05e9\u05dc\u05dd \u05e2\u05dc \u05db\u05da \u05e9\u05d0\u05d9\u05e0\u05da \u05d0\u05d7\u05d3 \u05de\u05d4\u05dd.*", "\ud83d\uddbc \u05d1\u05e9\u05e0\u05ea 1972 \u05de\u05d5\u05d7\u05de\u05d3 \u05e8\u05d6\u05d0 \u05e9\u05d0\u05d4 \u05e4\u05d4\u05dc\u05d5\u05d5\u05d9, \u05d4\u05e9\u05d0\u05d4 \u05e9\u05dc \u05d0\u05d9\u05e8\u05d0\u05df \u05e9\u05d4\u05d9\u05d4 \u05d7\u05d5\u05d1\u05d1 \u05e8\u05db\u05d1 \u05de\u05d5\u05e9\u05d1\u05e2 \u05d5\u05d1\u05e2\u05dc \u05de\u05e0\u05d9\u05d5\u05ea \u05de\u05e8\u05db\u05d6\u05d9 ...", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d7\u05e8\u05d3\u05d9\u05dd10", "\u05d4\u05d8\u05dc\u05d2\u05e8\u05e3 \u05d4\u05d1\u05e8\u05d9\u05d8\u05d9: \u05d2\u05d5\u05e8\u05dd \u05d1\u05db\u05d9\u05e8 \u05d1\u05e4\u05e0\u05d8\u05d2\u05d5\u05df \u05de\u05d6\u05d4\u05d9\u05e8 \u05db\u05d9 \u05de\u05dc\u05d0\u05d9 \u05d4\u05d8\u05d9\u05dc\u05d9\u05dd \u05e9\u05dc \u05d0\u05e8\u05e6\u05d5\u05ea \u05d4\u05d1\u05e8\u05d9\u05ea \u05d4\u05e6\u05d8\u05de\u05e6\u05dd \u05d1\u05e2\u05e7\u05d1\u05d5\u05ea...", "\ud83c\udfac\ud83d\uddbc \u05e8\u05d0\u05e9 \u05de\u05de\u05e9\u05dc\u05ea \u05d1\u05e8\u05d9\u05d8\u05e0\u05d9\u05d4 \u05e7\u05d9\u05e8 \u05e1\u05d8\u05d0\u05e8\u05de\u05e8 \u05d4\u05ea\u05e4\u05d8\u05e8 \u05de\u05ea\u05e4\u05e7\u05d9\u05d3\u05d5 \u05dc\u05e4\u05e0\u05d9 \u05d6\u05de\u05df \u05e7\u05e6\u05e8, \u05d4\u05de\u05d7\u05dc\u05d9\u05e3 \u05d4\u05d5\u05d0 \u05d0\u05e0\u05d3\u05d9 \u05d1\u05e8\u05e0\u05d4...", "\ud83d\uddbc \u05d7\u05d1\u05e8\u05d9 \u05d4\u05db\u05e0\u05e1\u05ea \u05e9\u05dc \u05d3\u05d2\u05dc \u05d4\u05ea\u05d5\u05e8\u05d4 \u05d1\u05de\u05db\u05ea\u05d1 \u05d7\u05e8\u05d9\u05e3 \u05dc\u05e8\u05d0\u05e9 \u05e8\u05e9\u05d5\u05ea \u05d4\u05de\u05e1\u05d9\u05dd: \"\u05d4\u05d0\u05e9\u05de\u05d4 \u05e7\u05d5\u05dc\u05e7\u05d8\u05d9\u05d1\u05d9\u05ea \u05e9\u05dc \u05e6\u05d9\u05d1\u05d5\u05e8 \u05e2\u05e0...", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d8\u05d5\u05d1\u05d9\u05d4 \u05d9\u05d2\u05dc\u05e0\u05d9\u05e7", "\ud83d\uddbc \u05d8\u05d5\u05d1\u05d9\u05d4 \u05d9\u05d2\u05dc\u05e0\u05d9\u05e7 \u05de\u05d2\u05d9\u05d1 \u05dc-\u05d8\u05d5\u05d1\u05d9\u05d4 \u05d9\u05d2\u05dc\u05e0\u05d9\u05e7", "\ud83d\uddbc \u05e7\u05d5\u05e8\u05d5\u05ea \u05e2\u05e5 \u05e9\u05e8\u05d5\u05e4\u05d5\u05ea \u05de\u05d7\u05d5\u05e8\u05d1\u05df \u05d1\u05d9\u05ea \u05d4\u05de\u05e7\u05d3\u05e9 \u05d4\u05e8\u05d0\u05e9\u05d5\u05df \u05d4\u05ea\u05d2\u05dc\u05d5 \u05d1\u05d9\u05e8\u05d5\u05e9\u05dc\u05d9\u05dd.", "\ud83d\uddbc \u05d4\u05dc\u05d1 \u05e9\u05dc\u05d4\u05dd \u05dc\u05d0 \u05e2\u05de\u05d3 \u05d1\u05d6\u05d4: \u05e9\u05e0\u05d9 \u05d0\u05e0\u05e9\u05d9\u05dd \u05d1\u05d0\u05e8\u05d2\u05e0\u05d8\u05d9\u05e0\u05d4 \u05dc\u05e7\u05d5 \u05d1\u05d3\u05d5\u05dd \u05dc\u05d1 \u05d5\u05de\u05ea\u05d5 \u05d1\u05de\u05d4\u05dc\u05da \u05d2\u05de\u05e8 \u05d4\u05de\u05d5\u05e0\u05d3\u05d9\u05d0\u05dc \ud83d\udc94", "\u05d3\u05d2\u05dc \u05d4\u05ea\u05d5\u05e8\u05d4 \u05e9\u05dc \u05d2\u05e4\u05e0\u05d9 \u05d1\u05d4\u05d5\u05d3\u05e2\u05d4 \u05e0\u05d2\u05d3 \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5:", "\u05e9\u05e8\u05d5\u05df \u05e7\u05e0\u05d5\u05d1\u05dc\u05d9\u05da", "\u21a9\ufe0f \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05d3\u05d2\u05dc \u05d4\u05ea\u05d5\u05e8\u05d4", "\ud83d\uddbc \u05d9\u05e9\u05d9 \u05db\u05d4\u05df \u05de\u05e6\u05d8\u05d8 \u05d0\u05ea Benjamin Netanyahu - \u05d1\u05e0\u05d9\u05de\u05d9\u05df \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d9\u05e2\u05e0\u05e7\u05d9 \u05e4\u05e8\u05d1\u05e8 | Yanki Farber", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05d7\u05d1\u05e8 \u05d4\u05db\u05e0\u05e1\u05ea \u05de\u05e9\u05d4 \u05d2\u05e4\u05e0\u05d9", "\ud83d\uddbc \u05e6\u05d9\u05d5\u05e5 \u05e9\u05dc \u05e9\u05d9\u05dc\u05d4 \u05e4\u05e8\u05d9\u05d3\ud83c\uddee\ud83c\uddf1", "\ud83d\uddbc \u05db\u05db\u05d4 \u05e4\u05d5\u05ea\u05d7\u05d9\u05dd \u05d9\u05d5\u05dd \u05d1\u05d2\u05d0\u05d5\u05e8\u05d2\u05d9\u05d4\ud83d\udc9a\ud83d\udc9a\ud83d\udc9a\ud83c\uddec\ud83c\uddea", "\ud83c\udfac *\u05d4\u05e6\u05ea\u05d4 \u05d0\u05d5 \u05d2\u05e8\u05d9\u05de\u05ea \u05e9\u05e8\u05d9\u05e4\u05d4 \u05d1\u05e8\u05e9\u05dc\u05e0\u05d5\u05ea?*", "\u05d1- \u05e9\u05d9\u05dc\u05d4", "\u05d0\u05d9\u05ea\u05d9 \u05d2\u05dc-\u05d0\u05d5\u05df", "\ud83d\uddbc \u05dc\u05e7\u05e8\u05d0\u05ea \u05e6\u05d5\u05dd \u05ea\u05e9\u05e2\u05d4 \u05d1\u05d0\u05d1 \u05d9\u05ea\u05e7\u05d9\u05d9\u05dd \u05e7\u05d5 \u05e4\u05ea\u05d5\u05d7 \u05dc\u05e9\u05d0\u05dc\u05d5\u05ea \u05e8\u05e4\u05d5\u05d0\u05d9\u05d5\u05ea \u05d5\u05d4\u05dc\u05db\u05ea\u05d9\u05d5\u05ea, \u05d1\u05d4\u05e9\u05ea\u05ea\u05e4\u05d5\u05ea \u05e8\u05d1\u05e0\u05d9 \u05d1\u05d9\u05ea \u05d4\u05d4...", "\ud83d\uddbc *\u05d7\u05d3\u05e9\u05d5\u05ea \u05d4\u05e1\u05e7\u05d5\u05e4\u05d9\u05dd*", "\ud83d\uddbc *\u05dc\u05d4\u05d9\u05e9\u05d0\u05e8 \u05d1\u05df \u05ea\u05d5\u05e8\u05d4 \u05d5\u05dc\u05d4\u05e4\u05d5\u05da \u05dc\u05d7\u05d5\u05e7\u05e8 \u05d1\u05de\u05d5\u05d3\u05d9\u05e2\u05d9\u05df!*", "\ud83d\uddbc \u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05e4\u05e8\u05e1\u05d5\u05dd \u05e8\u05d0\u05e9\u05d5\u05df: \u05d3\u05d9\u05df \u05ea\u05d5\u05e8\u05d4 \u05d1\u05d1\u05d3\"\u05e6 \u05d1\u05e0\u05d9 \u05d1\u05e8\u05e7 (\u05d4\u05d2\u05e8\"\u05e0 \u05e7\u05e8\u05dc\u05d9\u05e5) \u05d1\u05e2\u05e0\u05d9\u05d9\u05df \u05d4\u05d1\u05e2\u05dc\u05d5\u05ea \u05e2\u05dc \u05d4\u05de\u05d6\u05d5\u05d6\u05d4 ...", "\u05d4\u05d0\u05d9\u05e8\u05d0\u05e0\u05d9\u05dd \u05d5\u05d4\u05d0\u05de\u05e8\u05d9\u05e7\u05d0\u05d9\u05dd \u05e6\u05d5\u05e2\u05d3\u05d9\u05dd \u05dc\u05d4\u05e8\u05d7\u05d1\u05d4 \u05d3\u05e8\u05de\u05d8\u05d9\u05ea \u05e9\u05dc \u05d4\u05de\u05dc\u05d7\u05de\u05d4, \u05d5\u05d0\u05dd \u05dc\u05d0 \u05d9\u05d4\u05d9\u05d4 \u05e9\u05d9\u05e0\u05d5\u05d9 \u05de\u05d4\u05d5\u05ea\u05d9 \u05d4\u05d3\u05d1\u05e8 \u05e2...", "\u05e4\u05d9\u05e7\u05d5\u05d3 \u05d4\u05de\u05e8\u05db\u05d6 \u05e9\u05dc \u05d0\u05e8\u05d4\"\u05d1 \u05de\u05e2\u05d3\u05db\u05df \u05db\u05d9 \u05dc\u05de\u05e2\u05dc\u05d4 \u05de-400 \u05d0\u05e0\u05e9\u05d9 \u05e6\u05d1\u05d0 \u05d0\u05de\u05e8\u05d9\u05e7\u05e0\u05d9\u05dd \u05e0\u05e4\u05e6\u05e2\u05d5 \u05d1\u05de\u05e1\u05d2\u05e8\u05ea \u05d4\u05e2\u05d9\u05de\u05d5\u05ea \u05d4\u05de\u05ea\u05de...", "\u21a9\ufe0f \u05d3\u05d2\u05dc \u05d4\u05ea\u05d5\u05e8\u05d4 \u05e0\u05d2\u05d3 \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5: \"\u05d3\u05d1\u05e8\u05d9 \u05d2\u05d3\u05d5\u05dc\u05d9 \u05d4\u05ea\u05d5\u05e8\u05d4 \u05d4\u05dd \u05e7\u05d5\u05d3\u05e9 \u05e7\u05d5\u05d3\u05e9\u05d9\u05dd \u05d5\u05de\u05e4\u05d9\u05d4\u05dd \u05d0\u05e0\u05d5 \u05d7\u05d9\u05d9\u05dd. \u05de\u05d9 \u05e9\u05d0\u05d9\u05e0\u05d5 ...", "\u05dc\u05d0\u05d7\u05e8 \u05dc\u05d9\u05dc\u05d4 \u05de\u05d7\u05d5\u05e5 \u05dc\u05d1\u05d9\u05ea: \u05d4\u05d3\u05d9\u05d9\u05e8\u05d9\u05dd \u05d4\u05d5\u05e8\u05e9\u05d5 \u05dc\u05e9\u05d5\u05d1 \u05dc\u05d1\u05e0\u05d9\u05d9\u05df \u05e9\u05e0\u05e4\u05d2\u05e2 \u05de\u05d4\u05e9\u05e8\u05d9\u05e4\u05d4 \u05d1\u05e8\u05de\u05ea \u05d0\u05d1\u05e8\u05d4\u05dd", "*\u05d3\u05d2\u05dc \u05d4\u05ea\u05d5\u05e8\u05d4 \u05d1\u05ea\u05d2\u05d5\u05d1\u05d4 \u05e2\u05dc \u05d4\u05d7\u05d5\u05e6\u05e4\u05d4 \u05e9\u05dc \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5 \u05db\u05dc\u05e4\u05d9 \u05de\u05e8\u05df \u05d4\u05d2\u05e8\u05f3\u05f3\u05d3 \u05dc\u05e0\u05d3\u05d5: \"\u05d3\u05d1\u05e8\u05d9 \u05d2\u05d3\u05d5\u05dc\u05d9 \u05d4\u05ea\u05d5\u05e8\u05d4 \u05d4\u05dd \u05e7\u05d5\u05d3...", "\u05d0\u05dc\u05d9 \u05d4\u05d9\u05e8\u05e9\u05de\u05df", "\u05d4\u05e4\u05e8\u05d2\u05d5\u05d3: \u05db-200 \u05d0\u05d5\u05d8\u05d5\u05d1\u05d5\u05e1\u05d9\u05dd \u05d9\u05e2\u05e9\u05d5 \u05d0\u05ea \u05d3\u05e8\u05db\u05dd \u05d1\u05e9\u05e2\u05d5\u05ea \u05d4\u05e2\u05e8\u05d1 \u05de\u05db\u05dc \u05e8\u05d9\u05db\u05d5\u05d6\u05d9 \u05d7\u05e1\u05d9\u05d3\u05d5\u05ea \u05d2\u05d5\u05e8 \u05d1\u05e8\u05d7\u05d1\u05d9 \u05d4\u05d0\u05e8\u05e5 \u05de\u05d7\u05e6...", "\ud83d\uddbc \u05ea\u05e7\u05d5\u05e2 \u05db\u05e2\u05ea \u05d1\u05db\u05d9\u05db\u05e8 \u05d1\u05e8\u05d7\u05d5\u05d1 \u05d0\u05d1\u05d9\u05d9 \u05d1\u05e8\u05de\u05ea \u05d1\u05d9\u05ea \u05e9\u05de\u05e9 \u05d3' \u2022 \u05e2\u05d5\u05e7\u05d1 \u05d4\u05e8\u05e9\u05ea: \u05d9\u05e9 \u05e1\u05d9\u05d1\u05d4 \u05dc\u05de\u05d4 \u05d4\u05dd \u05e0\u05ea\u05e7\u05e2\u05d9\u05dd \u05e7\u05d1\u05d5\u05e2 ...", "*\u05d9\u05de\u05de\u05d4 \u05d1\u05dc\u05d1\u05d3 \u05d0\u05d7\u05e8\u05d9 \u05e9\u05e0\u05e2\u05e6\u05e8: \u05d4\u05d7\u05e9\u05d5\u05d3 \u05d1\u05e0\u05d9\u05e1\u05d9\u05d5\u05df \u05d4\u05e6\u05ea\u05ea \u05e1\u05e0\u05d9\u05e3 \u05d2\u2019\u05e4\u05e0\u05d9\u05e7\u05d4 \u05d1\u05d7\u05d9\u05e4\u05d4 \u05e9\u05d5\u05d7\u05e8\u05e8 \u05d1\u05ea\u05e0\u05d0\u05d9\u05dd \u05de\u05d2\u05d1\u05d9\u05dc\u05d9\u05dd*", "\ud83c\udfac \u05e7\u05d9\u05e8 \u05e1\u05d8\u05d0\u05e8\u05de\u05e8: \u05e8\u05d0\u05e9 \u05de\u05de\u05e9\u05dc\u05ea \u05d1\u05e8\u05d9\u05d8\u05e0\u05d9\u05d4 \u05d4\u05de\u05ea\u05e4\u05d8\u05e8:"]}